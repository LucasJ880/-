# ═══════════════════════════════════════════════════════════
# 青砚 环境变量配置
# 复制为 .env：cp .env.example .env
# ═══════════════════════════════════════════════════════════

# ── 数据库 ──────────────────────────────────────────────────
# 本地：可用 Docker Postgres，或 Neon 免费库的「开发分支」
# DATABASE_URL 与 DIRECT_URL 在本地可填同一条连接串
# 生产（Neon）：控制台提供「Pooled」→ DATABASE_URL，「Direct」→ DIRECT_URL
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="同上或 Neon 提供的 Direct 连接串"

# ── 认证 ────────────────────────────────────────────────────
JWT_SECRET="请替换为至少 32 字节的随机字符串"
# SESSION_MAX_AGE_SECONDS=604800  # 默认 7 天

# ── AI / LLM（OpenAI 兼容：DeepSeek / 通义千问 等）──────────
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o
# OPENAI_MODEL_MINI=gpt-4o-mini
# OPENAI_MODEL_NANO=gpt-4o-mini

# AI 情报分析模型（可选，默认使用主模型）
# OPENAI_MODEL_INTELLIGENCE_REPORT=
# OPENAI_MODEL_INTELLIGENCE_REPORT_FALLBACK=
# OPENAI_TEMPERATURE_INTELLIGENCE_REPORT=0.3
# OPENAI_MAX_TOKENS_INTELLIGENCE_REPORT=8000
# OPENAI_REASONING_EFFORT_INTELLIGENCE_REPORT=medium

# 销售驾驶舱周报模型（可选，默认使用 OPENAI_MODEL）
# AI_MODEL=

# Agent Core 开关（设为 true 启用统一 Agent 引擎）
# AGENT_CORE_ENABLED=true

# ── 部署 URL ───────────────────────────────────────────────
# Next.js 应用的公开访问地址
NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_BASE_URL=http://localhost:3000
# VERCEL_URL 由 Vercel 平台自动注入，本地不需要设置

# ── Cron / 内部密钥 ────────────────────────────────────────
# 用于保护定时任务 API（如 /api/cron/*）
# CRON_SECRET=

# ── Google OAuth（可选） ────────────────────────────────────
# 用于 Google 日历同步和 Gmail 邮件发送
# 在 Google Cloud Console 创建 OAuth 2.0 客户端
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Gmail 邮件发送 OAuth（独立于日历 OAuth，共用 Client ID/Secret）
# GOOGLE_EMAIL_REDIRECT_URI=http://localhost:3000/api/auth/google-email/callback

# ── Vercel Blob Storage（可选）──────────────────────────────
# 供应商画册 PDF 上传
# 在 Vercel Dashboard → Storage → Blob 创建后自动注入
# 本地开发需从 Vercel 项目设置复制，或使用 `vercel env pull`
# BLOB_READ_WRITE_TOKEN=

# ── 邮件发送 Resend（可选，用于外贸开发信）──────────────────
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── 外贸搜索 Serper（可选，用于一键获客）──────────────────
# 注册地址：https://serper.dev
# SERPER_API_KEY=

# ── 微信开放平台登录（可选）───────────────────────────────
# 在 open.weixin.qq.com 创建「网站应用」后获取
# 授权回调域填写你的顶级域名（不带 https:// 和路径）
# WECHAT_OPEN_APP_ID=
# WECHAT_OPEN_APP_SECRET=

# ── 微信集成（可选）────────────────────────────────────────
# 个人微信 iLink Bot API
# 注册地址：https://ilinkai.com
# ILINK_API_BASE=https://ilinkai.weixin.qq.com
# ILINK_API_KEY=

# 企业微信回调验证 Token
# WECHAT_TOKEN=

# ── WhatsApp 集成（可选）───────────────────────────────────
# WHATSAPP_VERIFY_TOKEN=

# ── Upstash Redis 分布式限流（可选，强烈建议生产启用）──────
# Vercel 多实例部署时，内存限流会"每实例各限一份"，实际失效。
# 配置 Upstash 后，AI/认证接口的限流将跨实例生效。
# 注册 https://upstash.com → 创建 Redis（选 Global 或就近区域）→ 复制 REST 配置
# 未设置时会自动退回到内存限流（单实例可用）
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxx

# ── Sentry 错误监控（可选，强烈建议生产启用）───────────────
# 注册 https://sentry.io → 创建 Next.js 项目 → 复制 DSN
# 同一个 DSN 用于服务端；前端用 NEXT_PUBLIC_SENTRY_DSN（可同值）
# 未设置时会自动跳过初始化，不影响应用运行
# SENTRY_DSN=https://xxx@o0.ingest.sentry.io/0
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@o0.ingest.sentry.io/0

# ── 开发/测试 ──────────────────────────────────────────────
# API 集成测试需要（npm test -- --api）
# BASE_URL=http://localhost:3000
# COOKIE="sid=xxx"
