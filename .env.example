# ═══════════════════════════════════════════════════════════
# 青砚 环境变量配置
# 复制为 .env：cp .env.example .env
# ═══════════════════════════════════════════════════════════

# ── 数据库 ──────────────────────────────────────────────────
# 本地：可用 Docker Postgres，或 Neon 免费库的「开发分支」
# DATABASE_URL 与 DIRECT_URL 在本地可填同一条连接串
# 生产（Neon）：控制台提供「Pooled」→ DATABASE_URL，「Direct」→ DIRECT_URL
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="同上或 Neon 提供的 Direct 连接串"

# ── 认证 ────────────────────────────────────────────────────
JWT_SECRET="请替换为至少 32 字节的随机字符串"
# SESSION_MAX_AGE_SECONDS=604800  # 默认 7 天

# ── AI / LLM（统一 ModelRegistry）──────────────────────────
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# 推荐新变量（优先于旧 OPENAI_MODEL*）
OPENAI_CHAT_MODEL=gpt-5.6-sol
OPENAI_REASONING_MODEL=gpt-5.6-terra
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_MODEL_PINNED=gpt-image-2-2026-04-21
# 兼容旧变量（仍可读取；未设置新变量时回退）
# OPENAI_MODEL=gpt-5.6-sol
# OPENAI_MODEL_MINI=gpt-5.6-terra
# OPENAI_MODEL_NANO=gpt-5.6-sol
# OPENAI_VISION_MODEL=
# OPENAI_FAST_MODEL=

# 市场情报深度研究（后台运行；主模型默认 16K，失败后自动切换备用模型）
# OPENAI_MODEL_MARKET_INTELLIGENCE=
# OPENAI_MAX_TOKENS_MARKET_INTELLIGENCE=16000
# OPENAI_TIMEOUT_MS_MARKET_INTELLIGENCE=120000
# OPENAI_TOTAL_TIMEOUT_MS_MARKET_INTELLIGENCE=180000
# OPENAI_MODEL_MARKET_INTELLIGENCE_FALLBACK=
# OPENAI_MAX_TOKENS_MARKET_INTELLIGENCE_FALLBACK=8000
# OPENAI_TIMEOUT_MS_MARKET_INTELLIGENCE_FALLBACK=90000
# OPENAI_TOTAL_TIMEOUT_MS_MARKET_INTELLIGENCE_FALLBACK=105000

# AI 情报分析模型（可选，默认使用主模型）
# OPENAI_MODEL_INTELLIGENCE_REPORT=
# OPENAI_MODEL_INTELLIGENCE_REPORT_FALLBACK=
# OPENAI_TEMPERATURE_INTELLIGENCE_REPORT=0.3
# OPENAI_MAX_TOKENS_INTELLIGENCE_REPORT=8000
# OPENAI_REASONING_EFFORT_INTELLIGENCE_REPORT=medium

# 销售驾驶舱周报模型（可选，默认使用 OPENAI_CHAT_MODEL）
# AI_MODEL=

# Agent Core 开关（设为 true 启用统一 Agent 引擎）
# AGENT_CORE_ENABLED=true

# ── AI Operator（协同主助手：工具调用 / 执行时间线 / 待确认审批）──
# 总开关；未开则 /assistant 走 legacy 纯对话，无工具时间线与审批卡
AI_OPERATOR_ENABLED=1
# 百分比灰度 0–100；白名单为空时生效。本地/MVP 建议 100
AI_OPERATOR_ROLLOUT_PCT=100
# 可选：仅指定用户或角色开启（设置后未命中者关闭，不再看 ROLLOUT_PCT）
# AI_OPERATOR_USER_ALLOWLIST=
# AI_OPERATOR_ROLE_ALLOWLIST=admin,sales,user

# ── 主管 AI Supervisor（默认关闭；开启后网页协同 + 企微/个微协同一律走主管 AI）──
AGENT_SUPERVISOR_ENABLED=0
AGENT_SUPERVISOR_ROLLOUT_PCT=0
# AGENT_SUPERVISOR_USER_ALLOWLIST=
# AGENT_SUPERVISOR_ROLE_ALLOWLIST=admin,super_admin,manager,sales,trade,user
# AGENT_SUPERVISOR_ORG_ALLOWLIST=sunny-home-deco,lucas-bid
# 建议先开：ENABLED=1 + ORG_ALLOWLIST=测试组织 + ROLE_ALLOWLIST 覆盖组织内常用角色

# ── 人机协作学习 Phase1（默认全关；勿自动开生产）──
EMPLOYEE_AI_LEARNING_ENABLED=0
EMPLOYEE_AI_FEEDBACK_ENABLED=0
EMPLOYEE_AI_OUTCOME_TRACKING_ENABLED=0
EMPLOYEE_AI_PLAYBOOKS_ENABLED=0
# EMPLOYEE_AI_ORG_ALLOWLIST=sunny-home-deco
# EMPLOYEE_AI_USER_ALLOWLIST=
# EMPLOYEE_AI_ROLE_ALLOWLIST=admin,manager,sales,marketing,user
# EMPLOYEE_AI_DEPARTMENT_ALLOWLIST=sales,marketing

# ── AI 外贸产品内容总监 Phase1 ──
# 默认 dry-run：不调用真实图片 Provider（本地/预览建议保持 1）
PRODUCT_CONTENT_IMAGE_DRY_RUN=1
# 图片模型统一走 OPENAI_IMAGE_MODEL（见上方 ModelRegistry），勿再维护 PRODUCT_CONTENT_IMAGE_MODEL
# PRODUCT_CONTENT_MULTIMODAL_QA=1
# 设为 0 时禁止真实出图（即使 dry-run=0）
# PRODUCT_CONTENT_IMAGE_GENERATE_ENABLED=0
# 本地验收无 private Blob store：1=写入 .data/product-content-blobs
# PRODUCT_CONTENT_LOCAL_STORE=1

# SUPERVISOR_MAX_STEPS=5
# SUPERVISOR_MAX_REPLANS=2
# SUPERVISOR_MAX_SKILL_CALLS=6
# SUPERVISOR_TIMEOUT_MS=120000
# 主管模型（未设置时使用 OPENAI_MODEL / 已验证可用的 primary；勿默认 luna）
# AGENT_SUPERVISOR_PLANNER_MODEL=
# AGENT_SUPERVISOR_OBSERVER_MODEL=
# AGENT_SUPERVISOR_SUMMARY_MODEL=
# AGENT_SUPERVISOR_REPAIR_MODEL=
# Embedding（知识检索；失败时显式降级，不假装已综合知识库）
# AGENT_EMBEDDING_MODEL=text-embedding-3-small

# ── 部署 URL ───────────────────────────────────────────────
# Next.js 应用的公开访问地址
NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_BASE_URL=http://localhost:3000
# VERCEL_URL 由 Vercel 平台自动注入，本地不需要设置

# ── Postiz Cloud / 社媒自动发布（可选）──────────────────────
# Cloud 填 https://api.postiz.com；自建实例填 https://ops.你的域名.com
# API Key 在 Postiz Settings → Developers → Public API 生成，仅保存到 Vercel 加密环境变量
# POSTIZ_API_URL=https://api.postiz.com
# POSTIZ_API_KEY=

# 市场情报竞品监听：Firecrawl API + webhook 鉴权
# FIRECRAWL_API_KEY=fc-xxx
# 官方 HMAC secret（Firecrawl Advanced settings）；推荐配置
# FIRECRAWL_WEBHOOK_SECRET=
# 无官方 secret 时可使用独立高熵共享 token，青砚创建 monitor 时会放入私有请求头
# MARKET_INTELLIGENCE_WEBHOOK_TOKEN=

# ── Growth Center / Activepieces（可选，推荐）────────────────
# Activepieces 独立部署，青砚仍是企业事实、审批、任务、实验与结果的真相源。
# 双向 Webhook 使用同一高熵 HMAC 密钥；不要暴露到 NEXT_PUBLIC_*。
# ACTIVEPIECES_WEBHOOK_SECRET=
# ACTIVEPIECES_MARKETING_SYNC_WEBHOOK_URL=https://automation.example.com/api/v1/webhooks/...
# ACTIVEPIECES_MARKETING_HEALTH_WEBHOOK_URL=https://automation.example.com/api/v1/webhooks/...
# ACTIVEPIECES_MARKETING_DAILY_BRIEF_WEBHOOK_URL=https://automation.example.com/api/v1/webhooks/...
# ACTIVEPIECES_MARKETING_EXPERIMENT_WEBHOOK_URL=https://automation.example.com/api/v1/webhooks/...
# ACTIVEPIECES_MMM_RUN_WEBHOOK_URL=https://automation.example.com/api/v1/webhooks/...
# Activepieces 回调青砚：POST /api/integrations/activepieces/webhook
# 回调头：x-qingyan-timestamp、x-qingyan-signature=sha256(HMAC)

# Meridian 在独立 Python Worker 中运行；模型结果通过上方回调写回青砚。
# 当前版本不在 Vercel 请求进程中安装或运行 Python/GPU 模型。

# ── Cron / 内部密钥 ────────────────────────────────────────
# 用于保护定时任务 API（如 /api/cron/*）
# CRON_SECRET=

# ── Google OAuth（可选） ────────────────────────────────────
# 用于 Google 日历同步和 Gmail 邮件发送
# 在 Google Cloud Console 创建 OAuth 2.0 客户端
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Gmail 邮件发送 OAuth（独立于日历 OAuth，共用 Client ID/Secret）
# GOOGLE_EMAIL_REDIRECT_URI=http://localhost:3000/api/auth/google-email/callback

# ── Vercel Blob Storage（可选）──────────────────────────────
# 供应商画册 PDF 上传
# 在 Vercel Dashboard → Storage → Blob 创建后自动注入
# 本地开发需从 Vercel 项目设置复制，或使用 `vercel env pull`
# BLOB_READ_WRITE_TOKEN=

# ── 邮件发送 Resend（可选，用于外贸开发信）──────────────────
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── 外贸搜索 Serper（可选，用于一键获客）──────────────────
# 注册地址：https://serper.dev
# SERPER_API_KEY=

# ── Firecrawl（可选，Trade 研究：map + scrape 增强站内证据）──
# https://firecrawl.dev — 未配置或失败时自动退回 Serper + fetch 首页
# FIRECRAWL_API_KEY=
# FIRECRAWL_ENABLED=true
# 单次研究最多抓取页数（3–5，默认 5）
# FIRECRAWL_MAX_RESEARCH_PAGES=5
# 单次 map/scrape 请求超时毫秒（约 8000–60000，默认 25000）
# FIRECRAWL_TIMEOUT_MS=25000

# ── 微信开放平台登录（可选）───────────────────────────────
# 在 open.weixin.qq.com 创建「网站应用」后获取
# 授权回调域填写你的顶级域名（不带 https:// 和路径）
# WECHAT_OPEN_APP_ID=
# WECHAT_OPEN_APP_SECRET=

# ── 微信集成（可选）────────────────────────────────────────
# 个人微信 iLink Bot API
# 注册地址：https://ilinkai.com
# ILINK_API_BASE=https://ilinkai.weixin.qq.com
# ILINK_API_KEY=

# 企业微信回调对外展示域名（备案子域名，供设置页拼回调 URL）
# 未设置时设置页回退为当前浏览器 origin（qingyan.ca 上容易填错）
# NEXT_PUBLIC_WECHAT_PUBLIC_ORIGIN=https://wechat.mengxinhometextile.com

# 企业微信回调验证 Token（遗留；实际 Token 存在组织 WeChatGateway）
# WECHAT_TOKEN=

# ── WhatsApp 集成（可选）───────────────────────────────────
# WHATSAPP_VERIFY_TOKEN=

# ── Upstash Redis 分布式限流（可选，强烈建议生产启用）──────
# Vercel 多实例部署时，内存限流会"每实例各限一份"，实际失效。
# 配置 Upstash 后，AI/认证接口的限流将跨实例生效。
# 注册 https://upstash.com → 创建 Redis（选 Global 或就近区域）→ 复制 REST 配置
# 未设置时会自动退回到内存限流（单实例可用）
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxx

# ── Sentry 错误监控（可选，强烈建议生产启用）───────────────
# 注册 https://sentry.io → 创建 Next.js 项目 → 复制 DSN
# 同一个 DSN 用于服务端；前端用 NEXT_PUBLIC_SENTRY_DSN（可同值）
# 未设置时会自动跳过初始化，不影响应用运行
# SENTRY_DSN=https://xxx@o0.ingest.sentry.io/0
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@o0.ingest.sentry.io/0

# ── 开发/测试 ──────────────────────────────────────────────
# API 集成测试需要（npm test -- --api）
# BASE_URL=http://localhost:3000
# COOKIE="sid=xxx"
