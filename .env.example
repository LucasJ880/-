# 复制为 .env：cp .env.example .env
#
# 本地：可用 Docker Postgres，或 Neon 免费库的「开发分支」。
# DATABASE_URL 与 DIRECT_URL 在本地可填同一条连接串（非连接池直连）。
# 生产（Neon）：控制台提供「Pooled」→ DATABASE_URL，「Direct」→ DIRECT_URL。

# 必须从 Neon「Connect」复制整段 URL，勿用「……」等占位符当主机名
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="同上或 Neon 提供的 Direct 连接串"

JWT_SECRET="请替换为至少 32 字节的随机字符串"

# AI（OpenAI 兼容：DeepSeek / 通义千问 等）
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-5.2
# OPENAI_MODEL_MINI=gpt-5-mini

# Vercel Blob Storage（供应商画册 PDF 上传）
# 在 Vercel Dashboard → Storage → Blob 创建后自动注入
# 本地开发需从 Vercel 项目设置复制，或使用 `vercel env pull`
# BLOB_READ_WRITE_TOKEN=

# Google OAuth（可选；线上请改为 https 回调地址）
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://你的域名/api/auth/google/callback

# Gmail 邮件发送 OAuth（独立于日历 OAuth，共用 Client ID/Secret）
# GOOGLE_EMAIL_REDIRECT_URI=https://你的域名/api/auth/google-email/callback

# 个人微信 iLink Bot API（可选）
# 注册地址：https://ilinkai.com 或其他个人微信 Bot 服务
# ILINK_API_BASE=https://ilinkai.weixin.qq.com
# ILINK_API_KEY=
