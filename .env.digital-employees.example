# Digital Employees Phase 1 — safe rollout template
# Copy these values into the Preview deployment environment after audit passes.
# Do NOT apply to Production until Phase 1 acceptance is complete.

# Master switch and rollout scope
DIGITAL_EMPLOYEES_ENABLED=1
DIGITAL_EMPLOYEE_ORG_ALLOWLIST=cmrtcnz1c0001sbjcy87hemyl
DIGITAL_EMPLOYEE_USER_ALLOWLIST=cmmy6zimk0000ju04hrln3yqv
# DIGITAL_EMPLOYEE_ROLE_ALLOWLIST=admin,sales

# Existing digital employees
DIGITAL_EMPLOYEE_DAILY_BRIEF_ENABLED=1
DIGITAL_EMPLOYEE_CUSTOMER_FOLLOWUP_ENABLED=1
DIGITAL_EMPLOYEE_QUOTE_RISK_ENABLED=1
DIGITAL_EMPLOYEE_PROJECT_HEALTH_ENABLED=1
DIGITAL_EMPLOYEE_MARKETING_BRIEF_ENABLED=1

# Web assistant Operator — Lucas-only first
AI_OPERATOR_ENABLED=1
AI_OPERATOR_USER_ALLOWLIST=cmmy6zimk0000ju04hrln3yqv
AI_OPERATOR_ROLLOUT_PCT=0

# Gmail remains draft-only
GMAIL_DRAFT_ENABLED=true

# Keep Supervisor limited during Phase 1
AGENT_SUPERVISOR_ENABLED=0
AGENT_SUPERVISOR_ROLLOUT_PCT=0
# AGENT_SUPERVISOR_ORG_ALLOWLIST=cmrtcnz1c0001sbjcy87hemyl
# AGENT_SUPERVISOR_USER_ALLOWLIST=cmmy6zimk0000ju04hrln3yqv

# Keep learning disabled until governance review
EMPLOYEE_AI_LEARNING_ENABLED=0
EMPLOYEE_AI_FEEDBACK_ENABLED=0
EMPLOYEE_AI_OUTCOME_TRACKING_ENABLED=0
EMPLOYEE_AI_PLAYBOOKS_ENABLED=0

# Product-content real image generation remains dry-run in Phase 1
PRODUCT_CONTENT_IMAGE_DRY_RUN=1
PRODUCT_CONTENT_IMAGE_GENERATE_ENABLED=0

# Required for existing scheduled jobs (already configured on Vercel Preview/Production)
# CRON_SECRET=<reuse existing Vercel CRON_SECRET>
