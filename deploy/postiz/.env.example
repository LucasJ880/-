# 复制为 .env 后填写真实值（.env 不入库）

# Postiz 访问域名（先做好 DNS A 记录指向本服务器，Caddy 会自动签 HTTPS 证书）
POSTIZ_DOMAIN=ops.example.com

# 随机长字符串（生成：openssl rand -hex 32）
JWT_SECRET=

# Postiz 数据库密码（生成：openssl rand -hex 16）
POSTGRES_PASSWORD=

# 建好团队账号后改为 true 并 docker compose up -d 重启，禁止陌生人注册
DISABLE_REGISTRATION=false

# ── Meta 开发者应用（M0 申请；同一应用覆盖 Facebook + Instagram）──
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ── 可选 ──
THREADS_APP_ID=
THREADS_APP_SECRET=
# 填了才启用 Postiz 内置 AI 文案（也可以不填，文案由青砚侧生成）
OPENAI_API_KEY=
