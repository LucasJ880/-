generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

/// pgvector 扩展 — 用于向量相似度搜索

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}


model User {
  id           String    @id @default(cuid())
  email        String    @unique
  phone        String?
  passwordHash String?
  authProvider String    @default("email")
  name         String
  nickname     String?
  avatar       String?
  role         String    @default("user")
  status       String    @default("active")
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // 销售个人配置 — 在驾驶舱"销售个人设置"里一次性填写
  salesRepInitials String? // 如 "LJ"，用于自动生成报价单编号

  projects           Project[]
  tasks              Task[]             @relation("TaskAssignee")
  createdTasks       Task[]             @relation("TaskCreator")
  comments           TaskComment[]
  activities         TaskActivity[]
  calendarEvents     CalendarEvent[]
  calendarProviders  CalendarProvider[]
  blindsOrders       BlindsOrder[]
  reminders          Reminder[]
  notifications               Notification[] @relation("UserNotifications")
  notificationPreference      UserNotificationPreference?
  projectNotificationRules    ProjectNotificationRule[]
  ownedOrgs          Organization[]
  orgMemberships     OrganizationMember[]
  projectMemberships ProjectMember[]
  auditLogs          AuditLog[]
  promptsCreated     Prompt[]           @relation("PromptCreatedBy")
  promptsUpdated     Prompt[]           @relation("PromptUpdatedBy")
  promptVersions     PromptVersion[]    @relation("PromptVersionCreatedBy")
  promptPublishLogs  PromptPublishLog[] @relation("PromptPublishBy")

  knowledgeBasesCreated            KnowledgeBase[]              @relation("KnowledgeBaseCreatedBy")
  knowledgeBasesUpdated            KnowledgeBase[]              @relation("KnowledgeBaseUpdatedBy")
  knowledgeBaseVersionsCreated     KnowledgeBaseVersion[]       @relation("KBVersionCreatedBy")
  knowledgeDocumentsCreated        KnowledgeDocument[]          @relation("KnowledgeDocumentCreatedBy")
  knowledgeDocumentsUpdated        KnowledgeDocument[]          @relation("KnowledgeDocumentUpdatedBy")
  projectMessages                  ProjectMessage[]             @relation("ProjectMessageSender")
  knowledgeDocumentVersionsCreated KnowledgeDocumentVersion[]   @relation("KDVersionCreatedBy")
  knowledgePublishLogs             KnowledgePublishLog[]        @relation("KBPublishedBy")

  conversations                    Conversation[]               @relation("ConversationUser")
  aiThreads                        AiThread[]

  agentsCreated                    Agent[]                      @relation("AgentCreatedBy")
  agentsUpdated                    Agent[]                      @relation("AgentUpdatedBy")
  agentVersionsCreated             AgentVersion[]               @relation("AgentVersionCreatedBy")
  toolsCreated                     ToolRegistry[]               @relation("ToolCreatedBy")
  toolsUpdated                     ToolRegistry[]               @relation("ToolUpdatedBy")
  agentTasksCreated                AgentTask[]                  @relation("AgentTaskCreatedBy")
  customFlowTemplates              CustomFlowTemplate[]         @relation("CustomFlowTemplateCreatedBy")

  // AI Memory
  memories                         UserMemory[]

  // Dynamic Skills
  agentSkillsCreated               AgentSkill[]                 @relation("AgentSkillCreatedBy")

  // WeChat Bindings
  wechatBindings                   WeChatBinding[]              @relation("UserWeChatBindings")

  // Sales CRM relations
  salesCustomersCreated            SalesCustomer[]              @relation("SalesCustomerCreatedBy")
  salesOpportunitiesAssigned       SalesOpportunity[]           @relation("SalesOpportunityAssignee")
  salesOpportunitiesCreated        SalesOpportunity[]           @relation("SalesOpportunityCreatedBy")
  customerInteractionsCreated      CustomerInteraction[]        @relation("CustomerInteractionCreatedBy")
  salesQuotesCreated               SalesQuote[]                 @relation("SalesQuoteCreatedBy")

  // Appointments
  appointmentsAssigned             Appointment[]                @relation("AppointmentAssignee")
  appointmentsCreated              Appointment[]                @relation("AppointmentCreatedBy")

  // Email Binding
  emailBinding                     EmailBinding?

  // Sales RAG
  salesInsights                    SalesInsight[]           @relation("SalesInsightUser")
  coachingRecords                  CoachingRecord[]         @relation("CoachingRecordUser")

  // 微信开放平台 OpenID（网站应用扫码登录）
  wechatOpenId  String?   @unique

  // 邀请码溯源
  inviteCodeId  String?

  @@index([status])
  @@index([authProvider])
  @@index([role])
}

// ============================================================
// 销售邮箱绑定 — SMTP 发信配置（一次绑定，自动发信）
// ============================================================

model EmailBinding {
  id            String    @id @default(cuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id])

  email         String    // 发信邮箱地址 (e.g. sales@sunny.com)
  displayName   String    // 发件人显示名 (e.g. "Kevin @ Sunny Blinds")
  provider      String    @default("smtp") // smtp / gmail / outlook
  smtpHost      String?   // smtp.gmail.com / smtp.office365.com
  smtpPort      Int?      @default(587)
  smtpUser      String?   // 通常是邮箱地址
  smtpPass      String?   // App Password（加密存储）
  useTls        Boolean   @default(true)

  verified      Boolean   @default(false)
  verifiedAt    DateTime?
  lastSentAt    DateTime?
  lastError     String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([email])
}

// ============================================================
// 邀请码（注册准入 + 角色绑定）
// ============================================================

model InviteCode {
  id          String    @id @default(cuid())
  code        String    @unique
  role        String
  label       String?
  maxUses     Int?
  usedCount   Int       @default(0)
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  createdById String
  createdAt   DateTime  @default(now())

  @@index([code])
  @@index([role])
}

model Project {
  id          String   @id @default(cuid())
  orgId       String?
  org         Organization? @relation(fields: [orgId], references: [id])
  name        String
  code        String?  @unique
  description String?
  color       String   @default("#3B82F6")
  status      String   @default("active")
  startDate   DateTime?
  dueDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // BidToGo / 外部集成字段
  category             String?
  priority             String   @default("medium")
  tenderStatus         String?
  sourceSystem         String?
  sourcePlatform       String?
  clientOrganization   String?
  location             String?
  estimatedValue       Float?
  currency             String?
  solicitationNumber   String?
  workflowTemplate     String?
  sourceMetadataJson   String?

  // 招投标流程日期
  publicDate           DateTime?
  questionCloseDate    DateTime?
  closeDate            DateTime?
  distributedAt        DateTime?
  interpretedAt        DateTime?
  supplierInquiredAt   DateTime?
  supplierQuotedAt     DateTime?
  submittedAt          DateTime?
  awardDate            DateTime?

  // 项目放弃
  abandonedAt          DateTime?
  abandonedStage       String?
  abandonedById        String?
  abandonedReason      String?

  // 项目分发 (Bid to Go intake)
  intakeStatus         String   @default("dispatched")
  dispatchedAt         DateTime?
  dispatchedById       String?

  ownerId      String
  owner        User     @relation(fields: [ownerId], references: [id])
  tasks        Task[]
  blindsOrders BlindsOrder[]
  members      ProjectMember[]
  environments Environment[]
  auditLogs    AuditLog[]
  prompts      Prompt[]
  promptPublishLogs PromptPublishLog[]
  knowledgeBases KnowledgeBase[]
  knowledgePublishLogs KnowledgePublishLog[]
  conversations Conversation[]
  agents        Agent[]
  tools         ToolRegistry[]
  notificationRules ProjectNotificationRule[]

  externalRef         ExternalReference?
  intelligence        ProjectIntelligence?
  progressSummaries   ProjectProgressSummary[]
  documents           ProjectDocument[]
  discussion    ProjectConversation?
  aiThreads     AiThread[]
  inquiries     ProjectInquiry[]
  quotes        ProjectQuote[]
  agentTasks    AgentTask[]

  @@index([orgId])
  @@index([sourceSystem])
  @@index([tenderStatus])
  @@index([intakeStatus])
  @@index([status, createdAt])
}

model Task {
  id           String   @id @default(cuid())
  title        String
  description  String?
  status       String   @default("todo")
  priority     String   @default("medium")
  dueDate      DateTime?
  needReminder Boolean  @default(false)
  followupAt   DateTime?
  completedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id])

  assigneeId  String?
  assignee    User?    @relation("TaskAssignee", fields: [assigneeId], references: [id])

  creatorId   String
  creator     User     @relation("TaskCreator", fields: [creatorId], references: [id])

  tags            TagOnTask[]
  comments        TaskComment[]
  activities      TaskActivity[]
  calendarEvents  CalendarEvent[]
  reminders       Reminder[]

  @@index([projectId, status])
  @@index([projectId, createdAt])
  @@index([creatorId])
  @@index([assigneeId])
  @@index([dueDate])
  @@index([status, createdAt])
}

model TaskComment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
}

model TaskActivity {
  id        String   @id @default(cuid())
  action    String
  detail    String?
  createdAt DateTime @default(now())

  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  actorId   String
  actor     User     @relation(fields: [actorId], references: [id])
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#6B7280")
  createdAt DateTime @default(now())

  tasks     TagOnTask[]
}

model TagOnTask {
  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tagId  String
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
}

model CalendarEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  allDay          Boolean  @default(false)
  location        String?
  reminderMinutes Int      @default(15)
  source          String   @default("qingyan")
  externalId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  taskId      String?
  task        Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)

  userId      String
  user        User     @relation(fields: [userId], references: [id])

  reminders   Reminder[]
}

model BlindsOrder {
  id            String   @id @default(cuid())
  code          String   @unique
  status        String   @default("draft")
  // draft → confirmed → in_production → ready → scheduled → installed → completed → cancelled
  ruleVersion   String   @default("blinds_20251024_v1")

  customerName  String
  phone         String?
  address       String?
  installDate   String?
  remarks       String?

  confirmedAt       DateTime?
  productionStartAt DateTime?
  readyAt           DateTime?
  scheduledAt       DateTime?
  installedAt       DateTime?
  completedAt       DateTime?
  cancelledAt       DateTime?
  cancelReason      String?

  expectedInstallDate DateTime?
  appointmentId       String?

  priority      String   @default("normal") // urgent / normal / low

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  creatorId     String
  creator       User     @relation(fields: [creatorId], references: [id])
  projectId     String?
  project       Project? @relation(fields: [projectId], references: [id])

  customerId    String?
  customer      SalesCustomer? @relation(fields: [customerId], references: [id])
  opportunityId String?
  opportunity   SalesOpportunity? @relation(fields: [opportunityId], references: [id])

  items         BlindsOrderItem[]
  statusLogs    OrderStatusLog[]

  @@index([customerId])
  @@index([opportunityId])
  @@index([status])
  @@index([expectedInstallDate])
}

/// 工单状态变更日志
model OrderStatusLog {
  id        String   @id @default(cuid())
  orderId   String
  order     BlindsOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus String
  toStatus   String
  note       String?
  operatorId String
  createdAt  DateTime @default(now())

  @@index([orderId, createdAt])
}

model BlindsOrderItem {
  id            String   @id @default(cuid())
  itemNumber    Int

  location      String
  width         Float
  height        Float
  fabricSku     String
  productType   String
  measureType   String
  controlType   String
  controlSide   String
  headrailType  String
  mountType     String
  fabricRatio   Float?
  silkRatio     Float?
  bottomBarWidth Float?
  itemRemark    String?

  cutHeadrail     Float?
  cutTube38       Float?
  cutRollerBar    Float?
  cutZebraBar     Float?
  cutCoreRod      Float?
  cutShangrilaBar Float?
  cutFabricWidth  Float?
  cutFabricLength Float?
  insertSize      Float?
  cordLength      Float?
  cordSleeveLen   Float?
  squareFeet      Float?

  sortOrder     Int      @default(0)

  orderId       String
  order         BlindsOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ============================================================
// 面料库存管理
// ============================================================

model FabricInventory {
  id            String    @id @default(cuid())
  sku           String    @unique
  productType   String    // Zebra / Roller / Drapery / ...
  fabricName    String    // Light Filtering / Blackout / ...
  color         String?
  supplier      String?

  totalYards    Float     @default(0)  // 总库存（码数）
  reservedYards Float     @default(0)  // 已预留（在产工单占用）
  minYards      Float     @default(10) // 安全库存线
  unitCost      Float     @default(0)  // 单位成本（$/yard）

  status        String    @default("in_stock") // in_stock / low / out_of_stock
  lastRestockAt DateTime?
  notes         String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([productType])
  @@index([status])
  @@index([sku])
}

/// 库存变动日志
model FabricStockLog {
  id            String    @id @default(cuid())
  fabricId      String
  type          String    // restock / reserve / consume / release / adjust
  yards         Float     // 变动数量（正=入库，负=出库）
  reason        String?   // 工单号 / 手动调整说明
  operatorId    String
  createdAt     DateTime  @default(now())

  @@index([fabricId, createdAt])
  @@index([type])
}

model Reminder {
  id          String   @id @default(cuid())
  type        String
  status      String   @default("pending")
  sourceKey   String   @unique

  title       String
  message     String?
  triggerAt   DateTime
  readAt      DateTime?

  taskId      String?
  task        Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  eventId     String?
  event       CalendarEvent? @relation(fields: [eventId], references: [id], onDelete: Cascade)

  userId      String
  user        User     @relation(fields: [userId], references: [id])

  createdAt   DateTime @default(now())
}

model CalendarProvider {
  id            String   @id @default(cuid())
  type          String
  name          String
  enabled       Boolean  @default(true)
  accessToken   String?
  refreshToken  String?
  tokenExpiry   DateTime?
  accountEmail  String?
  calendarId    String?   // 逗号分隔的已选日历 ID 列表（primary,xxx@group.calendar.google.com,...）
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userId        String
  user          User     @relation(fields: [userId], references: [id])
}

// ============================================================
// 多租户基础模型
// ============================================================

model Organization {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  status    String   @default("active")
  planType  String   @default("free")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members   OrganizationMember[]
  projects  Project[]
  auditLogs AuditLog[]
  suppliers Supplier[]
  agentSkills AgentSkill[]
}

model OrganizationMember {
  id        String   @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   @default("org_member")
  status    String   @default("active")
  joinedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, userId])
  @@index([orgId])
  @@index([userId])
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   @default("operator")
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model Environment {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  code      String
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, code])
  @@index([projectId])

  prompts           Prompt[]
  publishLogsFrom   PromptPublishLog[] @relation("PublishLogFromEnv")
  publishLogsTo     PromptPublishLog[] @relation("PublishLogToEnv")
  knowledgeBases    KnowledgeBase[]
  knowledgeDocuments KnowledgeDocument[]
  kbPublishLogsFrom KnowledgePublishLog[] @relation("KbPublishFromEnv")
  kbPublishLogsTo   KnowledgePublishLog[] @relation("KbPublishToEnv")
  conversations     Conversation[]
  agents            Agent[]
}

model Prompt {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environmentId   String
  environment     Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  key             String
  name            String
  type            String   @default("system")
  status          String   @default("active")
  activeVersionId String?  @unique
  activeVersion   PromptVersion? @relation("PromptActiveVersion", fields: [activeVersionId], references: [id], onDelete: SetNull)
  createdById     String
  createdBy       User     @relation("PromptCreatedBy", fields: [createdById], references: [id])
  updatedById     String
  updatedBy       User     @relation("PromptUpdatedBy", fields: [updatedById], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  versions        PromptVersion[] @relation("PromptVersions")

  @@unique([projectId, environmentId, key])
  @@index([projectId, environmentId])
  @@index([environmentId])
}

model PromptVersion {
  id              String   @id @default(cuid())
  promptId        String
  prompt          Prompt   @relation("PromptVersions", fields: [promptId], references: [id], onDelete: Cascade)
  version         Int
  content         String
  note            String?
  sourceVersionId String?
  sourceVersion   PromptVersion? @relation("VersionLineage", fields: [sourceVersionId], references: [id], onDelete: SetNull)
  derivedVersions PromptVersion[] @relation("VersionLineage")
  createdById     String
  createdBy       User     @relation("PromptVersionCreatedBy", fields: [createdById], references: [id])
  createdAt       DateTime @default(now())

  activeForPrompt Prompt?  @relation("PromptActiveVersion")

  @@unique([promptId, version])
  @@index([promptId])
}

// [C7审计] 低频使用，仅在 Prompt 发布时记录。后续可考虑归档到 AuditLog
model PromptPublishLog {
  id                String        @id @default(cuid())
  projectId         String
  project           Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  promptKey         String
  fromEnvironmentId String
  fromEnvironment   Environment   @relation("PublishLogFromEnv", fields: [fromEnvironmentId], references: [id])
  toEnvironmentId   String
  toEnvironment     Environment   @relation("PublishLogToEnv", fields: [toEnvironmentId], references: [id])
  fromVersionId     String
  toVersionId       String
  publishedById     String
  publishedBy       User          @relation("PromptPublishBy", fields: [publishedById], references: [id])
  note              String?
  createdAt         DateTime      @default(now())

  @@index([projectId])
  @@index([promptKey])
}

// ============================================================
// 知识库（按项目 + 环境隔离，版本快照 + 发布）
// ============================================================

model KnowledgeBase {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environmentId   String
  environment     Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  key             String
  name            String
  description     String?
  status          String   @default("active")
  activeVersionId String?  @unique
  activeVersion   KnowledgeBaseVersion? @relation("KBActiveVersion", fields: [activeVersionId], references: [id], onDelete: SetNull)
  createdById     String
  createdBy       User     @relation("KnowledgeBaseCreatedBy", fields: [createdById], references: [id])
  updatedById     String
  updatedBy       User     @relation("KnowledgeBaseUpdatedBy", fields: [updatedById], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  versions        KnowledgeBaseVersion[] @relation("KBVersions")
  documents       KnowledgeDocument[]

  @@unique([projectId, environmentId, key])
  @@index([projectId, environmentId])
  @@index([environmentId])
}

model KnowledgeBaseVersion {
  id                String   @id @default(cuid())
  knowledgeBaseId   String
  knowledgeBase     KnowledgeBase @relation("KBVersions", fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  version           Int
  note              String?
  sourceVersionId   String?
  sourceVersion     KnowledgeBaseVersion? @relation("KBVersionLineage", fields: [sourceVersionId], references: [id], onDelete: SetNull)
  derivedKbVersions KnowledgeBaseVersion[] @relation("KBVersionLineage")
  createdById       String
  createdBy         User     @relation("KBVersionCreatedBy", fields: [createdById], references: [id])
  createdAt         DateTime @default(now())

  documentSnapshots KnowledgeDocumentVersion[]
  activeForKb       KnowledgeBase? @relation("KBActiveVersion")

  @@unique([knowledgeBaseId, version])
  @@index([knowledgeBaseId])
}

model KnowledgeDocument {
  id              String   @id @default(cuid())
  knowledgeBaseId String
  knowledgeBase   KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  environmentId   String
  environment     Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  title           String
  sourceType      String
  sourceUrl       String?
  status          String   @default("active")
  sortOrder       Int      @default(0)
  createdById     String
  createdBy       User     @relation("KnowledgeDocumentCreatedBy", fields: [createdById], references: [id])
  updatedById     String
  updatedBy       User     @relation("KnowledgeDocumentUpdatedBy", fields: [updatedById], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  versions        KnowledgeDocumentVersion[]

  @@index([knowledgeBaseId])
  @@index([environmentId])
}

model KnowledgeDocumentVersion {
  id                     String   @id @default(cuid())
  documentId             String
  document               KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  knowledgeBaseVersionId String
  knowledgeBaseVersion   KnowledgeBaseVersion @relation(fields: [knowledgeBaseVersionId], references: [id], onDelete: Cascade)
  version                Int
  content                String   @default("")
  summary                String?
  note                   String?
  sourceVersionId        String?
  sourceVersion          KnowledgeDocumentVersion? @relation("DocVersionLineage", fields: [sourceVersionId], references: [id], onDelete: SetNull)
  derivedDocVersions     KnowledgeDocumentVersion[] @relation("DocVersionLineage")
  createdById            String
  createdBy              User     @relation("KDVersionCreatedBy", fields: [createdById], references: [id])
  createdAt              DateTime @default(now())

  @@unique([documentId, knowledgeBaseVersionId])
  @@unique([documentId, version])
  @@index([knowledgeBaseVersionId])
}

// [C7审计] 低频使用，仅在知识库发布时记录。后续可考虑归档到 AuditLog
model KnowledgePublishLog {
  id                         String        @id @default(cuid())
  projectId                  String
  project                    Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  knowledgeBaseKey           String
  fromEnvironmentId          String
  fromEnvironment            Environment   @relation("KbPublishFromEnv", fields: [fromEnvironmentId], references: [id])
  toEnvironmentId            String
  toEnvironment              Environment   @relation("KbPublishToEnv", fields: [toEnvironmentId], references: [id])
  fromKnowledgeBaseVersionId String
  toKnowledgeBaseVersionId   String
  publishedById              String
  publishedBy                User          @relation("KBPublishedBy", fields: [publishedById], references: [id])
  note                       String?
  createdAt                  DateTime      @default(now())

  @@index([projectId])
  @@index([knowledgeBaseKey])
}

// ============================================================
// 会话管理（按项目 + 环境隔离，消息记录 + 上下文追踪）
// ============================================================

model Conversation {
  id              String    @id @default(cuid())
  projectId       String
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environmentId   String
  environment     Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  userId          String?
  user            User?     @relation("ConversationUser", fields: [userId], references: [id], onDelete: SetNull)
  title           String    @default("")
  channel         String    @default("web")
  status          String    @default("active")

  messageCount    Int       @default(0)
  inputTokens     Int       @default(0)
  outputTokens    Int       @default(0)
  totalTokens     Int       @default(0)
  estimatedCost   Float     @default(0)
  avgLatencyMs    Int       @default(0)

  promptId               String?
  promptVersionId        String?
  knowledgeBaseId        String?
  knowledgeBaseVersionId String?

  agentId         String?
  runtimeStatus   String    @default("idle")
  lastErrorMessage String?
  runCount        Int       @default(0)

  startedAt       DateTime  @default(now())
  lastMessageAt   DateTime?
  endedAt         DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  messages           Message[]
  contextSnapshots   ConversationContextSnapshot[]
  toolCallTraces     ToolCallTrace[]

  @@index([projectId, environmentId])
  @@index([projectId])
  @@index([projectId, startedAt])
  @@index([environmentId])
  @@index([userId])
  @@index([status])
  @@index([lastMessageAt])
}

model Message {
  id              String   @id @default(cuid())
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role            String
  content         String   @default("")
  contentType     String   @default("text")
  sequence        Int
  modelName       String?
  inputTokens     Int      @default(0)
  outputTokens    Int      @default(0)
  latencyMs       Int      @default(0)
  status          String   @default("success")
  errorMessage    String?
  finishReason    String?
  toolName        String?
  toolCallId      String?
  parentMessageId String?
  metadataJson    String?
  createdAt       DateTime @default(now())

  toolCallTraces  ToolCallTrace[]

  @@unique([conversationId, sequence])
  @@index([conversationId])
}

// [C7审计] 低频使用，会话上下文快照。后续可考虑按需懒加载或归档
model ConversationContextSnapshot {
  id                     String   @id @default(cuid())
  conversationId         String
  conversation           Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  promptId               String?
  promptVersionId        String?
  promptKey              String?
  knowledgeBaseId        String?
  knowledgeBaseVersionId String?
  knowledgeBaseKey       String?
  environmentId          String?
  systemPromptSnapshot   String?
  retrievalConfigJson    String?
  extraConfigJson        String?
  createdAt              DateTime @default(now())

  @@index([conversationId])
}

model AuditLog {
  id         String        @id @default(cuid())
  orgId      String?
  org        Organization? @relation(fields: [orgId], references: [id])
  projectId  String?
  project    Project?      @relation(fields: [projectId], references: [id])
  userId     String
  user       User          @relation(fields: [userId], references: [id])
  action     String
  targetType String
  targetId   String?
  beforeData String?
  afterData  String?
  ip         String?
  userAgent  String?
  createdAt  DateTime      @default(now())

  @@index([orgId])
  @@index([projectId])
  @@index([userId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
}

// ============================================================
// Agent 配置与编排
// ============================================================

model Agent {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environmentId   String
  environment     Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  key             String
  name            String
  description     String?
  type            String   @default("chat")
  status          String   @default("active")

  promptId               String?
  promptVersionId        String?
  knowledgeBaseId        String?
  knowledgeBaseVersionId String?
  modelProvider          String   @default("openai")
  modelName              String   @default("gpt-5.2")
  temperature            Float    @default(0.7)
  maxTokens              Int      @default(4096)
  systemBehaviorNote     String?
  extraConfigJson        String?

  activeVersionId String?  @unique
  activeVersion   AgentVersion? @relation("AgentActiveVersion", fields: [activeVersionId], references: [id], onDelete: SetNull)

  createdById     String
  createdBy       User     @relation("AgentCreatedBy", fields: [createdById], references: [id])
  updatedById     String
  updatedBy       User     @relation("AgentUpdatedBy", fields: [updatedById], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  versions        AgentVersion[] @relation("AgentVersions")
  toolBindings    AgentToolBinding[]

  @@unique([projectId, environmentId, key])
  @@index([projectId, environmentId])
  @@index([environmentId])
}

model AgentVersion {
  id                  String   @id @default(cuid())
  agentId             String
  agent               Agent    @relation("AgentVersions", fields: [agentId], references: [id], onDelete: Cascade)
  version             Int
  configSnapshotJson  String
  changeNote          String?
  createdById         String
  createdBy           User     @relation("AgentVersionCreatedBy", fields: [createdById], references: [id])
  createdAt           DateTime @default(now())

  activeForAgent      Agent?   @relation("AgentActiveVersion")

  @@unique([agentId, version])
  @@index([agentId])
}

model ToolRegistry {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  key             String
  name            String
  description     String?
  category        String   @default("builtin")
  type            String   @default("function")
  status          String   @default("active")
  inputSchemaJson  String?
  outputSchemaJson String?
  configJson      String?
  createdById     String
  createdBy       User     @relation("ToolCreatedBy", fields: [createdById], references: [id])
  updatedById     String
  updatedBy       User     @relation("ToolUpdatedBy", fields: [updatedById], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  agentBindings   AgentToolBinding[]

  @@unique([projectId, key])
  @@index([projectId])
}

model AgentToolBinding {
  id                String   @id @default(cuid())
  agentId           String
  agent             Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  toolId            String
  tool              ToolRegistry @relation(fields: [toolId], references: [id], onDelete: Cascade)
  enabled           Boolean  @default(true)
  sortOrder         Int      @default(0)
  configOverrideJson String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([agentId, toolId])
  @@index([agentId])
  @@index([toolId])
}

// ============================================================
// Runtime: 工具调用追踪
// ============================================================

model ToolCallTrace {
  id              String   @id @default(cuid())
  projectId       String
  environmentId   String
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  messageId       String
  message         Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  agentId         String?
  toolId          String?
  toolKey         String
  toolName        String
  toolCallId      String?
  inputJson       String?
  outputJson      String?
  status          String   @default("success")
  errorMessage    String?
  durationMs      Int      @default(0)
  createdAt       DateTime @default(now())

  @@index([conversationId])
  @@index([messageId])
  @@index([projectId, environmentId])
}

// ============================================================
// 评估与质量反馈
// ============================================================

model ConversationFeedback {
  id                     String   @id @default(cuid())
  projectId              String
  environmentId          String
  conversationId         String
  agentId                String?
  promptId               String?
  promptVersionId        String?
  knowledgeBaseId        String?
  knowledgeBaseVersionId String?
  createdById            String

  rating                 Int      @default(0)
  scoreAccuracy          Int?
  scoreHelpfulness       Int?
  scoreSafety            Int?
  scoreCompleteness      Int?
  sentiment              String   @default("neutral")
  issueType              String?
  note                   String?
  status                 String   @default("open")

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  tags                   ConversationFeedbackTag[]

  @@index([projectId, environmentId])
  @@index([conversationId])
  @@index([status])
  @@index([rating])
  @@index([createdById])
}

model MessageFeedback {
  id              String   @id @default(cuid())
  projectId       String
  environmentId   String
  conversationId  String
  messageId       String
  agentId         String?
  createdById     String

  rating          Int      @default(0)
  issueType       String?
  note            String?
  status          String   @default("open")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tags            MessageFeedbackTag[]

  @@index([projectId, environmentId])
  @@index([conversationId])
  @@index([messageId])
  @@index([status])
  @@index([createdById])
}

model EvaluationTag {
  id          String   @id @default(cuid())
  projectId   String
  key         String
  label       String
  category    String   @default("quality")
  color       String   @default("#6b7280")
  status      String   @default("active")
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  conversationFeedbackTags ConversationFeedbackTag[]
  messageFeedbackTags      MessageFeedbackTag[]

  @@unique([projectId, key])
  @@index([projectId])
}

model ConversationFeedbackTag {
  id         String   @id @default(cuid())
  feedbackId String
  feedback   ConversationFeedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  tagId      String
  tag        EvaluationTag @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([feedbackId, tagId])
  @@index([feedbackId])
  @@index([tagId])
}

model MessageFeedbackTag {
  id         String   @id @default(cuid())
  feedbackId String
  feedback   MessageFeedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  tagId      String
  tag        EvaluationTag @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([feedbackId, tagId])
  @@index([feedbackId])
  @@index([tagId])
}

model EvaluationRun {
  id              String   @id @default(cuid())
  projectId       String
  environmentId   String
  conversationId  String?
  messageId       String?
  type            String   @default("manual")
  judgeModel      String?
  judgeVersion    String?
  criteriaJson    String?
  resultJson      String?
  score           Float?
  createdById     String
  createdAt       DateTime @default(now())

  @@index([projectId, environmentId])
  @@index([conversationId])
}

model Notification {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation("UserNotifications", fields: [userId], references: [id])
  orgId         String?
  projectId     String?
  type          String    @default("update")
  category      String    @default("update")
  title         String
  summary       String?
  entityType    String?
  entityId      String?
  activityId    String?
  status        String    @default("unread")
  priority      String    @default("medium")
  dueAt         DateTime?
  snoozeUntil   DateTime?
  readAt        DateTime?
  doneAt        DateTime?
  sourceKey     String?   @unique
  metadata      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([projectId])
  @@index([projectId, status])
}

model UserNotificationPreference {
  id                       String   @id @default(cuid())
  userId                   String   @unique
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgId                    String?
  enableInAppNotifications Boolean  @default(true)
  onlyHighPriority         Boolean  @default(false)
  onlyMyItems              Boolean  @default(false)
  includeWatchedProjects   Boolean  @default(true)
  quietHoursEnabled        Boolean  @default(false)
  quietHoursStart          String?
  quietHoursEnd            String?
  emailEnabled             Boolean  @default(false)
  pushEnabled              Boolean  @default(false)
  enabledTypesJson         String?
  metadata                 String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([userId])
}

model ProjectNotificationRule {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId             String
  project               Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  watchEnabled          Boolean  @default(false)
  notifyProjectUpdates  Boolean  @default(true)
  notifyRuntimeFailed   Boolean  @default(true)
  notifyFeedbackCreated Boolean  @default(true)
  notifyLowEvaluations  Boolean  @default(true)
  notifyTaskDue         Boolean  @default(true)
  minimumPriority       String   @default("medium")
  metadata              String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([userId, projectId])
  @@index([projectId])
}

// ============================================================
// 外部集成：BidToGo 等系统对接
// ============================================================

model ExternalReference {
  id         String   @id @default(cuid())
  system     String
  externalId String
  url        String?
  projectId  String   @unique
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([system, externalId])
  @@index([system])
}

model ProjectIntelligence {
  id              String   @id @default(cuid())
  projectId       String   @unique
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  recommendation  String
  riskLevel       String
  fitScore        Int      @default(0)
  summary         String?
  fullReportUrl   String?
  fullReportJson  String?
  reportMarkdown  String?

  // 审核工作流
  reportStatus    String   @default("ai_generated")  // draft | ai_generated | in_review | approved | needs_revision | delivered
  reviewedBy      String?
  reviewedAt      DateTime?
  reviewNotes     String?
  reviewScore     Int?     // 1-5 人工评分（可选）

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ProjectProgressSummary {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // 输出内容
  overallStatus   String                  // green | yellow | red
  statusLabel     String
  outputJson      String   @db.Text       // 完整 ProgressSummaryOutput JSON
  executiveSummary String?

  // 生成元数据
  docType         String   @default("project_progress_summary")
  promptVersion   String
  modelUsed       String
  usedFallback    Boolean  @default(false)
  generationTimeMs Int     @default(0)
  metaJson        String?  @db.Text       // 完整 ProgressSummaryMeta JSON

  // 审核工作流
  reportStatus    String   @default("ai_generated")  // ai_generated | in_review | approved | needs_revision
  reviewedBy      String?
  reviewedAt      DateTime?
  reviewNotes     String?
  reviewScore     Int?     // 1-5

  // 触发方式
  triggerType     String   @default("manual")  // manual | cron | agent

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([projectId])
  @@index([projectId, createdAt])
}

model ProjectDocument {
  id             String    @id @default(cuid())
  projectId      String
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title          String
  url            String
  blobUrl        String?
  fileType       String
  fileSize       Int?
  contentText    String?   @db.Text
  parseStatus    String    @default("pending") // pending | parsing | done | failed
  parseError     String?
  aiSummaryJson  String?   @db.Text            // AI 结构化摘要 JSON
  aiSummaryStatus String   @default("pending") // pending | generating | done | failed
  source         String    @default("external_link")
  uploadedById   String?
  sortOrder      Int       @default(0)
  createdAt      DateTime  @default(now())

  @@index([projectId])
  @@index([source])
}

model ApiToken {
  id          String    @id @default(cuid())
  name        String
  token       String    @unique
  system      String
  permissions String    @default("project:create")
  isActive    Boolean   @default(true)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([token])
  @@index([system])
}

model WebhookEndpoint {
  id           String    @id @default(cuid())
  system       String
  url          String
  secret       String
  events       String
  isActive     Boolean   @default(true)
  lastCalledAt DateTime?
  failCount    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([system])
}

// ─────────────────────────────────────────
// 项目讨论（Project Discussion）
// ─────────────────────────────────────────

model ProjectConversation {
  id         String    @id @default(cuid())
  projectId  String    @unique
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  kind       String    @default("MAIN")
  title      String    @default("项目讨论")
  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  messages   ProjectMessage[]
}

model ProjectMessage {
  id             String   @id @default(cuid())
  conversationId String
  conversation   ProjectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  projectId      String
  senderId       String?
  sender         User?    @relation("ProjectMessageSender", fields: [senderId], references: [id], onDelete: SetNull)
  type           String   @default("TEXT")
  body           String
  metadata       Json?
  replyToId      String?
  editedAt       DateTime?
  deletedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([conversationId, createdAt, id])
  @@index([projectId, createdAt, id])
  @@index([projectId, type, createdAt])
  @@index([senderId, createdAt])
}

// ── AI 助手持久对话 ──────────────────────────────────────────

model AiThread {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId     String?
  project       Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  title         String    @default("新对话")
  pinned        Boolean   @default(false)
  archived      Boolean   @default(false)
  lastMessageAt DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  messages      AiMessage[]

  @@index([userId, pinned, lastMessageAt])
  @@index([userId, projectId])
}

model AiMessage {
  id             String   @id @default(cuid())
  threadId       String
  thread         AiThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  role           String
  content        String
  workSuggestion Json?
  createdAt      DateTime @default(now())

  @@index([threadId, createdAt])
}

// ============================================================
// 供应商询价（Supplier Inquiry）
// ============================================================

model Supplier {
  id            String   @id @default(cuid())
  orgId         String
  org           Organization @relation(fields: [orgId], references: [id])
  name          String
  contactName   String?
  contactEmail  String?
  contactPhone  String?
  category      String?
  region        String?
  notes         String?  @db.Text
  status        String   @default("active")
  createdById   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // 来源追踪
  source        String?  // exhibition / referral / online / xiaohongshu / 1688 / cold_call / other
  sourceDetail  String?  // "2026广交会-3号馆-B12展位"
  website       String?

  // AI 自动分类
  tags              String?  @db.Text  // comma-separated: "阻燃面料,窗帘,工业布,出口"
  capabilities      String?  @db.Text  // AI 能力画像文本
  aiClassification  Json?    // {mainCategory, subCategories[], confidence, classifiedAt}

  // 评分
  rating        Float?   @default(0) // 0-5
  ratingDetail  Json?    // {quality, response, price, delivery}

  // 时间追踪
  lastContactAt DateTime?

  // 画册
  brochureUrl          String?
  brochureParseStatus  String?
  brochureParseResult  Json?
  brochureParseWarning String?

  inquiryItems  InquiryItem[]

  @@index([orgId, status])
  @@index([orgId, name])
  @@index([orgId, source])
  @@index([orgId, tags])
}

model ProjectInquiry {
  id            String    @id @default(cuid())
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  roundNumber   Int       @default(1)
  title         String?
  scope         String?
  status        String    @default("draft")
  dueDate       DateTime?
  token         String?   @unique
  createdById   String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  items         InquiryItem[]

  @@unique([projectId, roundNumber])
  @@index([projectId, status])
}

model InquiryItem {
  id            String    @id @default(cuid())
  inquiryId     String
  inquiry       ProjectInquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  supplierId    String
  supplier      Supplier  @relation(fields: [supplierId], references: [id])

  // ── 流程状态 ──
  status        String    @default("pending")
  sentVia       String?
  sentAt        DateTime?
  repliedAt     DateTime?
  declinedAt    DateTime?

  // ── 报价内容 ──
  unitPrice     Decimal?  @db.Decimal(18, 2)
  totalPrice    Decimal?  @db.Decimal(18, 2)
  currency      String    @default("CAD")
  deliveryDays  Int?
  validUntil    DateTime?
  quoteNotes    String?

  // ── 选定 ──
  isSelected    Boolean   @default(false)

  // ── 沟通备注 ──
  contactNotes  String?

  // ── 元数据 ──
  createdById   String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([inquiryId, supplierId])
  @@index([inquiryId, status])
  @@index([supplierId])
}

// ============================================================
// 项目报价
// ============================================================

/// 项目报价单 — AI 辅助生成 + 人工编辑确认
model ProjectQuote {
  id              String    @id @default(cuid())
  projectId       String
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  templateType    String    @default("export_standard")
  version         Int       @default(1)
  status          String    @default("draft")

  title           String?
  currency        String    @default("CAD")
  tradeTerms      String?
  paymentTerms    String?
  deliveryDays    Int?
  validUntil      DateTime?
  moq             Int?
  originCountry   String?

  subtotal        Decimal?  @db.Decimal(18, 2)
  totalAmount     Decimal?  @db.Decimal(18, 2)

  internalCost    Decimal?  @db.Decimal(18, 2)
  profitMargin    Decimal?  @db.Decimal(5, 2)
  internalNotes   String?

  aiGenerated     Boolean   @default(false)
  aiDraftJson     String?   @db.Text
  aiReviewJson    String?   @db.Text

  inquiryId       String?
  createdById     String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  lineItems       QuoteLineItem[]

  @@index([projectId, status])
  @@index([projectId, version])
}

/// 报价行项目
model QuoteLineItem {
  id              String    @id @default(cuid())
  quoteId         String
  quote           ProjectQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  sortOrder       Int       @default(0)
  category        String    @default("product")
  itemName        String
  specification   String?
  unit            String?
  quantity        Decimal?  @db.Decimal(18, 2)
  unitPrice       Decimal?  @db.Decimal(18, 2)
  totalPrice      Decimal?  @db.Decimal(18, 2)
  remarks         String?

  costPrice       Decimal?  @db.Decimal(18, 2)
  isInternal      Boolean   @default(false)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([quoteId, sortOrder])
}

// ============================================================
// 邮件发送
// ============================================================

/// 用户绑定的 Gmail OAuth 凭据（独立于 CalendarProvider）
model EmailProvider {
  id            String    @id @default(cuid())
  userId        String
  type          String    @default("gmail")
  accessToken   String    @db.Text
  refreshToken  String?   @db.Text
  tokenExpiry   DateTime?
  accountEmail  String

  /// 记录本次授权实际获得的 scope 列表（空格分隔），用于权限审查与增量授权诊断
  grantedScopes String?   @db.Text

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([userId, type])
  @@index([userId])
}

/// 项目内发出的邮件记录
model ProjectEmail {
  id                String    @id @default(cuid())
  orgId             String
  projectId         String
  inquiryId         String?
  inquiryItemId     String?

  toEmail           String
  toName            String?
  fromEmail         String
  subject           String
  body              String    @db.Text

  status            String    @default("draft")   // draft | sending | sent | failed
  provider          String    @default("gmail")
  externalMessageId String?
  errorMessage      String?

  createdById       String
  sentById          String?
  createdAt         DateTime  @default(now())
  sentAt            DateTime?
  updatedAt         DateTime  @updatedAt

  @@index([projectId])
  @@index([inquiryItemId])
  @@index([orgId, projectId])
}

/// 项目问题 / RFI — 向业主/GC/顾问发送的澄清确认邮件
model ProjectQuestion {
  id                  String    @id @default(cuid())
  projectId           String
  orgId               String?

  // ── 问题内容 ──
  title               String
  description         String    @db.Text
  locationOrReference String?
  clarificationNeeded String?   @db.Text
  impactNote          String?   @db.Text

  // ── 生成的邮件 ──
  generatedSubject    String?
  generatedBody       String?   @db.Text
  toRecipients        String?
  ccRecipients        String?

  // ── 流程状态 ──
  status              String    @default("draft") // draft | generated | sent | replied | closed
  emailId             String?

  // ── 元数据 ──
  createdById         String
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([projectId, status])
  @@index([projectId, createdAt])
}

// ══════════════════════════════════════════════════════════════════
// 子智能体委派系统
// ══════════════════════════════════════════════════════════════════

model AgentTask {
  id               String    @id @default(cuid())
  projectId        String
  project          Project   @relation(fields: [projectId], references: [id])
  taskType         String    @default("custom")
  triggerType       String    @default("manual")
  intent           String    @db.Text
  riskLevel        String    @default("low")
  status           String    @default("draft")
  currentStepIndex Int       @default(0)
  totalSteps       Int       @default(0)
  priority         String    @default("normal")
  parentTaskId     String?
  requiresApproval Boolean   @default(false)
  createdById      String
  createdBy        User      @relation("AgentTaskCreatedBy", fields: [createdById], references: [id])
  startedAt        DateTime?
  completedAt      DateTime?
  failedAt         DateTime?
  cancelledAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  steps            AgentTaskStep[]
  approvalRequests ApprovalRequest[]
  toolExecutions   ToolExecution[]

  @@index([projectId, status])
  @@index([createdById, status])
}

model AgentTaskStep {
  id               String    @id @default(cuid())
  taskId           String
  task             AgentTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  stepIndex        Int
  skillId          String
  agentName        String
  title            String
  description      String?
  riskLevel        String    @default("low")
  requiresApproval Boolean   @default(false)
  status           String    @default("pending")
  inputJson        String?   @db.Text
  outputJson       String?   @db.Text
  outputSummary    String?
  checkReportJson  String?   @db.Text
  confidence       Float?
  approvedBy       String?
  approvedAt       DateTime?
  rejectionNote    String?
  startedAt        DateTime?
  completedAt      DateTime?
  error            String?   @db.Text
  retryCount       Int       @default(0)
  createdAt        DateTime  @default(now())

  approvalRequests ApprovalRequest[]
  toolExecutions   ToolExecution[]

  @@index([taskId, stepIndex])
}

model ApprovalRequest {
  id               String    @id @default(cuid())
  taskId           String
  task             AgentTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  stepId           String
  step             AgentTaskStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  actionType       String
  riskLevel        String
  riskReason       String?   @db.Text
  previewJson      String?   @db.Text
  approverUserId   String?
  status           String    @default("pending")
  deadlineAt       DateTime?
  decidedAt        DateTime?
  decidedBy        String?
  decisionNote     String?   @db.Text
  acceptedWithRisk Boolean   @default(false)
  createdAt        DateTime  @default(now())

  @@index([taskId])
  @@index([approverUserId, status])
}

model ToolExecution {
  id               String    @id @default(cuid())
  taskId           String?
  task             AgentTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)
  stepId           String?
  step             AgentTaskStep? @relation(fields: [stepId], references: [id], onDelete: SetNull)
  toolName         String
  toolInput        String?   @db.Text
  toolOutput       String?   @db.Text
  status           String    @default("pending")
  retryCount       Int       @default(0)
  maxRetries       Int       @default(2)
  idempotencyKey   String    @unique
  error            String?   @db.Text
  executedBy       String
  executedAt       DateTime?
  duration         Int?
  createdAt        DateTime  @default(now())

  @@index([taskId])
  @@index([idempotencyKey])
}

model CustomFlowTemplate {
  id               String    @id @default(cuid())
  name             String
  description      String?   @db.Text
  icon             String?
  category         String    @default("custom")
  stepsJson        String    @db.Text
  createdById      String
  createdBy        User      @relation("CustomFlowTemplateCreatedBy", fields: [createdById], references: [id])
  isPublic         Boolean   @default(false)
  enabled          Boolean   @default(true)
  usageCount       Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([createdById])
  @@index([category])
}

// ============================================================
// Trade 外贸自动获客系统
// ============================================================

model TradeCampaign {
  id              String    @id @default(cuid())
  orgId           String
  name            String
  productDesc     String    @db.Text
  targetMarket    String    @db.Text
  searchKeywords  Json?
  status          String    @default("active") // active / paused / completed
  scoreThreshold  Float     @default(7)
  totalProspects  Int       @default(0)
  qualified       Int       @default(0)
  contacted       Int       @default(0)

  createdById     String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  prospects       TradeProspect[]

  @@index([orgId, status])
  @@index([createdById])
}

model TradeProspect {
  id              String    @id @default(cuid())
  campaignId      String
  campaign        TradeCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  orgId           String

  companyName     String
  contactName     String?
  contactEmail    String?
  contactTitle    String?
  website         String?
  country         String?
  source          String    @default("google") // google / exhibition / 1688 / linkedin / manual

  researchReport  Json?
  score           Float?
  scoreReason     String?   @db.Text

  stage           String    @default("new")
  // new → researched → qualified → outreach_draft → outreach_sent
  // → replied → interested → negotiating → won / lost
  // → unqualified / no_response

  outreachSubject String?
  outreachBody    String?   @db.Text
  outreachLang    String?   @default("en")
  outreachSentAt  DateTime?

  lastContactAt   DateTime?
  nextFollowUpAt  DateTime?
  followUpCount   Int       @default(0)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  messages        TradeMessage[]
  quotes          TradeQuote[]

  @@index([campaignId, stage])
  @@index([orgId, stage])
  @@index([nextFollowUpAt])
  @@index([score])
}

model TradeMessage {
  id          String   @id @default(cuid())
  prospectId  String
  prospect    TradeProspect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  direction   String   // inbound / outbound
  channel     String   @default("email") // email / whatsapp / wechat
  subject     String?
  content     String   @db.Text

  intent      String?  // interested / objection / not_interested / ooo / question / request_sample / unclear
  sentiment   String?  // positive / neutral / negative
  aiDraft     Boolean  @default(false)
  approvedAt  DateTime?

  createdAt   DateTime @default(now())

  @@index([prospectId, createdAt])
  @@index([prospectId, direction])
}

model TradeChatSession {
  id          String    @id @default(cuid())
  orgId       String
  userId      String
  title       String    @default("新对话")
  status      String    @default("active") // active / archived
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  messages    TradeChatMessage[]

  @@index([userId, updatedAt])
  @@index([orgId])
}

model TradeChatMessage {
  id          String   @id @default(cuid())
  sessionId   String
  session     TradeChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role        String   // user / assistant / system / tool
  content     String   @db.Text
  toolName    String?
  toolInput   Json?
  toolOutput  Json?
  createdAt   DateTime @default(now())

  @@index([sessionId, createdAt])
}

model TradeChannel {
  id            String    @id @default(cuid())
  orgId         String
  channel       String    // whatsapp / wechat / wechat_work
  name          String    // display name
  status        String    @default("active") // active / inactive / error
  config        Json      // encrypted config: apiKey, phoneNumberId, accessToken, etc.
  webhookSecret String?
  lastSyncAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([orgId, channel])
  @@index([orgId])
}

model TradeActivityLog {
  id          String   @id @default(cuid())
  orgId       String
  campaignId  String?
  prospectId  String?
  action      String   // discover / research / score / outreach / send / reply / stage_change / import / pipeline
  detail      String?  @db.Text
  meta        Json?
  createdAt   DateTime @default(now())

  @@index([campaignId, createdAt])
  @@index([prospectId, createdAt])
  @@index([orgId, createdAt])
}

model TradeQuote {
  id              String    @id @default(cuid())
  orgId           String
  prospectId      String?
  prospect        TradeProspect? @relation(fields: [prospectId], references: [id])
  campaignId      String?

  quoteNumber     String    @unique
  companyName     String
  contactName     String?
  contactEmail    String?
  country         String?

  status          String    @default("draft") // draft / sent / negotiating / accepted / rejected / expired
  currency        String    @default("USD")
  incoterm        String    @default("FOB") // FOB / CIF / EXW / DDP / CFR
  paymentTerms    String?   // T/T 30%, L/C, etc.
  validDays       Int       @default(30)
  leadTimeDays    Int?
  moq             String?
  shippingPort    String?

  subtotal        Float     @default(0)
  discount        Float     @default(0)
  shippingCost    Float     @default(0)
  totalAmount     Float     @default(0)

  notes           String?   @db.Text
  internalNotes   String?   @db.Text

  sentAt          DateTime?
  acceptedAt      DateTime?
  expiresAt       DateTime?

  createdById     String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  items           TradeQuoteItem[]

  @@index([orgId, status])
  @@index([prospectId])
}

model TradeQuoteItem {
  id              String    @id @default(cuid())
  quoteId         String
  quote           TradeQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  sortOrder       Int       @default(0)
  productName     String
  specification   String?
  unit            String    @default("pcs")
  quantity        Float     @default(0)
  unitPrice       Float     @default(0)
  totalPrice      Float     @default(0)
  remarks         String?

  @@index([quoteId, sortOrder])
}

model TradeKnowledge {
  id          String   @id @default(cuid())
  orgId       String
  category    String   // product / faq / case_study / certification / process
  title       String
  content     String   @db.Text
  tags        String?  // comma-separated
  language    String   @default("zh")
  isActive    Boolean  @default(true)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([orgId, category])
  @@index([orgId, isActive])
}

model TradeEmailTemplate {
  id          String   @id @default(cuid())
  orgId       String
  name        String
  category    String   // first_touch / follow_up / after_quote / after_sample / re_engage / exhibition
  language    String   @default("en") // en / zh / es / fr / de / auto
  subject     String
  body        String   @db.Text
  variables   Json?    // ["companyName", "contactName", "productDesc", ...]
  isDefault   Boolean  @default(false)
  usageCount  Int      @default(0)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([orgId, category])
}

// ============================================================
// Sales CRM Models — Sunny Shutter B2C 销售流程
// ============================================================

model SalesCustomer {
  id            String   @id @default(cuid())
  name          String
  phone         String?
  email         String?
  address       String?
  source        String?  // referral / google_ads / walk_in / wechat / other
  wechatNote    String?
  status        String   @default("active") // active / completed / dormant
  tags          String?  // comma-separated tags
  notes         String?  @db.Text
  jdyDataId     String?  @unique // 简道云 record ID for future sync
  lastSyncAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  createdById   String
  createdBy     User     @relation("SalesCustomerCreatedBy", fields: [createdById], references: [id])

  opportunities  SalesOpportunity[]
  interactions   CustomerInteraction[]
  quotes         SalesQuote[]       @relation("SalesQuoteCustomer")
  blindsOrders   BlindsOrder[]
  appointments   Appointment[]
  measurements   MeasurementRecord[]

  // RAG
  profile            CustomerProfile?
  knowledgeChunks    SalesKnowledgeChunk[]
  coachingRecords    CoachingRecord[]

  @@index([status])
  @@index([phone])
  @@index([email])
  @@index([createdAt])
}

model SalesOpportunity {
  id              String    @id @default(cuid())
  customerId      String
  customer        SalesCustomer @relation(fields: [customerId], references: [id])
  title           String
  stage           String    @default("new_lead") // Pipeline stage
  estimatedValue  Float?
  windowCount     Int?
  productTypes    String?   // comma-separated: Zebra,Roller,Drapery,...
  source          String?   // lead source
  priority        String    @default("warm") // hot / warm / cold
  lostReason      String?   @db.Text
  wonAt           DateTime?
  lostAt          DateTime?
  nextFollowupAt  DateTime?
  measureDate     DateTime?
  installDate     DateTime?
  jdyDataId       String?   @unique
  lastSyncAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  assignedToId    String?
  assignedTo      User?     @relation("SalesOpportunityAssignee", fields: [assignedToId], references: [id])
  createdById     String
  createdBy       User      @relation("SalesOpportunityCreatedBy", fields: [createdById], references: [id])

  interactions    CustomerInteraction[]
  quotes          SalesQuote[]
  blindsOrders    BlindsOrder[]
  appointments    Appointment[]

  // RAG
  knowledgeChunks SalesKnowledgeChunk[]
  coachingRecords CoachingRecord[]

  @@index([customerId])
  @@index([stage])
  @@index([assignedToId])
  @@index([nextFollowupAt])
  @@index([stage, updatedAt])
}

model CustomerInteraction {
  id              String   @id @default(cuid())
  customerId      String
  customer        SalesCustomer @relation(fields: [customerId], references: [id])
  opportunityId   String?
  opportunity     SalesOpportunity? @relation(fields: [opportunityId], references: [id])
  type            String   // phone_call / wechat / email / in_person / note
  direction       String?  // inbound / outbound
  summary         String   @db.Text
  content         String?  @db.Text
  emailMessageId  String?
  attachments     String?  @db.Text // JSON array of file URLs

  // 多渠道 + 多语言扩展
  channel         String?  // wechat / xiaohongshu / facebook / email / phone / in_person / other
  language        String?  // zh / en / mixed
  rawMessages     String?  @db.Text // JSON: [{role:"customer"|"staff", content:string, time?:string}]
  sentiment       String?  // positive / neutral / negative
  outcome         String?  // converted / lost / pending / info_request / follow_up
  topicTags       String?  // comma-separated: "pricing,zebra,installation"

  // RAG 分析状态
  analysisStatus  String?  // pending / analyzed / failed
  analysisResult  Json?    // AI 结构化分析输出

  createdAt       DateTime @default(now())

  createdById     String
  createdBy       User     @relation("CustomerInteractionCreatedBy", fields: [createdById], references: [id])

  knowledgeChunks SalesKnowledgeChunk[]

  @@index([customerId, createdAt])
  @@index([opportunityId])
  @@index([type])
  @@index([channel])
  @@index([analysisStatus])
}

model SalesQuote {
  id               String    @id @default(cuid())
  opportunityId    String?
  opportunity      SalesOpportunity? @relation(fields: [opportunityId], references: [id])
  customerId       String
  customer         SalesCustomer @relation("SalesQuoteCustomer", fields: [customerId], references: [id])
  version          Int       @default(1)
  status           String    @default("draft") // draft / sent / viewed / accepted / signed / rejected / expired
  installMode      String    @default("default") // default / pickup
  merchSubtotal    Float     @default(0)
  addonsSubtotal   Float     @default(0)
  installSubtotal  Float     @default(0)
  installApplied   Float     @default(0)
  deliveryFee      Float     @default(50)
  preTaxTotal      Float     @default(0)
  taxRate          Float     @default(0.13)
  taxAmount        Float     @default(0)
  grandTotal       Float     @default(0)
  currency         String    @default("CAD")
  sentAt           DateTime?
  emailMessageId   String?
  orderNumber      String?
  notes            String?   @db.Text
  formDataJson     String?   @db.Text

  // Sprint 21 新增字段
  shareToken       String?   @unique  // 报价分享链接 token
  signatureUrl     String?            // 电子签名图片 URL
  signedAt         DateTime?          // 签名时间
  aiSource         String?            // voice / text / image / manual
  viewedAt         DateTime?          // 客户查看时间

  // 折扣率追踪（Step 4）
  totalMsrp        Float?             // 所有产品行的 MSRP 之和（Part B/C 不计入分母）
  specialPromotion Float?   @default(0) // 销售手填的「Special Promotion」让利金额（税前直减）
  finalDiscountPct Float?             // = 1 - (preTaxProducts - specialPromotion) / totalMsrp

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  createdById      String
  createdBy        User      @relation("SalesQuoteCreatedBy", fields: [createdById], references: [id])

  items            SalesQuoteItem[]
  addons           SalesQuoteAddon[]
  rooms            QuoteRoom[]

  @@index([customerId])
  @@index([opportunityId])
  @@index([status])
  @@index([createdAt])
}

/// 全局报价折扣率设置（单行配置 id="singleton"）
/// - Order Form / AI 报价工具 / 驾驶舱统一读取
/// - 仅 admin/super_admin 可写，走 RBAC + 审计日志
/// - 每个字段为 0~1 之间的小数，代表默认百分比折扣
model QuoteDiscountSettings {
  id        String   @id @default("singleton")
  zebra     Float    @default(0.45)
  shangrila Float    @default(0.35)
  cellular  Float    @default(0.35)
  roller    Float    @default(0.45)
  drapery   Float    @default(0.35)
  sheer     Float    @default(0.35)
  shutters  Float    @default(0.35)
  honeycomb Float    @default(0.35)
  // Special Promotion 预警 & 上限阈值（0~1 小数，如 0.06 表示 6%）
  // - warn:   >= 此比例开始黄色提醒
  // - danger: >= 此比例红色强警告
  // - max:    销售不得超过；admin/super_admin 不受限
  promoWarnPct   Float @default(0.06)
  promoDangerPct Float @default(0.15)
  promoMaxPct    Float @default(0.25)
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model SalesQuoteItem {
  id             String  @id @default(cuid())
  quoteId        String
  quote          SalesQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  roomId         String?
  room           QuoteRoom? @relation(fields: [roomId], references: [id])
  sortOrder      Int     @default(0)
  product        String  // Zebra / Roller / Drapery / ...
  fabric         String  // Light Filtering / Blackout / ...
  sku            String? // fabric SKU
  widthIn        Float   // raw width in inches
  heightIn       Float   // raw height in inches
  bracketWidth   Float?  // bracket-aligned width
  bracketHeight  Float?  // bracket-aligned height
  cordless       Boolean @default(false)
  msrp           Float   @default(0)
  discountPct    Float   @default(0)
  discountValue  Float   @default(0)
  price          Float   @default(0)
  installFee     Float   @default(0)
  location       String? // room location note

  @@index([quoteId, sortOrder])
  @@index([roomId])
}

model SalesQuoteAddon {
  id          String  @id @default(cuid())
  quoteId     String
  quote       SalesQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  addonKey    String  // motor / hub / remote / track6 / track8 / track10 / track12
  displayName String
  unitPrice   Float
  qty         Int     @default(1)
  subtotal    Float   @default(0)

  @@index([quoteId])
}

/// 报价房间维度 — 按房间组织报价项
model QuoteRoom {
  id          String  @id @default(cuid())
  quoteId     String
  quote       SalesQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  roomName    String  // Living Room / Master Bedroom / ...
  windowWidth Float?  // 窗户整体宽度（参考）
  windowHeight Float? // 窗户整体高度（参考）
  remarks     String? @db.Text
  sortOrder   Int     @default(0)

  items       SalesQuoteItem[]
  attachments RoomAttachment[]

  @@index([quoteId, sortOrder])
}

/// 房间级附件（量房照片/视频）
// TODO: 量房附件功能预留，API 尚未接入
model RoomAttachment {
  id         String   @id @default(cuid())
  roomId     String
  room       QuoteRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  fileName   String
  fileUrl    String
  fileType   String   @default("image") // image / video
  createdAt  DateTime @default(now())

  @@index([roomId])
}

// ============================================================
// 预约管理（量房 / 安装 / 回访）
// ============================================================

/// 预约记录 — 量房/安装/回访等上门服务
model Appointment {
  id              String    @id @default(cuid())
  customerId      String
  customer        SalesCustomer @relation(fields: [customerId], references: [id])
  opportunityId   String?
  opportunity     SalesOpportunity? @relation(fields: [opportunityId], references: [id])

  type            String    @default("measure") // measure / install / revisit / consultation
  title           String
  description     String?   @db.Text

  startAt         DateTime
  endAt           DateTime
  allDay          Boolean   @default(false)

  address         String?   @db.Text
  contactPhone    String?

  status          String    @default("scheduled") // scheduled / confirmed / in_progress / completed / cancelled / no_show
  cancelReason    String?

  assignedToId    String
  assignedTo      User      @relation("AppointmentAssignee", fields: [assignedToId], references: [id])
  createdById     String
  createdBy       User      @relation("AppointmentCreatedBy", fields: [createdById], references: [id])

  notifiedAt      DateTime? // 微信/站内通知发送时间
  reminderSentAt  DateTime? // 提前提醒发送时间
  completedAt     DateTime?
  notes           String?   @db.Text

  googleEventId   String?   // 同步到 Google Calendar 后的事件 ID
  googleSyncedAt  DateTime? // 最后一次成功同步时间

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([assignedToId, startAt])
  @@index([customerId])
  @@index([opportunityId])
  @@index([status, startAt])
  @@index([startAt])
  @@index([type, startAt])
}

// ============================================================
// 现场量房记录
// ============================================================

/// 量房记录 — 一次上门量房产生一条记录，关联客户/机会/预约
model MeasurementRecord {
  id              String   @id @default(cuid())
  customerId      String
  customer        SalesCustomer @relation(fields: [customerId], references: [id])
  opportunityId   String?
  appointmentId   String?

  status          String   @default("draft") // draft / completed / quoted
  overallNotes    String?  @db.Text
  measuredById    String
  measuredAt      DateTime @default(now())

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  windows         MeasurementWindow[]

  @@index([customerId])
  @@index([opportunityId])
  @@index([measuredById, createdAt])
}

/// 量房窗位 — 每扇窗的尺寸和产品选择
model MeasurementWindow {
  id              String   @id @default(cuid())
  recordId        String
  record          MeasurementRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)

  roomName        String   // Living Room / Master Bedroom / ...
  windowLabel     String?  // W1 / W2 / Bay Window Left / ...
  widthIn         Float    // 宽度（英寸）
  heightIn        Float    // 高度（英寸）
  measureType     String   @default("IN") // IN / OUT / Tight
  product         String?  // Zebra / Roller / ...
  fabric          String?  // Light Filtering / Blackout / ...
  cordless        Boolean  @default(false)
  notes           String?

  sortOrder       Int      @default(0)
  photos          MeasurementPhoto[]

  @@index([recordId, sortOrder])
}

/// 量房照片 — 关联到具体窗位
model MeasurementPhoto {
  id          String   @id @default(cuid())
  windowId    String
  window      MeasurementWindow @relation(fields: [windowId], references: [id], onDelete: Cascade)
  fileName    String
  fileUrl     String
  createdAt   DateTime @default(now())

  @@index([windowId])
}

// ============================================================
// 销售话术库 + FAQ（从真实对话提炼）
// ============================================================

/// 销售话术模板 — 按渠道 + 场景组织
model SalesPlaybook {
  id            String    @id @default(cuid())
  userId        String

  channel       String    // wechat / xiaohongshu / facebook / email / phone
  language      String    // zh / en / mixed
  scene         String    // first_contact / follow_up / price_objection / closing / after_sale / ...
  sceneLabel    String    // 场景中文名
  content       String    @db.Text
  example       String?   @db.Text  // 实际使用范例
  effectiveness Int       @default(0) // 0-5 有效性评分
  sourceInteractionId String? // 提取来源互动 ID
  embedding     Unsupported("vector(1536)")?

  tags          String?   // comma-separated
  status        String    @default("active") // active / archived
  usageCount    Int       @default(0)
  sourceType    String?   // manual / ai_extracted / battle_tested

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId, channel])
  @@index([userId, scene])
  @@index([userId, status])
}

/// 销售 FAQ — 客户常见问题 + 最佳回答
model SalesFAQ {
  id            String    @id @default(cuid())
  userId        String

  question      String    @db.Text
  answer        String    @db.Text
  language      String    // zh / en / mixed
  category      String    // product / pricing / installation / warranty / delivery / process / other
  categoryLabel String

  productTags   String?   // comma-separated: "zebra,roller"
  frequency     Int       @default(1) // 被问到的频次
  sourceInteractionId String?
  embedding     Unsupported("vector(1536)")?

  status        String    @default("active") // active / archived
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId, category])
  @@index([userId, language])
  @@index([userId, status])
}

// ============================================================
// AI 用户长期记忆（借鉴 MemPalace 分层设计）
// ============================================================

/// 用户级 AI 记忆条目 — 跨对话、跨项目的持久知识
model UserMemory {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 记忆分类（借鉴 MemPalace 的 5 类提取）
  memoryType    String    // decision / preference / milestone / problem / insight / fact
  // 记忆层级：L0=身份偏好(始终加载) L1=核心(高频加载) L2=按需(话题匹配)
  layer         Int       @default(1)

  content       String    @db.Text
  // 结构化标签，用于按需检索
  tags          String?   // comma-separated: "sales,pricing,customer:张三"
  // 来源对话 ID，便于溯源
  sourceThreadId String?
  // 关联的客户/项目（可选，便于分域检索）
  customerId    String?
  projectId     String?

  // 重要度 1-5，高的优先加载
  importance    Int       @default(3)
  // 被引用/激活次数，用于衰减排序
  accessCount   Int       @default(0)
  lastAccessedAt DateTime?

  // 向量嵌入 (text-embedding-3-small, 1536维)
  embedding     Json?
  // 被此记忆取代的旧记忆 ID（冲突覆盖时记录）
  supersededById String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId, layer])
  @@index([userId, memoryType])
  @@index([userId, importance])
  @@index([userId, tags])
  @@index([userId, customerId])
  @@index([userId, projectId])
}

// ============================================================
// 动态技能系统（Sprint 16）
// ============================================================

/// AI 动态技能 — 可在运行时创建、修改、自我优化的能力单元
model AgentSkill {
  id              String   @id @default(cuid())
  orgId           String
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  name            String           // 技能名，如 "外贸开发信优化"
  slug            String           // 唯一标识，如 "trade-outreach-optimizer"
  description     String   @db.Text // 技能用途描述
  domain          String           // trade / sales / project / secretary
  tier            String   @default("foundation") // foundation / analysis / execution

  // AI 执行配置
  systemPrompt    String   @db.Text // 执行此技能时的系统 prompt
  userPromptTemplate String @db.Text // 用户 prompt 模板，支持 {{变量}} 占位
  outputFormat    String   @default("text") // text / json / markdown
  temperature     Float    @default(0.3)
  maxTokens       Int      @default(2000)

  // 参数定义（JSON Schema 格式）
  inputSchema     Json?            // { type: "object", properties: { ... } }
  outputSchema    Json?            // 期望输出结构

  // 所需工具（可选，执行时自动挂载这些 Agent Core tools）
  requiredTools   String?          // comma-separated: "trade.get_prospect,secretary.execute_action"

  // 元信息
  version         Int      @default(1)
  isBuiltin       Boolean  @default(false) // 内置技能不可删除
  isActive        Boolean  @default(true)
  createdById     String?
  createdBy       User?    @relation("AgentSkillCreatedBy", fields: [createdById], references: [id])

  // 自我改进
  lastOptimizedAt DateTime?
  optimizationCount Int    @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  executions      SkillExecution[]

  @@unique([orgId, slug])
  @@index([orgId, domain])
  @@index([orgId, isActive])
}

/// 技能执行记录 — 每次 AgentSkill 运行的输入/输出/评分
model SkillExecution {
  id            String   @id @default(cuid())
  skillId       String
  skill         AgentSkill @relation(fields: [skillId], references: [id], onDelete: Cascade)
  userId        String

  // 执行上下文
  inputJson     String   @db.Text  // 传入参数 JSON
  outputJson    String?  @db.Text  // AI 输出 JSON
  toolCalls     Json?              // 执行过程中的工具调用记录

  // 结果评估
  success       Boolean  @default(true)
  durationMs    Int?
  tokenCount    Int?

  // 用户反馈（核心改进信号）
  userRating    Int?              // 1-5 星
  userFeedback  String?  @db.Text // 用户文字反馈
  wasEdited     Boolean  @default(false) // 用户是否编辑了输出

  // prompt 快照（用于回溯对比）
  promptSnapshot String? @db.Text // 执行时使用的完整 prompt

  createdAt     DateTime @default(now())

  @@index([skillId, createdAt])
  @@index([skillId, success])
  @@index([skillId, userRating])
}

// ============================================================
// 跨会话语义搜索 + Context 压缩（Sprint 17）
// ============================================================

/// 统一消息嵌入索引 — 跨所有会话类型的语义搜索
model MessageEmbedding {
  id            String   @id @default(cuid())
  userId        String
  orgId         String?

  // 消息来源（多态引用）
  sourceType    String   // ai_message / trade_chat / project_conversation / project_discussion
  sourceId      String   // 原始消息 ID
  sessionId     String   // 所属会话/线程 ID
  sessionTitle  String?  // 会话标题（冗余存储，加速搜索结果展示）

  role          String   // user / assistant
  content       String   @db.Text
  embedding     Json     // 1536 维向量

  createdAt     DateTime @default(now())

  @@unique([sourceType, sourceId])
  @@index([userId, sourceType])
  @@index([orgId, sourceType])
  @@index([userId, createdAt])
}

/// 会话摘要 — 长对话压缩后的持久化摘要
model ConversationSummary {
  id            String   @id @default(cuid())
  userId        String

  // 会话来源
  sourceType    String   // ai_thread / trade_chat_session / conversation
  sessionId     String   // 原始会话 ID
  sessionTitle  String?

  // 摘要内容
  summary       String   @db.Text  // AI 生成的结构化摘要
  keyTopics     String?  @db.Text  // 逗号分隔的关键主题
  keyDecisions  String?  @db.Text  // 重要决策摘要
  messageCount  Int                // 被摘要的消息数
  tokenEstimate Int?               // 原始消息的估算 token 数

  // 向量（用于搜索摘要本身）
  embedding     Json?

  version       Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([sourceType, sessionId])
  @@index([userId, sourceType])
  @@index([userId, updatedAt])
}

// ============================================================
// 微信双通道消息网关（Sprint 19）
// ============================================================

/// 微信绑定 — 微信用户 ID 与青砚用户的映射
model WeChatBinding {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation("UserWeChatBindings", fields: [userId], references: [id], onDelete: Cascade)
  orgId         String?

  channel       String   // personal_wechat / wecom
  externalId    String   // 微信openid / 企微userid
  displayName   String?  // 微信昵称
  avatarUrl     String?

  // 连接状态
  status        String   @default("active") // active / disconnected / expired
  lastActiveAt  DateTime?

  // 推送偏好
  pushBriefing  Boolean  @default(true)
  pushFollowup  Boolean  @default(true)
  pushReport    Boolean  @default(true)
  pushSales     Boolean  @default(false)  // 销售域推送
  silentStart   String?  // "22:00"
  silentEnd     String?  // "08:00"

  // 业务域权限（逗号分隔，如 "trade,sales"）—— 绑定时根据用户角色自动设置
  pushDomains   String   @default("trade") // trade / sales / project / all

  // 消息过滤
  filterMode    String   @default("all") // all / keyword / whitelist
  filterKeyword String?  // 触发关键词，如"青砚"

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([channel, externalId])
  @@index([userId])
  @@index([channel, status])
}

/// 微信网关连接 — 个人微信 Bot / 企业微信应用的连接实例
model WeChatGateway {
  id            String   @id @default(cuid())
  orgId         String
  channel       String   // personal_wechat / wecom

  // 个人微信 iLink 字段
  botNickname   String?
  botToken      String?  @db.Text
  botBaseUrl    String?
  getUpdatesBuf String?  @db.Text
  loginStatus   String   @default("disconnected") // qr_pending / scanning / connected / disconnected

  // 企业微信字段
  corpId        String?
  agentId       String?
  secret        String?  // 加密存储
  callbackToken String?
  encodingKey   String?

  status        String   @default("inactive") // active / inactive / error
  lastHeartbeat DateTime?
  errorMessage  String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([orgId, channel])
}

/// 微信消息记录
model WeChatMessage {
  id            String   @id @default(cuid())
  bindingId     String   // 关联的 WeChatBinding
  userId        String
  orgId         String?

  direction     String   // inbound / outbound
  channel       String   // personal_wechat / wecom
  externalUserId String  // 对方微信ID
  content       String   @db.Text
  messageType   String   @default("text") // text / image / file / voice
  externalMsgId String?  // 微信侧消息ID

  // AI 处理
  agentProcessed Boolean @default(false)
  agentResponse  String? @db.Text

  createdAt     DateTime @default(now())

  @@index([bindingId, createdAt])
  @@index([userId, createdAt])
  @@index([channel, createdAt])
}

// ============================================================
// 销售智能 RAG — 知识库 + 客户画像 + 训练闭环
// ============================================================

/// 销售知识分块 — 沟通内容经 AI 分析后的语义分块
model SalesKnowledgeChunk {
  id              String   @id @default(cuid())

  // 来源关联
  sourceType      String   // email / wechat / call_transcript / note / bulk_upload
  sourceId        String?  // CustomerInteraction.id 或上传批次 ID
  customerId      String?
  customer        SalesCustomer?    @relation(fields: [customerId], references: [id])
  opportunityId   String?
  opportunity     SalesOpportunity? @relation(fields: [opportunityId], references: [id])
  interactionId   String?
  interaction     CustomerInteraction? @relation(fields: [interactionId], references: [id])

  // 内容
  content         String   @db.Text
  embedding       Unsupported("vector(1536)")?
  // 元数据
  metadata        Json?    // { speaker, direction, timestamp, dealStage, dealOutcome }
  tags            String[] // AI 提取的标签
  language        String   @default("en")

  // AI 分析结果
  sentiment       String?  // positive / negative / neutral
  intent          String?  // objection / inquiry / negotiation / closing / smalltalk
  objectionType   String?  // price / timing / competition / authority / need
  isWinPattern    Boolean  @default(false)
  isLossSignal    Boolean  @default(false)

  createdAt       DateTime @default(now())

  @@index([customerId])
  @@index([opportunityId])
  @@index([interactionId])
  @@index([sourceType])
  @@index([isWinPattern])
  @@index([isLossSignal])
  @@index([intent])
}

/// 销售洞察 — AI 提炼的赢单/丢单模式与最佳实践
model SalesInsight {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation("SalesInsightUser", fields: [userId], references: [id])

  // 洞察类型
  insightType     String   // win_pattern / loss_signal / objection_response / best_practice / stage_tactic
  // 内容
  title           String
  description     String   @db.Text
  embedding       Unsupported("vector(1536)")?

  // 适用条件
  dealStage       String?  // 适用的商机阶段
  productType     String?  // 适用的产品类型
  customerTags    String[] // 适用客户标签
  objectionType   String?  // 针对的异议类型

  // 效果追踪
  effectiveness   Float    @default(0) // 0-1 有效性权重
  usageCount      Int      @default(0)
  successCount    Int      @default(0)

  // 来源
  sourceChunkIds  String[]
  status          String   @default("active") // active / deprecated

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  coachingRecords CoachingRecord[]

  @@index([insightType])
  @@index([dealStage])
  @@index([status])
  @@index([effectiveness])
}

/// 客户画像 — AI 自动生成的结构化画像（销售 + Marketing 预留）
model CustomerProfile {
  id                  String   @id @default(cuid())
  customerId          String   @unique
  customer            SalesCustomer @relation(fields: [customerId], references: [id])

  // 基础画像
  customerType        String?  // residential / commercial / designer / contractor / developer
  decisionRole        String?  // owner / spouse / property_manager / designer / committee
  budgetRange         String?  // economy / mid_range / premium / luxury
  priceSensitivity    Float?   // 0-1

  // 行为画像
  communicationStyle  String?  // direct / detail_oriented / relationship_focused / price_driven
  preferredChannel    String?  // wechat / email / phone / in_person
  responseSpeed       String?  // fast_responder / slow_deliberate / ghost_risk
  decisionSpeed       String?  // impulse / moderate / slow_researcher

  // 需求画像
  productPreferences  String[] // motorized / blackout / sheer / zebra ...
  roomTypes           String[] // bedroom / living_room / office / bathroom ...
  keyNeeds            String[] // child_safety / energy_efficiency / smart_home ...
  objectionHistory    String[] // price / timing / competition ...

  // 成交预测
  winProbability          Float?   // 0-1
  estimatedLifetimeValue  Float?
  churnRisk               Float?   // 0-1

  // Marketing 预留字段
  acquisitionChannel  String?  // referral / google_ads / social_media / walk_in / website
  referralSource      String?
  contentEngagement   Json?    // { emailOpenRate, clickRate, lastEngagedAt, interestedTopics[] }
  segment             String?  // high_value_repeat / new_lead / at_risk
  campaignIds         String[]

  // 元数据
  confidence          Float    @default(0) // 画像置信度 0-1
  lastAnalyzedAt      DateTime?
  analysisVersion     Int      @default(1)
  embedding           Unsupported("vector(1536)")?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([customerType])
  @@index([segment])
  @@index([budgetRange])
  @@index([winProbability])
}

/// 教练记录 — 记录每次 AI 建议及后续效果，用于自我训练
model CoachingRecord {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation("CoachingRecordUser", fields: [userId], references: [id])
  customerId      String
  customer        SalesCustomer @relation(fields: [customerId], references: [id])
  opportunityId   String?
  opportunity     SalesOpportunity? @relation(fields: [opportunityId], references: [id])

  // AI 推荐内容
  insightId       String?
  insight         SalesInsight? @relation(fields: [insightId], references: [id])
  coachingType    String   // tactic / objection_response / email_draft / next_action
  recommendation  String   @db.Text
  context         Json?    // { dealStage, customerTags, triggerEvent }

  // 销售行为
  adopted         Boolean?
  adoptedAt       DateTime?

  // 结果归因
  outcome         String?  // won / lost / still_open / ignored
  outcomeAt       DateTime?
  daysToOutcome   Int?
  dealValue       Float?
  contributionScore Float? // 0-1

  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([customerId])
  @@index([opportunityId])
  @@index([insightId])
  @@index([outcome])
  @@index([coachingType])
}
