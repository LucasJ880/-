  minimumPriority       String   @default("medium")
  metadata              String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([userId, projectId])
  @@index([projectId])
}

// ============================================================
// 外部集成：BidToGo 等系统对接
// ============================================================

model ExternalReference {
  id         String   @id @default(cuid())
  system     String
  externalId String
  url        String?
  projectId  String   @unique
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([system, externalId])
  @@index([system])
}

model ProjectIntelligence {
  id              String   @id @default(cuid())
  projectId       String   @unique
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  recommendation  String
  riskLevel       String
  fitScore        Int      @default(0)
  summary         String?
  fullReportUrl   String?
  fullReportJson  String?
  reportMarkdown  String?

  // 审核工作流
  reportStatus    String   @default("ai_generated")  // draft | ai_generated | in_review | approved | needs_revision | delivered
  reviewedBy      String?
  reviewedAt      DateTime?
  reviewNotes     String?
  reviewScore     Int?     // 1-5 人工评分（可选）

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ProjectProgressSummary {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // 输出内容
  overallStatus   String                  // green | yellow | red
  statusLabel     String
  outputJson      String   @db.Text       // 完整 ProgressSummaryOutput JSON
  executiveSummary String?

  // 生成元数据
  docType         String   @default("project_progress_summary")
  promptVersion   String
  modelUsed       String
  usedFallback    Boolean  @default(false)
  generationTimeMs Int     @default(0)
  metaJson        String?  @db.Text       // 完整 ProgressSummaryMeta JSON

  // 审核工作流
  reportStatus    String   @default("ai_generated")  // ai_generated | in_review | approved | needs_revision
  reviewedBy      String?
  reviewedAt      DateTime?
  reviewNotes     String?
  reviewScore     Int?     // 1-5

  // 触发方式
  triggerType     String   @default("manual")  // manual | cron | agent

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([projectId])
  @@index([projectId, createdAt])
}

model ProjectDocument {
  id             String    @id @default(cuid())
  projectId      String
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title          String
  url            String
  blobUrl        String?
  fileType       String
  fileSize       Int?
  contentText    String?   @db.Text
  parseStatus    String    @default("pending") // pending | parsing | done | failed
  parseError     String?
  aiSummaryJson  String?   @db.Text            // AI 结构化摘要 JSON
  aiSummaryStatus String   @default("pending") // pending | generating | done | failed
  source         String    @default("external_link")
  uploadedById   String?
  sortOrder      Int       @default(0)
  createdAt      DateTime  @default(now())

  @@index([projectId])
  @@index([source])
}

model ApiToken {
  id          String    @id @default(cuid())
  name        String
  token       String    @unique
  system      String
  permissions String    @default("project:create")
  isActive    Boolean   @default(true)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([token])
  @@index([system])
}

model WebhookEndpoint {
  id           String    @id @default(cuid())
  system       String
  url          String
  secret       String
  events       String
  isActive     Boolean   @default(true)
  lastCalledAt DateTime?
  failCount    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([system])
}

// ─────────────────────────────────────────
// 项目讨论（Project Discussion）
// ─────────────────────────────────────────

model ProjectConversation {
  id         String    @id @default(cuid())
  projectId  String    @unique
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  kind       String    @default("MAIN")
  title      String    @default("项目讨论")
  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  messages   ProjectMessage[]
}

model ProjectMessage {
  id             String   @id @default(cuid())
  conversationId String
  conversation   ProjectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  projectId      String
  senderId       String?
  sender         User?    @relation("ProjectMessageSender", fields: [senderId], references: [id], onDelete: SetNull)
  type           String   @default("TEXT")
  body           String
  metadata       Json?
  replyToId      String?
  editedAt       DateTime?
  deletedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([conversationId, createdAt, id])
  @@index([projectId, createdAt, id])
  @@index([projectId, type, createdAt])
  @@index([senderId, createdAt])
}

// ── AI 助手持久对话 ──────────────────────────────────────────

model AiThread {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId     String?
  project       Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  title         String    @default("新对话")
  pinned        Boolean   @default(false)
  archived      Boolean   @default(false)
  lastMessageAt DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  messages      AiMessage[]

  @@index([userId, pinned, lastMessageAt])
  @@index([userId, projectId])
}

model AiMessage {
  id             String   @id @default(cuid())
  threadId       String
  thread         AiThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  role           String
  content        String
  workSuggestion Json?
  createdAt      DateTime @default(now())

  @@index([threadId, createdAt])
}

// ============================================================
// 供应商询价（Supplier Inquiry）
// ============================================================

model Supplier {
  id            String   @id @default(cuid())
  orgId         String
  org           Organization @relation(fields: [orgId], references: [id])
  name          String
  contactName   String?
  contactEmail  String?
  contactPhone  String?
  category      String?
  region        String?
  notes         String?
  status        String   @default("active")
  createdById   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  brochureUrl          String?
  brochureParseStatus  String?
  brochureParseResult  Json?
  brochureParseWarning String?

  inquiryItems  InquiryItem[]

  @@index([orgId, status])
  @@index([orgId, name])
}

model ProjectInquiry {
  id            String    @id @default(cuid())
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  roundNumber   Int       @default(1)
  title         String?
  scope         String?
  status        String    @default("draft")
  dueDate       DateTime?
  token         String?   @unique
  createdById   String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  items         InquiryItem[]

  @@unique([projectId, roundNumber])
  @@index([projectId, status])
}

model InquiryItem {
  id            String    @id @default(cuid())
  inquiryId     String
  inquiry       ProjectInquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  supplierId    String
  supplier      Supplier  @relation(fields: [supplierId], references: [id])

  // ── 流程状态 ──
  status        String    @default("pending")
  sentVia       String?
  sentAt        DateTime?
  repliedAt     DateTime?
  declinedAt    DateTime?

  // ── 报价内容 ──
  unitPrice     Decimal?  @db.Decimal(18, 2)
  totalPrice    Decimal?  @db.Decimal(18, 2)
  currency      String    @default("CAD")
  deliveryDays  Int?
  validUntil    DateTime?
  quoteNotes    String?

  // ── 选定 ──
  isSelected    Boolean   @default(false)

  // ── 沟通备注 ──
  contactNotes  String?

  // ── 元数据 ──
  createdById   String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([inquiryId, supplierId])
  @@index([inquiryId, status])
  @@index([supplierId])
}

// ============================================================
// 项目报价
// ============================================================

/// 项目报价单 — AI 辅助生成 + 人工编辑确认
model ProjectQuote {
  id              String    @id @default(cuid())
  projectId       String
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  templateType    String    @default("export_standard")
  version         Int       @default(1)
  status          String    @default("draft")

  title           String?
  currency        String    @default("CAD")
  tradeTerms      String?
  paymentTerms    String?
  deliveryDays    Int?
  validUntil      DateTime?
  moq             Int?
  originCountry   String?

  subtotal        Decimal?  @db.Decimal(18, 2)
  totalAmount     Decimal?  @db.Decimal(18, 2)

  internalCost    Decimal?  @db.Decimal(18, 2)
  profitMargin    Decimal?  @db.Decimal(5, 2)
  internalNotes   String?

  aiGenerated     Boolean   @default(false)
  aiDraftJson     String?   @db.Text
  aiReviewJson    String?   @db.Text

  inquiryId       String?
  createdById     String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  lineItems       QuoteLineItem[]

  @@index([projectId, status])
  @@index([projectId, version])
}

/// 报价行项目
model QuoteLineItem {
  id              String    @id @default(cuid())
  quoteId         String
  quote           ProjectQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  sortOrder       Int       @default(0)
  category        String    @default("product")
  itemName        String
  specification   String?
  unit            String?
  quantity        Decimal?  @db.Decimal(18, 2)
  unitPrice       Decimal?  @db.Decimal(18, 2)
  totalPrice      Decimal?  @db.Decimal(18, 2)
  remarks         String?

  costPrice       Decimal?  @db.Decimal(18, 2)
  isInternal      Boolean   @default(false)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([quoteId, sortOrder])
}

// ============================================================
// 邮件发送
// ============================================================

/// 用户绑定的 Gmail OAuth 凭据（独立于 CalendarProvider）
model EmailProvider {
  id            String    @id @default(cuid())
  userId        String
  type          String    @default("gmail")
  accessToken   String    @db.Text
  refreshToken  String?   @db.Text
  tokenExpiry   DateTime?
  accountEmail  String

  /// 记录本次授权实际获得的 scope 列表（空格分隔），用于权限审查与增量授权诊断
  grantedScopes String?   @db.Text

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([userId, type])
  @@index([userId])
}

/// 项目内发出的邮件记录
model ProjectEmail {
  id                String    @id @default(cuid())
  orgId             String
  projectId         String
  inquiryId         String?
  inquiryItemId     String?

  toEmail           String
  toName            String?
  fromEmail         String
  subject           String
  body              String    @db.Text

  status            String    @default("draft")   // draft | sending | sent | failed
  provider          String    @default("gmail")
  externalMessageId String?
  errorMessage      String?

  createdById       String
  sentById          String?
  createdAt         DateTime  @default(now())
  sentAt            DateTime?
  updatedAt         DateTime  @updatedAt

  @@index([projectId])
  @@index([inquiryItemId])
  @@index([orgId, projectId])
}

/// 项目问题 / RFI — 向业主/GC/顾问发送的澄清确认邮件
model ProjectQuestion {
  id                  String    @id @default(cuid())
  projectId           String
  orgId               String?

  // ── 问题内容 ──
  title               String
  description         String    @db.Text
  locationOrReference String?
  clarificationNeeded String?   @db.Text
  impactNote          String?   @db.Text

  // ── 生成的邮件 ──
  generatedSubject    String?
  generatedBody       String?   @db.Text
  toRecipients        String?
  ccRecipients        String?

  // ── 流程状态 ──
  status              String    @default("draft") // draft | generated | sent | replied | closed
  emailId             String?

  // ── 元数据 ──
  createdById         String
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([projectId, status])
  @@index([projectId, createdAt])
}

// ══════════════════════════════════════════════════════════════════
// 子智能体委派系统
// ══════════════════════════════════════════════════════════════════

model AgentTask {
  id               String    @id @default(cuid())
  projectId        String
  project          Project   @relation(fields: [projectId], references: [id])
  taskType         String    @default("custom")
  triggerType       String    @default("manual")
  intent           String    @db.Text
  riskLevel        String    @default("low")
  status           String    @default("draft")
  currentStepIndex Int       @default(0)
  totalSteps       Int       @default(0)
  priority         String    @default("normal")
  parentTaskId     String?
  requiresApproval Boolean   @default(false)
  createdById      String
  createdBy        User      @relation("AgentTaskCreatedBy", fields: [createdById], references: [id])
  startedAt        DateTime?
  completedAt      DateTime?
  failedAt         DateTime?
  cancelledAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  steps            AgentTaskStep[]
  approvalRequests ApprovalRequest[]
  toolExecutions   ToolExecution[]

  @@index([projectId, status])
  @@index([createdById, status])
}

model AgentTaskStep {
  id               String    @id @default(cuid())
  taskId           String
  task             AgentTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  stepIndex        Int
  skillId          String
  agentName        String
  title            String
  description      String?
  riskLevel        String    @default("low")
  requiresApproval Boolean   @default(false)
  status           String    @default("pending")
  inputJson        String?   @db.Text
  outputJson       String?   @db.Text
  outputSummary    String?
  checkReportJson  String?   @db.Text
  confidence       Float?
  approvedBy       String?
  approvedAt       DateTime?
  rejectionNote    String?
  startedAt        DateTime?
  completedAt      DateTime?
  error            String?   @db.Text
  retryCount       Int       @default(0)
  createdAt        DateTime  @default(now())

  approvalRequests ApprovalRequest[]
  toolExecutions   ToolExecution[]

  @@index([taskId, stepIndex])
}

model ApprovalRequest {
  id               String    @id @default(cuid())
  taskId           String
  task             AgentTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  stepId           String
  step             AgentTaskStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  actionType       String
  riskLevel        String
  riskReason       String?   @db.Text
  previewJson      String?   @db.Text
  approverUserId   String?
  status           String    @default("pending")
  deadlineAt       DateTime?
  decidedAt        DateTime?
  decidedBy        String?
  decisionNote     String?   @db.Text
  acceptedWithRisk Boolean   @default(false)
  createdAt        DateTime  @default(now())

  @@index([taskId])
  @@index([approverUserId, status])
}

model ToolExecution {
  id               String    @id @default(cuid())
  taskId           String?
  task             AgentTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)
  stepId           String?
  step             AgentTaskStep? @relation(fields: [stepId], references: [id], onDelete: SetNull)
  toolName         String
  toolInput        String?   @db.Text
  toolOutput       String?   @db.Text
  status           String    @default("pending")
  retryCount       Int       @default(0)
  maxRetries       Int       @default(2)
  idempotencyKey   String    @unique
  error            String?   @db.Text
  executedBy       String
  executedAt       DateTime?
  duration         Int?
  createdAt        DateTime  @default(now())

  @@index([taskId])
  @@index([idempotencyKey])
}

model CustomFlowTemplate {
  id               String    @id @default(cuid())
  name             String
  description      String?   @db.Text
  icon             String?
  category         String    @default("custom")
  stepsJson        String    @db.Text
  createdById      String
  createdBy        User      @relation("CustomFlowTemplateCreatedBy", fields: [createdById], references: [id])
  isPublic         Boolean   @default(false)
  enabled          Boolean   @default(true)
  usageCount       Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([createdById])
  @@index([category])
}

// ============================================================
// Sales CRM Models — Sunny Shutter B2C 销售流程
// ============================================================

model SalesCustomer {
  id            String   @id @default(cuid())
  name          String
  phone         String?
  email         String?
  address       String?
  source        String?  // referral / google_ads / walk_in / wechat / other
  wechatNote    String?
  status        String   @default("active") // active / completed / dormant
  tags          String?  // comma-separated tags
  notes         String?  @db.Text
  jdyDataId     String?  @unique // 简道云 record ID for future sync
  lastSyncAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  createdById   String
  createdBy     User     @relation("SalesCustomerCreatedBy", fields: [createdById], references: [id])

  opportunities  SalesOpportunity[]
  interactions   CustomerInteraction[]
  quotes         SalesQuote[]       @relation("SalesQuoteCustomer")
  blindsOrders   BlindsOrder[]

  @@index([status])
  @@index([phone])
  @@index([email])
  @@index([createdAt])
}

model SalesOpportunity {
  id              String    @id @default(cuid())
  customerId      String
  customer        SalesCustomer @relation(fields: [customerId], references: [id])
  title           String
  stage           String    @default("new_inquiry") // Pipeline stage
  estimatedValue  Float?
  windowCount     Int?
  productTypes    String?   // comma-separated: Zebra,Roller,Drapery,...
  source          String?   // lead source
  priority        String    @default("warm") // hot / warm / cold
  lostReason      String?   @db.Text
  wonAt           DateTime?
  lostAt          DateTime?
  nextFollowupAt  DateTime?
  measureDate     DateTime?
  installDate     DateTime?
  jdyDataId       String?   @unique
  lastSyncAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  assignedToId    String?
  assignedTo      User?     @relation("SalesOpportunityAssignee", fields: [assignedToId], references: [id])
  createdById     String
  createdBy       User      @relation("SalesOpportunityCreatedBy", fields: [createdById], references: [id])

  interactions    CustomerInteraction[]
  quotes          SalesQuote[]
  blindsOrders    BlindsOrder[]

  @@index([customerId])
  @@index([stage])
  @@index([assignedToId])
  @@index([nextFollowupAt])
  @@index([stage, updatedAt])
}

model CustomerInteraction {
  id              String   @id @default(cuid())
  customerId      String
  customer        SalesCustomer @relation(fields: [customerId], references: [id])
  opportunityId   String?
  opportunity     SalesOpportunity? @relation(fields: [opportunityId], references: [id])
  type            String   // phone_call / wechat / email / in_person / note
  direction       String?  // inbound / outbound
  summary         String   @db.Text
  content         String?  @db.Text
  emailMessageId  String?
  attachments     String?  @db.Text // JSON array of file URLs

  // 多渠道 + 多语言扩展
  channel         String?  // wechat / xiaohongshu / facebook / email / phone / in_person / other
  language        String?  // zh / en / mixed
  rawMessages     String?  @db.Text // JSON: [{role:"customer"|"staff", content:string, time?:string}]
  sentiment       String?  // positive / neutral / negative
  outcome         String?  // converted / lost / pending / info_request / follow_up
  topicTags       String?  // comma-separated: "pricing,zebra,installation"

  createdAt       DateTime @default(now())

  createdById     String
  createdBy       User     @relation("CustomerInteractionCreatedBy", fields: [createdById], references: [id])

  @@index([customerId, createdAt])
  @@index([opportunityId])
  @@index([type])
  @@index([channel])
}

model SalesQuote {
  id               String    @id @default(cuid())
  opportunityId    String?
  opportunity      SalesOpportunity? @relation(fields: [opportunityId], references: [id])
  customerId       String
  customer         SalesCustomer @relation("SalesQuoteCustomer", fields: [customerId], references: [id])
  version          Int       @default(1)
  status           String    @default("draft") // draft / sent / accepted / rejected
  installMode      String    @default("default") // default / pickup
  merchSubtotal    Float     @default(0)
  addonsSubtotal   Float     @default(0)
  installSubtotal  Float     @default(0)
  installApplied   Float     @default(0)
  deliveryFee      Float     @default(50)
  preTaxTotal      Float     @default(0)
  taxRate          Float     @default(0.13)
  taxAmount        Float     @default(0)
  grandTotal       Float     @default(0)
  currency         String    @default("CAD")
  sentAt           DateTime?
  emailMessageId   String?
  notes            String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  createdById      String
  createdBy        User      @relation("SalesQuoteCreatedBy", fields: [createdById], references: [id])

  items            SalesQuoteItem[]
  addons           SalesQuoteAddon[]

  @@index([customerId])
  @@index([opportunityId])
  @@index([status])
  @@index([createdAt])
}

model SalesQuoteItem {
  id             String  @id @default(cuid())
  quoteId        String
  quote          SalesQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  sortOrder      Int     @default(0)
  product        String  // Zebra / Roller / Drapery / ...
  fabric         String  // Light Filtering / Blackout / ...
  sku            String? // fabric SKU
  widthIn        Float   // raw width in inches
  heightIn       Float   // raw height in inches
  bracketWidth   Float?  // bracket-aligned width
  bracketHeight  Float?  // bracket-aligned height
  cordless       Boolean @default(false)
  msrp           Float   @default(0)
  discountPct    Float   @default(0)
  discountValue  Float   @default(0)
  price          Float   @default(0)
  installFee     Float   @default(0)
  location       String? // room location note

  @@index([quoteId, sortOrder])
}

model SalesQuoteAddon {
  id          String  @id @default(cuid())
  quoteId     String
  quote       SalesQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  addonKey    String  // motor / hub / remote / track6 / track8 / track10 / track12
  displayName String
  unitPrice   Float
  qty         Int     @default(1)
  subtotal    Float   @default(0)

  @@index([quoteId])
}

// ============================================================
// 销售话术库 + FAQ（从真实对话提炼）
// ============================================================

/// 销售话术模板 — 按渠道 + 场景组织
model SalesPlaybook {
  id            String    @id @default(cuid())
  userId        String

  channel       String    // wechat / xiaohongshu / facebook / email / phone
  language      String    // zh / en / mixed
  scene         String    // first_contact / follow_up / price_objection / closing / after_sale / ...
  sceneLabel    String    // 场景中文名
  content       String    @db.Text
  example       String?   @db.Text  // 实际使用范例
  effectiveness Int       @default(0) // 0-5 有效性评分
  sourceInteractionId String? // 提取来源互动 ID

  tags          String?   // comma-separated
  status        String    @default("active") // active / archived
  usageCount    Int       @default(0)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId, channel])
  @@index([userId, scene])
  @@index([userId, status])
}

/// 销售 FAQ — 客户常见问题 + 最佳回答
model SalesFAQ {
  id            String    @id @default(cuid())
  userId        String

  question      String    @db.Text
  answer        String    @db.Text
  language      String    // zh / en / mixed
  category      String    // product / pricing / installation / warranty / delivery / process / other
  categoryLabel String

  productTags   String?   // comma-separated: "zebra,roller"
  frequency     Int       @default(1) // 被问到的频次
  sourceInteractionId String?

  status        String    @default("active") // active / archived
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId, category])
  @@index([userId, language])
  @@index([userId, status])
}

// ============================================================
// AI 用户长期记忆（借鉴 MemPalace 分层设计）
// ============================================================

/// 用户级 AI 记忆条目 — 跨对话、跨项目的持久知识
model UserMemory {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 记忆分类（借鉴 MemPalace 的 5 类提取）
  memoryType    String    // decision / preference / milestone / problem / insight / fact
  // 记忆层级：L0=身份偏好(始终加载) L1=核心(高频加载) L2=按需(话题匹配)
  layer         Int       @default(1)

  content       String    @db.Text
  // 结构化标签，用于按需检索
  tags          String?   // comma-separated: "sales,pricing,customer:张三"
  // 来源对话 ID，便于溯源
  sourceThreadId String?
  // 关联的客户/项目（可选，便于分域检索）
  customerId    String?
  projectId     String?

  // 重要度 1-5，高的优先加载
  importance    Int       @default(3)
  // 被引用/激活次数，用于衰减排序
  accessCount   Int       @default(0)
  lastAccessedAt DateTime?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId, layer])
  @@index([userId, memoryType])
  @@index([userId, importance])
  @@index([userId, tags])
  @@index([userId, customerId])
  @@index([userId, projectId])
}
