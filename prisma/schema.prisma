// ============================================================
// PR4 — AI 发起的待审批动作（Pending Action）
// ============================================================
// AI 通过工具生成的"写动作"不直接落库，而是先写到这里。
// 用户在聊天里点"批准"后才由 executor 执行真正的副作用。
// status 流转：pending -> approved -> executed / failed
//            pending -> rejected

model PendingAction {
  id String @id @default(cuid())

  /**
   * 动作类型，如 sales.update_followup、sales.update_stage、calendar.create_event
   */
  type String

  /**
   * 用户可读的标题 —— 一句话说明这个动作
   */
  title String

  /**
   * 用户可读的预览 —— 更详细的描述
   */
  preview String @db.Text

  /**
   * 执行动作所需的完整参数（含资源 ID、新值等），JSON 结构
   */
  payload Json

  /**
   * pending / approved / rejected / executed / failed
   */
  status String @default("pending")

  /**
   * 生成草稿的用户（也是有权批准的人）
   */
  createdById String
  createdBy   User   @relation("PendingActionCreatedBy", fields: [createdById], references: [id])

  /// 团队审批范围。为空时保持旧语义：只有创建人本人可处理。
  orgId          String?
  projectId      String?
  approverUserId String?
  approver       User?   @relation("PendingActionApprover", fields: [approverUserId], references: [id], onDelete: SetNull)
  requiredRole   String?
  decidedById    String?
  decidedBy      User?   @relation("PendingActionDecidedBy", fields: [decidedById], references: [id], onDelete: SetNull)

  /**
   * 触发生成的 AI 会话（用于回查上下文）
   */
  threadId String?

  /**
   * 触发生成的消息 ID（用于回查上下文）
   */
  messageId String?

  /**
   * 关联的 AgentRun（微信/Runtime 任务）。取消 Run 时联动拒绝未决草稿。
   */
  agentRunId String?

  /**
   * 过期时间（默认创建时 +24h）
   */
  expiresAt DateTime

  /**
   * 批准 / 拒绝时间
   */
  decidedAt DateTime?

  /**
   * 实际执行完成时间
   */
  executedAt DateTime?

  /**
   * 失败时的错误信息
   */
  failureReason String? @db.Text

  /**
   * 执行后产生的资源 ID，供前端跳转（可选）
   */
  resultRef String?

  /// Phase 3A-3：可选 Workspace 归属（历史可空；新草稿应尽量写入）
  workspaceId String?
  /// Phase 3A-3：防篡改 — 审批创建时固定
  payloadVersion Int?
  payloadHash    String?
  policyVersion  String?
  resourceVersion String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdById, status, createdAt])
  @@index([approverUserId, status, createdAt])
  @@index([orgId, status, createdAt])
  @@index([projectId, status, createdAt])
  @@index([threadId])
  @@index([agentRunId, status])
  @@index([orgId, workspaceId, status])
}

/// Phase 3A-3：审批决定幂等（防重复点击 / 网络重试）
model ApprovalDecisionIdempotency {
  id             String   @id @default(cuid())
  orgId          String
  idempotencyKey String
  approvalKey    String   // sourceType:sourceId
  action         String   // approve | reject | cancel | retry
  userId         String
  resultJson     Json?
  createdAt      DateTime @default(now())

  @@unique([orgId, idempotencyKey])
  @@index([orgId, approvalKey])
}

