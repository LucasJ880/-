  updatedAt       DateTime @updatedAt

  tags            MessageFeedbackTag[]

  @@index([projectId, environmentId])
  @@index([conversationId])
  @@index([messageId])
  @@index([status])
  @@index([createdById])
}

model EvaluationTag {
