  campaign   TradeCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  orgId      String

  /// 负责该线索的销售；历史数据由活动创建人回填
  ownerId String?
  owner   User?   @relation("TradeProspectOwner", fields: [ownerId], references: [id])

  companyName  String
  contactName  String?
  contactEmail String?
  contactTitle String?
  website      String?
  country      String?
  source       String  @default("google") // google / exhibition / 1688 / linkedin / manual

  researchReport Json?
  score          Float?
  scoreReason    String? @db.Text

  /// Serper 等得到的候选官网 JSON 数组（见 website-candidate-scoring）
  websiteCandidates      Json?
  /// 当前用于研究的官网置信度 0–1
  websiteConfidence      Float?
  /// user_provided | imported | serper_auto_high_confidence | serper_candidates_pending | manual_confirmed
  websiteCandidateSource String?
  websiteVerifiedAt      DateTime?
  websiteVerifiedBy      String?

  /// 研究管线状态（与 stage 独立）；历史数据可为 null
  researchStatus    String?
  researchWarnings  Json?
  crawlStatus       String?
  crawlSourceType   String?
  sourcesCount      Int?
  lastResearchError String?   @db.VarChar(2000)
  lastResearchedAt  DateTime?

  /// 线索业务生命周期（标准值见 src/lib/trade/stage.ts TRADE_PROSPECT_STAGES）
  stage String @default("new")

  outreachSubject String?
  outreachBody    String?   @db.Text
  outreachLang    String?   @default("en")
  outreachSentAt  DateTime?

  lastContactAt  DateTime?
  nextFollowUpAt DateTime?
  followUpCount  Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages                    TradeMessage[]
  quotes                      TradeQuote[]
  watchTargets                TradeWatchTarget[]
  intelligenceCaseConversions TradeIntelligenceCase[] @relation("TradeIntelligenceCaseProspect")

  /// 转入销售 CRM 后回填（与 stage=converted 配套）
  convertedToSalesCustomerId    String?
  convertedToSalesOpportunityId String?
  convertedAt                   DateTime?
  convertedById                 String?
  convertedBy                   User?     @relation("TradeProspectConvertedBy", fields: [convertedById], references: [id])

  @@index([campaignId, stage])
  @@index([orgId, stage])
  @@index([orgId, ownerId, stage])
  @@index([orgId, researchStatus])
  @@index([nextFollowUpAt])
  @@index([score])
}

// P1-alpha：少量 URL 文本指纹监控（与 researchReport / bundle 无关）
model TradeWatchTarget {
  id              String         @id @default(cuid())
  orgId           String
  prospectId      String?
  prospect        TradeProspect? @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  url             String         @db.Text
  pageType        String // products | collections | news | blog | about | careers | custom
  isActive        Boolean        @default(true)
  lastContentHash String?
  lastCheckedAt   DateTime?
  lastChangedAt   DateTime?
  lastFetchError  String?        @db.VarChar(500)
  createdById     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  signals TradeSignal[]

  @@index([orgId, isActive])
  @@index([prospectId])
}

model TradeSignal {
  id            String           @id @default(cuid())
  orgId         String
  watchTargetId String
  watchTarget   TradeWatchTarget @relation(fields: [watchTargetId], references: [id], onDelete: Cascade)
  prospectId    String?
  signalType    String           @default("page_text_changed")
  strength      String           @default("low") // P1-alpha 固定 low
  title         String
  description   String           @db.Text
  evidenceJson  Json?
  createdAt     DateTime         @default(now())

  @@index([orgId, createdAt])
  @@index([prospectId, createdAt])
  @@index([watchTargetId, createdAt])
}

// ============================================================
// 市场情报 — 竞品监听、证据快照与分析审核
// ============================================================

model MarketCompetitor {
  id               String       @id @default(cuid())
  orgId            String
  org              Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name             String
  websiteUrl       String       @db.Text
  normalizedDomain String
  targetGeography  String?
  primaryProduct   String?
  salesModel       String?      @default("询价报价 + 预约量房")
  watchFocus       Json?
  status           String       @default("active") // active | paused | setup_error
  createdById      String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  monitors     MarketMonitor[]
  analysisRuns MarketAnalysisRun[]

  @@unique([orgId, normalizedDomain])
  @@index([orgId, status])
  @@index([orgId, updatedAt])
}

model MarketMonitor {
  id                String           @id @default(cuid())
  orgId             String
  competitorId      String
  competitor        MarketCompetitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  provider          String           @default("firecrawl")
  providerMonitorId String?          @unique
  status            String           @default("provisioning") // provisioning | active | paused | error
  scheduleText      String           @default("weekly")
  scheduleCron      String?
  timezone          String           @default("America/Toronto")
  goal              String           @db.Text
  targetUrls        Json
  nextRunAt         DateTime?
  lastRunAt         DateTime?
  lastCheckId       String?
  lastError         String?          @db.VarChar(2000)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  snapshots MarketSnapshot[]

  @@unique([competitorId, provider])
  @@index([orgId, status])
  @@index([orgId, nextRunAt])
}

model MarketSnapshot {
  id              String        @id @default(cuid())
  orgId           String
  monitorId       String
  monitor         MarketMonitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  providerEventId String?
  providerCheckId String
  url             String        @db.Text
  urlHash         String
  pageStatus      String
  isMeaningful    Boolean?
  diffJson        Json?
  snapshotJson    Json?
  judgmentJson    Json?
  capturedAt      DateTime      @default(now())
  createdAt       DateTime      @default(now())

  signal MarketSignal?

  @@unique([monitorId, providerCheckId, urlHash])
  @@index([orgId, capturedAt])
  @@index([monitorId, capturedAt])
}

model MarketSignal {
  id                     String         @id @default(cuid())
  orgId                  String
  competitorId           String
  snapshotId             String         @unique
  snapshot               MarketSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  signalType             String
  severity               String         @default("low") // low | medium | high
  status                 String         @default("pending") // pending | reviewed | dismissed
  title                  String
  summary                String         @db.Text
  evidenceJson           Json?
  analysisStatus         String         @default("queued") // queued | running | completed | skipped | failed
  analysisAttempts       Int            @default(0)
  analysisNextAttemptAt  DateTime?
  analysisLeaseExpiresAt DateTime?
  analysisLastError      String?        @db.VarChar(2000)
  reviewedById           String?
  reviewedAt             DateTime?
  reviewNote             String?        @db.Text
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  analysisRuns MarketAnalysisRun[]

  @@index([orgId, status, createdAt])
  @@index([competitorId, createdAt])
  @@index([orgId, severity, createdAt])
  @@index([analysisStatus, analysisNextAttemptAt])
  @@index([analysisStatus, analysisLeaseExpiresAt])
}

model MarketAnalysisRun {
  id               String           @id @default(cuid())
  orgId            String
  competitorId     String
  competitor       MarketCompetitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  signalId         String?
  signal           MarketSignal?    @relation(fields: [signalId], references: [id], onDelete: Cascade)
  skillExecutionId String?
  trigger          String           @default("webhook") // webhook | manual
  status           String           @default("running") // running | completed | failed
  inputJson        Json?
  outputMarkdown   String?          @db.Text
  error            String?          @db.VarChar(2000)
  createdById      String
  startedAt        DateTime         @default(now())
  completedAt      DateTime?
  createdAt        DateTime         @default(now())

  @@index([orgId, createdAt])
  @@index([competitorId, createdAt])
  @@index([signalId, createdAt])
}

/// 用户主动提交的深度市场研究。与请求解耦，由 after/cron 在后台执行。
model MarketResearchRun {
  id               String    @id @default(cuid())
  orgId            String
  status           String    @default("queued") // queued | running | completed | failed
  inputJson        Json
  outputMarkdown   String?   @db.Text
  errorCode        String?
  error            String?   @db.VarChar(2000)
  attempts         Int       @default(0)
  nextAttemptAt    DateTime?
  leaseExpiresAt   DateTime?
  primaryModel     String
  fallbackModel    String?
  modelUsed        String?
  fallbackUsed     Boolean   @default(false)
  skillExecutionId String?
  createdById      String
  projectId        String?
  planId           String?   @unique
  pendingActionId  String?
  actionDraftJson  Json?
  planStatus       String    @default("none") // none | awaiting_approval | active | rejected | failed
  startedAt        DateTime?
  completedAt      DateTime?
  durationMs       Int?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([orgId, createdAt])
  @@index([orgId, status, createdAt])
  @@index([orgId, planStatus, createdAt])
  @@index([status, nextAttemptAt])
  @@index([status, leaseExpiresAt])
}

model TradeMessage {
  id         String        @id @default(cuid())
  prospectId String
  prospect   TradeProspect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  direction String // inbound / outbound
  channel   String  @default("email") // email / whatsapp / wechat
  subject   String?
  content   String  @db.Text

  intent     String? // interested / objection / not_interested / ooo / question / request_sample / unclear
  sentiment  String? // positive / neutral / negative
  aiDraft    Boolean   @default(false)
  approvedAt DateTime?

  createdAt DateTime @default(now())

  @@index([prospectId, createdAt])
  @@index([prospectId, direction])
}

model TradeChatSession {
  id        String   @id @default(cuid())
  orgId     String
  userId    String
  title     String   @default("新对话")
  status    String   @default("active") // active / archived
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages TradeChatMessage[]

  @@index([userId, updatedAt])
  @@index([orgId])
}

model TradeChatMessage {
  id         String           @id @default(cuid())
  sessionId  String
  session    TradeChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role       String // user / assistant / system / tool
  content    String           @db.Text
  toolName   String?
  toolInput  Json?
  toolOutput Json?
  createdAt  DateTime         @default(now())

  @@index([sessionId, createdAt])
}

/// 竞品产品溯源 / 买家发现（MVP：JSON 存候选，后续可拆表）
model TradeIntelligenceCase {
  id         String @id @default(cuid())
  orgId      String
  title      String
  status     String @default("new") // new | searching | analyzing | needs_review | buyer_identified | converted_to_prospect | failed | archived
  sourceType String @default("manual") // manual | import | api | image

  productName     String?
  brand           String?
  upc             String?
  gtin            String?
  sku             String?
  mpn             String?
  productUrl      String?
  retailerName    String?
  category        String?
  material        String?
  size            String?
  color           String?
  countryOfOrigin String?
  notes           String? @db.Text

  structuredProduct    Json?
  searchQueries        Json?
  evidence             Json?
  buyerCandidates      Json?
  retailerCandidates   Json?
  importerCandidates   Json?
  supplierCandidates   Json?
  contactCandidates    Json?
  recommendedProspects Json?

  analysisReport  String?   @db.Text
  confidenceScore Float?
  lastRunAt       DateTime?
  lastError       String?   @db.VarChar(2000)

  convertedProspectId String?
  convertedProspect   TradeProspect? @relation("TradeIntelligenceCaseProspect", fields: [convertedProspectId], references: [id])
  convertedAt         DateTime?
  convertedById       String?
  convertedBy         User?          @relation("TradeIntelligenceCaseConvertedBy", fields: [convertedById], references: [id])

  createdById String
  createdBy   User   @relation("TradeIntelligenceCaseCreatedBy", fields: [createdById], references: [id])

  assets TradeIntelligenceAsset[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([orgId, status])
  @@index([orgId, createdAt])
  @@index([orgId, upc])
  @@index([orgId, mpn])
}

/// 竞品溯源 — 吊牌/包装/截图等图片资产（Vision 提取结构化字段）
model TradeIntelligenceAsset {
  id              String                 @id @default(cuid())
  orgId           String
  caseId          String?
  case            TradeIntelligenceCase? @relation(fields: [caseId], references: [id], onDelete: SetNull)
  fileUrl         String
  fileName        String
  fileType        String
  assetType       String // tag_image | carton_label | package_image | screenshot | receipt
  extractedText   Json?
  extractedFields Json?
  confidence      Float?
  warnings        Json?
  createdById     String
  createdBy       User                   @relation("TradeIntelligenceAssetCreatedBy", fields: [createdById], references: [id])
  createdAt       DateTime               @default(now())

  @@index([orgId])
  @@index([caseId])
}

/// 外贸客户服务工单 — 微信 AI 助手受理的需求（美工出图 / 文档总结 / 会议纪要 / 群聊总结等）
/// orgId          = 客户所属组织（受理归属 + 可见性边界，强制隔离）
/// fulfillmentOrgId = 处理方组织（加拿大团队），仅允许通过 assignToFulfillment relay 写入。
/// 这是客户 org 与加拿大 org 之间唯一的受控跨组织桥接点；bid 招标数据在不同表中，物理隔离。
model TradeServiceRequest {
  id               String  @id @default(cuid())
  orgId            String // 客户 org（受理归属，强制隔离）
  fulfillmentOrgId String? // 处理方 org（加拿大团队），仅经 relay 写入

  requestType String  @default("other") // design_image | doc_summary | meeting_minutes | group_summary | other
  title       String
  description String? @db.Text

  structuredSpec Json? // AI 结构化提取的需求字段（产品、规格、交付要求等）

  status   String @default("new") // new | accepted | in_progress | delivered | closed | cancelled
  priority String @default("medium") // low | medium | high | urgent

  // 来源（微信受理）
  sourceChannel  String? // personal_wechat | wecom
  externalUserId String?
  bindingId      String?

  createdById String? // 受理触发者（绑定用户 / 系统机器人），可空
  assigneeId  String? // 处理人（加拿大团队成员 userId），经 relay 指派

  assignedAt  DateTime?
  deliveredAt DateTime?
  closedAt    DateTime?

  assets TradeServiceAsset[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, status])
  @@index([orgId, createdAt])
  @@index([fulfillmentOrgId, status])
  @@index([assigneeId])
}

/// 外贸服务工单资产 — 输入（客户上传的图片 / 聊天记录 / 文档）与交付物（加拿大团队出图 / 总结）
model TradeServiceAsset {
  id        String              @id @default(cuid())
  orgId     String // 必须与 request.orgId 一致（客户 org），强制写入
  requestId String
  request   TradeServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  kind     String // input | deliverable
  fileUrl  String
  fileName String
  mimeType String?
  meta     Json?

  createdById String?
  createdAt   DateTime @default(now())

  @@index([orgId])
  @@index([requestId])
  @@index([requestId, kind])
}

model TradeChannel {
  id            String    @id @default(cuid())
  orgId         String
  channel       String // whatsapp / wechat / wechat_work
  name          String // display name
  status        String    @default("active") // active / inactive / error
  config        Json // encrypted config: apiKey, phoneNumberId, accessToken, etc.
  webhookSecret String?
  lastSyncAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([orgId, channel])
  @@index([orgId])
}

model TradeActivityLog {
  id         String   @id @default(cuid())
  orgId      String
  campaignId String?
  prospectId String?
  action     String // discover / research / score / outreach / send / reply / stage_change / import / pipeline
  detail     String?  @db.Text
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([campaignId, createdAt])
  @@index([prospectId, createdAt])
  @@index([orgId, createdAt])
}

model TradeQuote {
  id         String         @id @default(cuid())
  orgId      String
  prospectId String?
  prospect   TradeProspect? @relation(fields: [prospectId], references: [id])
  campaignId String?

  quoteNumber  String  @unique
  companyName  String
  contactName  String?
  contactEmail String?
  country      String?

  status       String  @default("draft") // draft / sent / negotiating / accepted / rejected / expired
  currency     String  @default("USD")
  incoterm     String  @default("FOB") // FOB / CIF / EXW / DDP / CFR
  paymentTerms String? // T/T 30%, L/C, etc.
  validDays    Int     @default(30)
  leadTimeDays Int?
  moq          String?
  shippingPort String?

  subtotal     Float @default(0)
  discount     Float @default(0)
  shippingCost Float @default(0)
  totalAmount  Float @default(0)

  notes         String? @db.Text
  internalNotes String? @db.Text

  sentAt     DateTime?
  acceptedAt DateTime?
  expiresAt  DateTime?

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items TradeQuoteItem[]

  @@index([orgId, status])
  @@index([prospectId])
}

model TradeQuoteItem {
  id      String     @id @default(cuid())
  quoteId String
  quote   TradeQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  sortOrder     Int     @default(0)
  productName   String
  specification String?
  unit          String  @default("pcs")
  quantity      Float   @default(0)
  unitPrice     Float   @default(0)
  totalPrice    Float   @default(0)
  remarks       String?

  @@index([quoteId, sortOrder])
}

model TradeKnowledge {
  id          String   @id @default(cuid())
  orgId       String
  category    String // product / faq / case_study / certification / process
  title       String
  content     String   @db.Text
  tags        String? // comma-separated
  language    String   @default("zh")
  isActive    Boolean  @default(true)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([orgId, category])
  @@index([orgId, isActive])
}

/// 组织通用知识库（平台真相源）— Markdown/vault 导入后供数字员工向量检索
/// Obsidian 等仅作起草边缘；不双向同步。
model OrgKnowledgeDocument {
  id          String   @id @default(cuid())
  orgId       String
  title       String
  content     String   @db.Text
  category    String   @default("general")
  tags        String?
  language    String   @default("zh")
  sourceType  String   @default("manual") // manual / vault_import
  sourcePath  String?
  status      String   @default("active") // active / archived
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  chunks OrgKnowledgeChunk[]

  @@index([orgId, status, updatedAt])
  @@index([orgId, category])
}

model OrgKnowledgeChunk {
  id         String                       @id @default(cuid())
  orgId      String
  documentId String
  document   OrgKnowledgeDocument         @relation(fields: [documentId], references: [id], onDelete: Cascade)
  chunkIndex Int
  content    String                       @db.Text
  embedding  Unsupported("vector(1536)")?
  createdAt  DateTime                     @default(now())

  @@unique([documentId, chunkIndex])
  @@index([orgId, documentId])
}

model TradeEmailTemplate {
  id          String   @id @default(cuid())
  orgId       String
  name        String
  category    String // first_touch / follow_up / after_quote / after_sample / re_engage / exhibition
  language    String   @default("en") // en / zh / es / fr / de / auto
  subject     String
  body        String   @db.Text
  variables   Json? // ["companyName", "contactName", "productDesc", ...]
  isDefault   Boolean  @default(false)
  usageCount  Int      @default(0)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([orgId, category])
}

// ============================================================
// Sales CRM Models — Sunny Shutter B2C 销售流程
// ============================================================

model SalesCustomer {
  id         String    @id @default(cuid())
  orgId      String
  name       String
  phone      String?
  email      String?
  address    String?
  source     String? // referral / google_ads / walk_in / wechat / other
  wechatNote String?
  status     String    @default("active") // active / completed / dormant
  tags       String? // comma-separated tags
  notes      String?   @db.Text
  jdyDataId  String?   @unique // 简道云 record ID for future sync
  lastSyncAt DateTime?
  // 软删字段：管理员"删除客户"时设置此时间戳；列表默认过滤掉已归档
  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  createdById String
  createdBy   User   @relation("SalesCustomerCreatedBy", fields: [createdById], references: [id])

  opportunities SalesOpportunity[]
  interactions  CustomerInteraction[]
  quotes        SalesQuote[]          @relation("SalesQuoteCustomer")
  blindsOrders  BlindsOrder[]
  appointments  Appointment[]
  measurements  MeasurementRecord[]

  // RAG
  profile         CustomerProfile?
  knowledgeChunks SalesKnowledgeChunk[]
  coachingRecords CoachingRecord[]

  // Visualizer
  visualizerSessions VisualizerSession[]

  @@index([status])
  @@index([phone])
  @@index([email])
  @@index([createdAt])
  @@index([orgId])
}

model SalesOpportunity {
  id                    String        @id @default(cuid())
  orgId                 String
  customerId            String
  customer              SalesCustomer @relation(fields: [customerId], references: [id])
  title                 String
  stage                 String        @default("new_lead") // Pipeline stage
  estimatedValue        Float?
  windowCount           Int?
  productTypes          String? // comma-separated: Zebra,Roller,Drapery,...
  source                String? // lead source
  priority              String        @default("warm") // hot / warm / cold
  lostReason            String?       @db.Text
  wonAt                 DateTime?
  lostAt                DateTime?
  nextFollowupAt        DateTime?
  measureDate           DateTime?
  installDate           DateTime?
  jdyDataId             String?       @unique
  lastSyncAt            DateTime?
  /// 来源外贸线索（可空；用于去重与审计）
  sourceTradeProspectId String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  assignedToId String?
  assignedTo   User?   @relation("SalesOpportunityAssignee", fields: [assignedToId], references: [id])
  createdById  String
  createdBy    User    @relation("SalesOpportunityCreatedBy", fields: [createdById], references: [id])

  interactions CustomerInteraction[]
  quotes       SalesQuote[]
  blindsOrders BlindsOrder[]
  appointments Appointment[]

  // RAG
  knowledgeChunks SalesKnowledgeChunk[]
  coachingRecords CoachingRecord[]

  // Visualizer
  visualizerSessions VisualizerSession[]

  @@index([customerId])
  @@index([stage])
  @@index([assignedToId])
  @@index([nextFollowupAt])
  @@index([stage, updatedAt])
  @@index([sourceTradeProspectId])
  @@index([orgId])
}

model CustomerInteraction {
  id             String            @id @default(cuid())
  orgId          String
  customerId     String
  customer       SalesCustomer     @relation(fields: [customerId], references: [id])
  opportunityId  String?
  opportunity    SalesOpportunity? @relation(fields: [opportunityId], references: [id])
  type           String // phone_call / wechat / email / in_person / note
  direction      String? // inbound / outbound
  summary        String            @db.Text
  content        String?           @db.Text
  emailMessageId String?
  attachments    String?           @db.Text // JSON array of file URLs

  // 多渠道 + 多语言扩展
  channel     String? // wechat / xiaohongshu / facebook / email / phone / in_person / other
  language    String? // zh / en / mixed
  rawMessages String? @db.Text // JSON: [{role:"customer"|"staff", content:string, time?:string}]
  sentiment   String? // positive / neutral / negative
  outcome     String? // converted / lost / pending / info_request / follow_up
  topicTags   String? // comma-separated: "pricing,zebra,installation"

  // RAG 分析状态
  analysisStatus String? // pending / analyzed / failed
  analysisResult Json? // AI 结构化分析输出

  createdAt DateTime @default(now())

  createdById String
  createdBy   User   @relation("CustomerInteractionCreatedBy", fields: [createdById], references: [id])

  knowledgeChunks SalesKnowledgeChunk[]

  @@index([customerId, createdAt])
  @@index([opportunityId])
  @@index([type])
  @@index([channel])
  @@index([analysisStatus])
  @@index([orgId])
}

model SalesQuote {
  id              String            @id @default(cuid())
  orgId           String
  opportunityId   String?
  opportunity     SalesOpportunity? @relation(fields: [opportunityId], references: [id])
  customerId      String
  customer        SalesCustomer     @relation("SalesQuoteCustomer", fields: [customerId], references: [id])
  version         Int               @default(1)
  status          String            @default("draft") // draft / sent / viewed / accepted / signed / rejected / expired
  installMode     String            @default("default") // default / pickup
  merchSubtotal   Float             @default(0)
  addonsSubtotal  Float             @default(0)
  installSubtotal Float             @default(0)
  installApplied  Float             @default(0)
  deliveryFee     Float             @default(50)
  preTaxTotal     Float             @default(0)
  taxRate         Float             @default(0.13)
  taxAmount       Float             @default(0)
  grandTotal      Float             @default(0)
  currency        String            @default("CAD")
  sentAt          DateTime?
  emailMessageId  String?
  orderNumber     String?
  notes           String?           @db.Text
  formDataJson    String?           @db.Text

  // Sprint 21 新增字段
  shareToken   String?   @unique // 报价分享链接 token
  signatureUrl String? // 电子签名图片 URL
  signedAt     DateTime? // 签名时间
  aiSource     String? // voice / text / image / manual
  viewedAt     DateTime? // 客户查看时间

  // 报价 PDF 存档（客户以 PDF 为准查看并签字，解决网页渲染与 PDF 不一致问题）
  pdfPath       String? // 发送时存档的 Order Form PDF（私有 Blob pathname）
  signedPdfPath String? // 客户签字后盖章生成的已签署 PDF（私有 Blob pathname）

  // 折扣率追踪（Step 4）
  totalMsrp        Float? // 所有产品行的 MSRP 之和（Part B/C 不计入分母）
  specialPromotion Float? @default(0) // 销售手填的「Special Promotion」让利金额（税前直减）
  finalDiscountPct Float? // = 1 - (preTaxProducts - specialPromotion) / totalMsrp

  // 定金登记（线上签字 → 销售补录收款情况）
  //   - depositAmount / depositMethod / depositCollectedAt 三者同时写入，空表示未登记
  //   - method 取值：cash | check | etransfer（前端下拉固定）
  //   - 线下签字时销售可以不登记，UI 会在 signed && 无 depositCollectedAt 时提示
  depositAmount        Float?
  depositMethod        String?
  depositCollectedAt   DateTime?
  depositCollectedById String?
  depositNote          String?   @db.Text

  /// Part B 签单时手填的约定定金/余款（含税口径，与 formDataJson 同步；登记定金时优先预填）
  agreedDepositAmount Float?
  agreedBalanceAmount Float?

  /// 由外贸 TradeQuote 人工转换而来；唯一约束防止同一外贸报价重复生成销售报价
  sourceTradeQuoteId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String
  createdBy   User   @relation("SalesQuoteCreatedBy", fields: [createdById], references: [id])

  items  SalesQuoteItem[]
  addons SalesQuoteAddon[]
  rooms  QuoteRoom[]

  // Visualizer
  visualizerSessions VisualizerSession[]

  @@index([customerId])
  @@index([opportunityId])
  @@index([status])
  @@index([createdAt])
  @@index([orgId])
}

/// 企业级报价折扣/促销/定金规则（每 org 一行当前生效配置）
/// 历史版本见 OrgBusinessRule(ruleKey=quote_discounts)
/// 遗留 singleton 行仅作迁移源，运行时禁止跨 org 读取
model QuoteDiscountSettings {
  id                  String       @id @default(cuid())
  orgId               String       @unique
  org                 Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  version             Int          @default(1)
  effectiveAt         DateTime     @default(now())
  zebra               Float        @default(0.45)
  shangrila           Float        @default(0.35)
  cellular            Float        @default(0.35)
  roller              Float        @default(0.45)
  drapery             Float        @default(0.35)
  sheer               Float        @default(0.35)
  shutters            Float        @default(0.35)
  honeycomb           Float        @default(0.35)
  promoWarnPct        Float        @default(0.06)
  promoDangerPct      Float        @default(0.15)
  promoMaxPct         Float        @default(0.25)
  depositWarnPct      Float        @default(0.40)
  depositMinPct       Float        @default(0.30)
  /// bcrypt 哈希；禁止存明文。API 永不返回此字段。
  depositOverrideCode String?
  /// 行折扣解锁码的 bcrypt 哈希（禁止存明文；API 永不返回）
  lineDiscountUnlockCodeHash String?
  updatedAt           DateTime     @updatedAt
  updatedBy           String?
}

/// 企业业务规则版本库（毛利/风险/自动发送/Agent 工具覆盖等）
model OrgBusinessRule {
  id          String       @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  /// quote_margin | quote_auto_send | project_risk | agent_tool_policy | quote_discounts_snapshot
  ruleKey     String
  version     Int          @default(1)
  /// draft | active | superseded
  status      String       @default("active")
  configJson  Json
  effectiveAt DateTime     @default(now())
  createdById String?
  updatedById String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([orgId, ruleKey, version])
  @@index([orgId, ruleKey, status])
}

/// Phase 2B：企业术语表（轻量 Glossary，非知识图谱）
model OrganizationGlossaryTerm {
  id            String       @id @default(cuid())
  orgId         String
  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  workspaceId   String?
  workspace     Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  /// "org" 或 workspaceId，避免 PG 对 NULL unique 的歧义
  scopeKey      String       @default("org")
  canonicalTerm String
  displayName   String
  description   String?      @db.Text
  aliasesJson   Json         @default("[]")
  category      String       @default("general")
  language      String       @default("zh")
  /// active | draft | archived
  status        String       @default("active")
  version       Int          @default(1)
  effectiveFrom DateTime     @default(now())
  effectiveTo   DateTime?
  createdById   String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([orgId, scopeKey, canonicalTerm, language])
  @@index([orgId, status])
  @@index([orgId, workspaceId, status])
}

/// Phase 2B：标准业务对象定义（注册现有 Prisma 对象，不复制业务数据）
model BusinessObjectDefinition {
  id                     String       @id @default(cuid())
  orgId                  String
  org                    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  workspaceId            String?
  workspace              Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  industryPackId         String?
  objectKey              String
  displayName            String
  description            String?      @db.Text
  aliasesJson            Json         @default("[]")
  sourceModel            String?
  idField                String?      @default("id")
  statusField            String?
  allowedStatusesJson     Json?
  relationDefinitionsJson Json?
  riskFieldsJson         Json?
  /// active | draft | disabled
  status                 String       @default("active")
  version                Int          @default(1)
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  @@unique([orgId, objectKey])
  @@index([orgId, status])
  @@index([orgId, workspaceId])
}

/// Phase 2B：企业经营指标定义（仅定义与接口，不做复杂图表）
model BusinessMetricDefinition {
  id                   String       @id @default(cuid())
  orgId                String
  org                  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  workspaceId          String?
  workspace            Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  key                  String
  name                 String
  description          String?      @db.Text
  category             String       @default("operations")
  unit                 String       @default("count")
  /// higher_better | lower_better | neutral
  direction            String       @default("higher_better")
  /// query | static | manual
  sourceType           String       @default("query")
  sourceConfigJson     Json         @default("{}")
  warningThresholdJson Json?
  targetValueJson      Json?
  /// active | draft | disabled
  status               String       @default("active")
  displayOrder         Int          @default(0)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@unique([orgId, key])
  @@index([orgId, status, displayOrder])
}

/// Phase 2B：Workspace Skill 启用/参数（不复制 Skill 本体）
model WorkspaceSkillBinding {
  id            String       @id @default(cuid())
  orgId         String
  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  workspaceId   String
  workspace     Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  skillKey      String
  enabled       Boolean      @default(true)
  paramsJson    Json?
  /// 可选：限制 orgRole 列表
  allowOrgRolesJson Json?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([workspaceId, skillKey])
  @@index([orgId, workspaceId])
}

/// Phase 2B：Workspace 默认知识库绑定
model WorkspaceKnowledgeBinding {
  id              String       @id @default(cuid())
  orgId           String
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  workspaceId     String
  workspace       Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  knowledgeBaseId String
  isDefault       Boolean      @default(false)
  status          String       @default("active")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([workspaceId, knowledgeBaseId])
  @@index([orgId, workspaceId])
}

model SalesQuoteItem {
  id            String     @id @default(cuid())
  quoteId       String
  quote         SalesQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  roomId        String?
  room          QuoteRoom? @relation(fields: [roomId], references: [id])
  sortOrder     Int        @default(0)
  product       String // Zebra / Roller / Drapery / ...
  fabric        String // Light Filtering / Blackout / ...
  sku           String? // fabric SKU
  widthIn       Float // raw width in inches
  heightIn      Float // raw height in inches
  bracketWidth  Float? // bracket-aligned width
  bracketHeight Float? // bracket-aligned height
  cordless      Boolean    @default(false)
  msrp          Float      @default(0)
  discountPct   Float      @default(0)
  discountValue Float      @default(0)
  price         Float      @default(0)
  installFee    Float      @default(0)
  location      String? // room location note

  @@index([quoteId, sortOrder])
  @@index([roomId])
}

model SalesQuoteAddon {
  id          String     @id @default(cuid())
  quoteId     String
  quote       SalesQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  addonKey    String // motor / hub / remote / track6 / track8 / track10 / track12
  displayName String
  unitPrice   Float
  qty         Int        @default(1)
  subtotal    Float      @default(0)

  @@index([quoteId])
}

/// 报价房间维度 — 按房间组织报价项
model QuoteRoom {
  id           String     @id @default(cuid())
  quoteId      String
  quote        SalesQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  roomName     String // Living Room / Master Bedroom / ...
  windowWidth  Float? // 窗户整体宽度（参考）
  windowHeight Float? // 窗户整体高度（参考）
  remarks      String?    @db.Text
  sortOrder    Int        @default(0)

  items       SalesQuoteItem[]
  attachments RoomAttachment[]

  @@index([quoteId, sortOrder])
}

/// 房间级附件（量房照片/视频）
// TODO: 量房附件功能预留，API 尚未接入
model RoomAttachment {
  id        String    @id @default(cuid())
  roomId    String
  room      QuoteRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  fileName  String
  fileUrl   String
  fileType  String    @default("image") // image / video
  createdAt DateTime  @default(now())

  @@index([roomId])
}

// ============================================================
// 预约管理（量房 / 安装 / 回访）
// ============================================================

/// 预约记录 — 量房/安装/回访等上门服务
model Appointment {
  id            String            @id @default(cuid())
  customerId    String
  customer      SalesCustomer     @relation(fields: [customerId], references: [id])
  opportunityId String?
  opportunity   SalesOpportunity? @relation(fields: [opportunityId], references: [id])

  type        String  @default("measure") // measure / install / revisit / consultation
  title       String
  description String? @db.Text

  startAt DateTime
  endAt   DateTime
  allDay  Boolean  @default(false)

  address      String? @db.Text
  contactPhone String?

  status       String  @default("scheduled") // scheduled / confirmed / in_progress / completed / cancelled / no_show
  cancelReason String?

  assignedToId String
  assignedTo   User   @relation("AppointmentAssignee", fields: [assignedToId], references: [id])
  createdById  String
  createdBy    User   @relation("AppointmentCreatedBy", fields: [createdById], references: [id])

  notifiedAt     DateTime? // 微信/站内通知发送时间
  reminderSentAt DateTime? // 提前提醒发送时间
  completedAt    DateTime?
  notes          String?   @db.Text

  googleEventId  String? // 同步到 Google Calendar 后的事件 ID
  googleSyncedAt DateTime? // 最后一次成功同步时间

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assignedToId, startAt])
  @@index([customerId])
  @@index([opportunityId])
  @@index([status, startAt])
  @@index([startAt])
  @@index([type, startAt])
}

// ============================================================
// 现场量房记录
// ============================================================

/// 量房记录 — 一次上门量房产生一条记录，关联客户/机会/预约
model MeasurementRecord {
  id            String        @id @default(cuid())
  customerId    String
  customer      SalesCustomer @relation(fields: [customerId], references: [id])
  opportunityId String?
  appointmentId String?

  status       String   @default("draft") // draft / completed / quoted
  overallNotes String?  @db.Text
  measuredById String
  measuredAt   DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  windows MeasurementWindow[]

  // Visualizer（可选：一次量房可对应多个可视化方案）
  visualizerSessions VisualizerSession[]

  @@index([customerId])
  @@index([opportunityId])
  @@index([measuredById, createdAt])
}

/// 量房窗位 — 每扇窗的尺寸和产品选择
model MeasurementWindow {
  id       String            @id @default(cuid())
  recordId String
  record   MeasurementRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)

  roomName    String // Living Room / Master Bedroom / ...
  windowLabel String? // W1 / W2 / Bay Window Left / ...
  widthIn     Float // 宽度（英寸）
  heightIn    Float // 高度（英寸）
  measureType String  @default("IN") // IN / OUT / Tight
  product     String? // Zebra / Roller / ...
  fabric      String? // Light Filtering / Blackout / ...
  cordless    Boolean @default(false)
  notes       String?

  sortOrder Int                @default(0)
  photos    MeasurementPhoto[]

  @@index([recordId, sortOrder])
}

/// 量房照片 — 关联到具体窗位
model MeasurementPhoto {
  id        String            @id @default(cuid())
  windowId  String
  window    MeasurementWindow @relation(fields: [windowId], references: [id], onDelete: Cascade)
  fileName  String
  fileUrl   String
  createdAt DateTime          @default(now())

  @@index([windowId])
}

// ============================================================
// 销售话术库 + FAQ（从真实对话提炼）
// ============================================================

/// 销售话术模板 — 按渠道 + 场景组织
model SalesPlaybook {
  id     String @id @default(cuid())
  userId String

  channel             String // wechat / xiaohongshu / facebook / email / phone
  language            String // zh / en / mixed
  scene               String // first_contact / follow_up / price_objection / closing / after_sale / ...
  sceneLabel          String // 场景中文名
  content             String                       @db.Text
  example             String?                      @db.Text // 实际使用范例
  effectiveness       Int                          @default(0) // 0-5 有效性评分
  sourceInteractionId String? // 提取来源互动 ID
  embedding           Unsupported("vector(1536)")?

  tags       String? // comma-separated
  status     String  @default("active") // active / archived
  usageCount Int     @default(0)
  sourceType String? // manual / ai_extracted / battle_tested

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, channel])
  @@index([userId, scene])
  @@index([userId, status])
}

/// 销售 FAQ — 客户常见问题 + 最佳回答
model SalesFAQ {
  id     String @id @default(cuid())
  userId String

  question      String @db.Text
  answer        String @db.Text
  language      String // zh / en / mixed
  category      String // product / pricing / installation / warranty / delivery / process / other
  categoryLabel String

  productTags         String? // comma-separated: "zebra,roller"
  frequency           Int                          @default(1) // 被问到的频次
  sourceInteractionId String?
  embedding           Unsupported("vector(1536)")?

  status    String   @default("active") // active / archived
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, category])
  @@index([userId, language])
  @@index([userId, status])
}

// ============================================================
// AI 用户长期记忆（借鉴 MemPalace 分层设计）
// ============================================================

/// 用户级 AI 记忆条目 — 跨对话、跨项目的持久知识
/// 强制 orgId 隔离：同一用户在不同组织的记忆互不召回
model UserMemory {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 所属组织（必填）。禁止跨组织读写记忆。
  orgId  String

  // 记忆分类（借鉴 MemPalace 的 5 类提取）
  memoryType String // decision / preference / milestone / problem / insight / fact
  // 记忆层级：L0=身份偏好(始终加载) L1=核心(高频加载) L2=按需(话题匹配)
  layer      Int    @default(1)

  content        String  @db.Text
  // 结构化标签，用于按需检索
  tags           String? // comma-separated: "sales,pricing,customer:张三"
  // 来源对话 ID，便于溯源
  sourceThreadId String?
  // 关联的客户/项目（可选，便于分域检索）
  customerId     String?
  projectId      String?

  // 重要度 1-5，高的优先加载
  importance     Int       @default(3)
  // 被引用/激活次数，用于衰减排序
  accessCount    Int       @default(0)
  lastAccessedAt DateTime?

  // 向量嵌入 (text-embedding-3-small, 1536维)
  embedding      Json?
  // 被此记忆取代的旧记忆 ID（旧 → 新）
  supersededById String?
  // 本记忆取代的旧记忆 ID（新 → 旧）
  supersedesId   String?
  /// 生效起点；存量回填为 createdAt
  effectiveFrom  DateTime  @default(now())
  /// 失效终点；null 表示仍生效
  effectiveTo    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, userId, layer])
  @@index([orgId, userId, memoryType])
  @@index([orgId, userId, importance])
  @@index([orgId, userId, tags])
  @@index([orgId, userId, customerId])
  @@index([orgId, userId, projectId])
  @@index([orgId, userId, effectiveTo])
  @@index([userId, layer])
  @@index([supersedesId])
  @@index([supersededById])
}

// ============================================================
// 动态技能系统（Sprint 16）
// ============================================================

/// AI 动态技能 — 可在运行时创建、修改、自我优化的能力单元
model AgentSkill {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  name        String // 技能名，如 "外贸开发信优化"
  slug        String // 唯一标识，如 "trade-outreach-optimizer"
  description String @db.Text // 技能用途描述
  domain      String // trade / sales / project / secretary
  tier        String @default("foundation") // foundation / analysis / execution

  // AI 执行配置
  systemPrompt       String @db.Text // 执行此技能时的系统 prompt
  userPromptTemplate String @db.Text // 用户 prompt 模板，支持 {{变量}} 占位
  outputFormat       String @default("text") // text / json / markdown
  temperature        Float  @default(0.3)
  maxTokens          Int    @default(2000)

  // 参数定义（JSON Schema 格式）
  inputSchema  Json? // { type: "object", properties: { ... } }
  outputSchema Json? // 期望输出结构

  // 所需工具（可选，执行时自动挂载这些 Agent Core tools）
  requiredTools String? // comma-separated: "trade.get_prospect,secretary.execute_action"

  // 元信息
  version     Int     @default(1)
  isBuiltin   Boolean @default(false) // 内置技能不可删除
  isActive    Boolean @default(true)
  createdById String?
  createdBy   User?   @relation("AgentSkillCreatedBy", fields: [createdById], references: [id])

  // 自我改进
  lastOptimizedAt   DateTime?
  optimizationCount Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  executions SkillExecution[]
  versions   AgentSkillVersion[]

  @@unique([orgId, slug])
  @@index([orgId, domain])
  @@index([orgId, isActive])
}

/// 技能执行记录 — 每次 AgentSkill 运行的输入/输出/评分
model SkillExecution {
  id      String     @id @default(cuid())
  skillId String
  skill   AgentSkill @relation(fields: [skillId], references: [id], onDelete: Cascade)
  userId  String

  // 执行上下文
  inputJson  String  @db.Text // 传入参数 JSON
  outputJson String? @db.Text // AI 输出 JSON
  toolCalls  Json? // 执行过程中的工具调用记录

  // 结果评估
  success    Boolean @default(true)
  durationMs Int?
  tokenCount Int?

  // 用户反馈（核心改进信号）
  userRating   Int? // 1-5 星
  userFeedback String? @db.Text // 用户文字反馈
  wasEdited    Boolean @default(false) // 用户是否编辑了输出

  // prompt 快照（用于回溯对比）
  promptSnapshot String? @db.Text // 执行时使用的完整 prompt

  createdAt DateTime @default(now())

  @@index([skillId, createdAt])
  @@index([skillId, success])
  @@index([skillId, userRating])
}

// ============================================================
// 跨会话语义搜索 + Context 压缩（Sprint 17）
// ============================================================

/// 统一消息嵌入索引 — 跨所有会话类型的语义搜索
model MessageEmbedding {
  id     String  @id @default(cuid())
  userId String
  orgId  String?

  // 消息来源（多态引用）
  sourceType   String // ai_message / trade_chat / project_conversation / project_discussion
  sourceId     String // 原始消息 ID
  sessionId    String // 所属会话/线程 ID
  sessionTitle String? // 会话标题（冗余存储，加速搜索结果展示）

  role      String // user / assistant
  content   String @db.Text
  embedding Json // 1536 维向量

  createdAt DateTime @default(now())

  @@unique([sourceType, sourceId])
  @@index([userId, sourceType])
  @@index([orgId, sourceType])
  @@index([userId, createdAt])
}

/// 会话摘要 — 长对话压缩后的持久化摘要
model ConversationSummary {
  id     String @id @default(cuid())
  userId String

  // 会话来源
  sourceType   String // ai_thread / trade_chat_session / conversation
  sessionId    String // 原始会话 ID
  sessionTitle String?

  // 摘要内容
  summary       String  @db.Text // AI 生成的结构化摘要
  keyTopics     String? @db.Text // 逗号分隔的关键主题
  keyDecisions  String? @db.Text // 重要决策摘要
  messageCount  Int // 被摘要的消息数
  tokenEstimate Int? // 原始消息的估算 token 数

  // 向量（用于搜索摘要本身）
  embedding Json?

  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sourceType, sessionId])
  @@index([userId, sourceType])
  @@index([userId, updatedAt])
}

// ============================================================
// 微信双通道消息网关（Sprint 19）
// ============================================================

/// 微信绑定 — 微信用户 ID 与青砚用户的映射
model WeChatBinding {
  id     String  @id @default(cuid())
  userId String
  user   User    @relation("UserWeChatBindings", fields: [userId], references: [id], onDelete: Cascade)
  orgId  String?

  channel     String // personal_wechat / wecom
  externalId  String // 微信openid / 企微userid
  displayName String? // 微信昵称
  avatarUrl   String?

  // 连接状态
  status       String    @default("active") // active / disconnected / expired
  lastActiveAt DateTime?

  // 推送偏好
  pushBriefing Boolean @default(true)
  pushFollowup Boolean @default(true)
  pushReport   Boolean @default(true)
  pushSales    Boolean @default(false) // 销售域推送
  silentStart  String? // "22:00"
  silentEnd    String? // "08:00"

  // 业务域权限（逗号分隔，如 "trade,sales"）—— 绑定时根据用户角色自动设置
  pushDomains String @default("trade") // trade / sales / project / all

  // 消息过滤
  filterMode    String  @default("all") // all / keyword / whitelist
  filterKeyword String? // 触发关键词，如"青砚"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([channel, externalId])
  @@index([userId])
  @@index([channel, status])
}

/// 微信网关连接 — 个人微信 Bot / 企业微信应用的连接实例
model WeChatGateway {
  id      String @id @default(cuid())
  orgId   String
  channel String // personal_wechat / wecom

  // 个人微信 iLink 字段
  botNickname   String?
  botToken      String? @db.Text
  botBaseUrl    String?
  getUpdatesBuf String? @db.Text
  loginStatus   String  @default("disconnected") // qr_pending / scanning / connected / disconnected

  // 企业微信字段
  corpId        String?
  agentId       String?
  secret        String? // 加密存储
  callbackToken String?
  encodingKey   String?

  status        String    @default("inactive") // active / inactive / error
  lastHeartbeat DateTime?
  errorMessage  String?

  // 业务模式：assistant=内部员工 AI 助理（默认）；trade_intake=外贸客户需求受理 bot
  mode             String  @default("assistant")
  // trade_intake 模式下，自动桥接到的处理方组织（加拿大团队 org）；仅经 assignToFulfillment relay 使用
  fulfillmentOrgId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, channel])
}

/// 微信会话上下文令牌（iLink context_token）
///
/// iLink 为被动回复：每条出站消息必须回传入站消息携带的 context_token，否则无法路由到正确会话。
/// 持久化到 DB，使「常驻 worker 进程」收消息后，「Vercel 控制台进程」也能用最新 token 回传交付物。
model WeChatContext {
  id             String @id @default(cuid())
  orgId          String
  channel        String // personal_wechat / wecom
  externalUserId String // 外部联系人（客户微信）ID

  contextToken String @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, channel, externalUserId])
  @@index([orgId, channel])
}

/// 微信 Grader 短期上下文记忆（按 用户 + 渠道 维度；TTL 30 分钟）
/// 仅存最近一次 Grader / 目标对象的 id/name，用于解析「这个客户/项目/报价」等指代。
/// 不存正文；过期不使用；严格按 orgId + userId + channel 隔离。
model WeChatGraderContext {
  id             String   @id @default(cuid())
  orgId          String
  userId         String
  channel        String
  externalUserId String?
  contextData    Json
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([orgId, userId, channel])
  @@index([userId])
}

/// 微信消息记录
model WeChatMessage {
  id        String  @id @default(cuid())
  bindingId String // 关联的 WeChatBinding
  userId    String
  orgId     String?

  direction      String // inbound / outbound
  channel        String // personal_wechat / wecom
  externalUserId String // 对方微信ID
  content        String  @db.Text
  messageType    String  @default("text") // text / image / file / voice
  externalMsgId  String? // 微信侧消息ID

  // AI 处理
  agentProcessed Boolean @default(false)
  agentResponse  String? @db.Text

  createdAt DateTime @default(now())

  @@index([bindingId, createdAt])
  @@index([userId, createdAt])
  @@index([channel, createdAt])
  @@index([orgId, channel, externalMsgId])
}

/// Agent 渠道会话（微信/企微等）— 多轮复用，带 org 隔离
/// 不存完整聊天；原文仍在 WeChatMessage。summary 仅为压缩摘要。
model AgentSession {
  id                    String    @id @default(cuid())
  orgId                 String
  userId                String?
  channel               String
  channelUserId         String?
  channelConversationId String?
  currentProjectId      String?
  currentCustomerId     String?
  currentOpportunityId  String?
  currentQuoteId        String?
  lastResponseId        String?
  summary               String?   @db.Text
  status                String    @default("active") // active / archived
  lastActiveAt          DateTime  @default(now())
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  runs AgentRun[]

  @@index([orgId, userId])
  @@index([orgId, channel, channelConversationId])
  @@index([orgId, channel, channelUserId, status])
}

/// 单次 AI 处理任务（含后台队列租约，对标 MarketResearchRun）
model AgentRun {
  id            String    @id @default(cuid())
  orgId         String
  sessionId     String
  session       AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userMessageId String?
  runType       String    @default("conversation")
  status        String    @default("queued")
  model         String?
  intent        String?
  /// Phase 3A：跨执行关联；历史可空，新执行应写入
  traceId       String?
  /// Phase 3A：父 Run（可选）
  parentRunId   String?
  startedAt     DateTime?
  completedAt   DateTime?
  cancelledAt   DateTime?
  latencyMs     Int?
  errorCode     String?
  errorMessage  String?   @db.Text
  metadata      Json?
  /// 主管 AI Supervisor 持久化状态（与 metadata.background 隔离）
  supervisorState Json?
  /// 后台消费：尝试次数
  attempts      Int       @default(0)
  /// 租约过期时间（running 超时可被重新认领）
  leaseExpiresAt DateTime?
  /// 下次可尝试时间（退避重试）
  nextAttemptAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  events AgentRunEvent[]

  @@index([orgId, sessionId])
  @@index([orgId, status])
  @@index([orgId, userMessageId])
  @@index([orgId, traceId])
  @@index([status, nextAttemptAt])
  @@index([status, leaseExpiresAt])
}

/// AgentRun 真实执行进度事件（不伪造「正在思考」）
model AgentRunEvent {
  id            String   @id @default(cuid())
  orgId         String
  runId         String
  run           AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  sequence      Int
  eventType     String
  title         String?
  payload       Json?
  visibleToUser Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@unique([runId, sequence])
  @@index([orgId, runId])
}

/// 客服会话 — 未绑定的外部联系人（客户）发给机器人微信号的会话
///
/// 与 WeChatMessage（内部员工 AI 助理通道）分开建模：
/// 客户没有青砚账号，会话以 orgId + channel + externalUserId 唯一标识。
/// unansweredSince / reminderLevel 驱动「未回复超时提醒」SLA 扫描。
model ServiceConversation {
  id             String  @id @default(cuid())
  orgId          String
  channel        String // personal_wechat / wecom
  externalUserId String
  displayName    String?

  status                String    @default("open") // open（待处理）/ handled（已处理）
  lastCustomerMessageAt DateTime?
  lastReplyAt           DateTime?
  /// 当前未回复起点（客服回复或标记已处理后清空）
  unansweredSince       DateTime?
  /// SLA 提醒等级：0 未提醒 / 1 一级已提醒 / 2 升级已提醒
  reminderLevel         Int       @default(0)

  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  messages  ServiceMessage[]

  @@unique([orgId, channel, externalUserId])
  @@index([orgId, status, unansweredSince])
  @@index([orgId, lastCustomerMessageAt])
}

/// 客服会话消息
model ServiceMessage {
  id             String              @id @default(cuid())
  conversationId String
  conversation   ServiceConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  orgId          String

  direction     String // inbound（客户）/ outbound（客服经青砚回复）
  content       String  @db.Text
  messageType   String  @default("text") // text / image
  externalMsgId String?
  /// outbound：在青砚中发送回复的用户
  sentByUserId  String?

  createdAt DateTime @default(now())

  @@index([conversationId, createdAt])
  @@index([orgId, createdAt])
}

// ============================================================
// 销售智能 RAG — 知识库 + 客户画像 + 训练闭环
// ============================================================

/// 销售知识分块 — 沟通内容经 AI 分析后的语义分块
model SalesKnowledgeChunk {
  id String @id @default(cuid())

  // 来源关联
  sourceType    String // email / wechat / call_transcript / note / bulk_upload
  sourceId      String? // CustomerInteraction.id 或上传批次 ID
  customerId    String?
  customer      SalesCustomer?       @relation(fields: [customerId], references: [id])
  opportunityId String?
  opportunity   SalesOpportunity?    @relation(fields: [opportunityId], references: [id])
  interactionId String?
  interaction   CustomerInteraction? @relation(fields: [interactionId], references: [id])

  // 内容
  content   String                       @db.Text
  embedding Unsupported("vector(1536)")?
  // 元数据
  metadata  Json? // { speaker, direction, timestamp, dealStage, dealOutcome }
  tags      String[] // AI 提取的标签
  language  String                       @default("en")

  // AI 分析结果
  sentiment     String? // positive / negative / neutral
  intent        String? // objection / inquiry / negotiation / closing / smalltalk
  objectionType String? // price / timing / competition / authority / need
  isWinPattern  Boolean @default(false)
  isLossSignal  Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([customerId])
  @@index([opportunityId])
  @@index([interactionId])
  @@index([sourceType])
  @@index([isWinPattern])
  @@index([isLossSignal])
  @@index([intent])
}

/// 销售洞察 — AI 提炼的赢单/丢单模式与最佳实践
model SalesInsight {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("SalesInsightUser", fields: [userId], references: [id])

  // 洞察类型
  insightType String // win_pattern / loss_signal / objection_response / best_practice / stage_tactic
  // 内容
  title       String
  description String                       @db.Text
  embedding   Unsupported("vector(1536)")?

  // 适用条件
  dealStage     String? // 适用的商机阶段
  productType   String? // 适用的产品类型
  customerTags  String[] // 适用客户标签
  objectionType String? // 针对的异议类型

  // 效果追踪
  effectiveness Float @default(0) // 0-1 有效性权重
  usageCount    Int   @default(0)
  successCount  Int   @default(0)

  // 来源
  sourceChunkIds String[]
  status         String   @default("active") // active / deprecated

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  coachingRecords CoachingRecord[]

  @@index([insightType])
  @@index([dealStage])
  @@index([status])
  @@index([effectiveness])
}

/// 客户画像 — AI 自动生成的结构化画像（销售 + Marketing 预留）
model CustomerProfile {
  id         String        @id @default(cuid())
  customerId String        @unique
  customer   SalesCustomer @relation(fields: [customerId], references: [id])

  // 基础画像
  customerType     String? // residential / commercial / designer / contractor / developer
  decisionRole     String? // owner / spouse / property_manager / designer / committee
  budgetRange      String? // economy / mid_range / premium / luxury
  priceSensitivity Float? // 0-1

  // 行为画像
  communicationStyle String? // direct / detail_oriented / relationship_focused / price_driven
  preferredChannel   String? // wechat / email / phone / in_person
  responseSpeed      String? // fast_responder / slow_deliberate / ghost_risk
  decisionSpeed      String? // impulse / moderate / slow_researcher

  // 需求画像
  productPreferences String[] // motorized / blackout / sheer / zebra ...
  roomTypes          String[] // bedroom / living_room / office / bathroom ...
  keyNeeds           String[] // child_safety / energy_efficiency / smart_home ...
  objectionHistory   String[] // price / timing / competition ...

  // 成交预测
  winProbability         Float? // 0-1
  estimatedLifetimeValue Float?
  churnRisk              Float? // 0-1

  // Marketing 预留字段
  acquisitionChannel String? // referral / google_ads / social_media / walk_in / website
  referralSource     String?
  contentEngagement  Json? // { emailOpenRate, clickRate, lastEngagedAt, interestedTopics[] }
  segment            String? // high_value_repeat / new_lead / at_risk
  campaignIds        String[]

  // 元数据
  confidence      Float                        @default(0) // 画像置信度 0-1
  lastAnalyzedAt  DateTime?
  analysisVersion Int                          @default(1)
  embedding       Unsupported("vector(1536)")?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerType])
  @@index([segment])
  @@index([budgetRange])
  @@index([winProbability])
}

/// 教练记录 — 记录每次 AI 建议及后续效果，用于自我训练
model CoachingRecord {
  id            String            @id @default(cuid())
  userId        String
  user          User              @relation("CoachingRecordUser", fields: [userId], references: [id])
  customerId    String
  customer      SalesCustomer     @relation(fields: [customerId], references: [id])
  opportunityId String?
  opportunity   SalesOpportunity? @relation(fields: [opportunityId], references: [id])

  // AI 推荐内容
  insightId      String?
  insight        SalesInsight? @relation(fields: [insightId], references: [id])
  coachingType   String // tactic / objection_response / email_draft / next_action
  recommendation String        @db.Text
  context        Json? // { dealStage, customerTags, triggerEvent }

  // 销售行为
  adopted   Boolean?
  adoptedAt DateTime?

  // 结果归因
  outcome           String? // won / lost / still_open / ignored
  outcomeAt         DateTime?
  daysToOutcome     Int?
  dealValue         Float?
  contributionScore Float? // 0-1

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([customerId])
  @@index([opportunityId])
  @@index([insightId])
  @@index([outcome])
  @@index([coachingType])
}

// ============================================================
// AI Window Covering Visualizer — 窗饰可视化（PR #1：schema + 基础 API + 客户页 tab）
// ============================================================
// 设计约束（摘要）：
// - 所有 session 强制挂 customerId；opportunityId / quoteId / measurementRecordId 可选
// - 权限：sales 只看自己创建/负责/或 customer 属于自己的 session；admin 全见
// - measurementWindowId / measurementPhotoId 用 String 弱耦合（MVP 不加 FK，避免级联改动）
// - shareToken 预留 Phase 6，MVP 不暴露对外访问
// - 对现有销售/报价/量房模型无字段改动，仅新增反向关系
// ============================================================

/// 一次客户/机会下的可视化方案工作区
model VisualizerSession {
  id     String @id @default(cuid())
  title  String @default("可视化方案")
  status String @default("draft") // draft / active / archived

  customerId String
  customer   SalesCustomer @relation(fields: [customerId], references: [id])

  opportunityId String?
  opportunity   SalesOpportunity? @relation(fields: [opportunityId], references: [id])

  quoteId String?
  quote   SalesQuote? @relation(fields: [quoteId], references: [id])

  measurementRecordId String?
  measurementRecord   MeasurementRecord? @relation(fields: [measurementRecordId], references: [id])

  createdById String
  createdBy   User   @relation("VisualizerSessionCreatedBy", fields: [createdById], references: [id])

  // 允许销售负责人与创建人解耦（转交客户场景）
  salesOwnerId String?
  salesOwner   User?   @relation("VisualizerSessionSalesOwner", fields: [salesOwnerId], references: [id])

  // Phase 6 预留：客户分享链接 token
  shareToken     String?   @unique
  shareExpiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sourceImages VisualizerSourceImage[]
  variants     VisualizerVariant[]

  @@index([customerId])
  @@index([opportunityId])
  @@index([quoteId])
  @@index([salesOwnerId])
  @@index([createdById, createdAt])
}

/// 客户/销售上传的现场原始照片
model VisualizerSourceImage {
  id        String            @id @default(cuid())
  sessionId String
  session   VisualizerSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  /// 弱耦合：可回链到 MeasurementPhoto.id，避免重复上传；不做 FK
  measurementPhotoId String?

  fileUrl   String
  fileName  String
  mimeType  String
  width     Int?
  height    Int?
  bytes     Int?
  roomLabel String? // 客厅 / Master Bedroom
  note      String?

  createdAt DateTime @default(now())

  regions VisualizerWindowRegion[]

  @@index([sessionId])
}

/// 一张原图上标记的窗户区域（1 张图可标多个窗）
model VisualizerWindowRegion {
  id            String                @id @default(cuid())
  sourceImageId String
  sourceImage   VisualizerSourceImage @relation(fields: [sourceImageId], references: [id], onDelete: Cascade)

  /// 弱耦合：可与 MeasurementWindow.id 绑定，自动带入尺寸
  measurementWindowId String?

  label      String? // W1 / Living Room Left
  shape      String  @default("polygon") // polygon / rect
  /// polygon: [[x,y], ...]; rect: [[x,y],[x2,y2]]; 坐标系=原图像素
  pointsJson Json
  widthIn    Float?
  heightIn   Float?

  createdAt DateTime @default(now())

  productOptions VisualizerProductOption[]

  @@index([sourceImageId])
}

/// 方案（Option A / Option B / Blackout Version ...）
model VisualizerVariant {
  id        String            @id @default(cuid())
  sessionId String
  session   VisualizerSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  name           String
  notes          String? @db.Text
  /// 导出的 PNG URL（快照/分享/邮件用）
  exportImageUrl String?
  sortOrder      Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  productOptions VisualizerProductOption[]
  selections     VisualizerSelection[]

  @@index([sessionId, sortOrder])
}

/// 方案中某扇窗使用的产品（颜色/透明度/叠加变换）
model VisualizerProductOption {
  id        String            @id @default(cuid())
  variantId String
  variant   VisualizerVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  regionId String
  region   VisualizerWindowRegion @relation(fields: [regionId], references: [id], onDelete: Cascade)

  /// Mock 阶段：指向 src/lib/visualizer/mock-products.ts 里的 id
  /// 升级到真产品表后：指向 Product.id，迁移不改 schema
  productCatalogId String
  productName      String
  productCategory  String // roller / zebra / drapery / ...
  color            String?
  colorHex         String?
  opacity          Float   @default(0.85)
  mountingType     String? // inside / outside

  /// Konva Transform 参数：{ offsetX, offsetY, scaleX, scaleY, rotation }
  transformJson Json?
  notes         String?

  createdAt DateTime @default(now())

  @@index([variantId])
  @@index([regionId])
}

/// 销售推荐 / 客户最终选择
model VisualizerSelection {
  id        String            @id @default(cuid())
  variantId String
  variant   VisualizerVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  selectedBy     String // "customer" / "sales"
  selectedById   String?
  selectedByUser User?   @relation("VisualizerSelectionBy", fields: [selectedById], references: [id])
  note           String?

  createdAt DateTime @default(now())

  @@index([variantId])
}

/// 可视化产品库（替代写死的 mock-products）
/// 兼容性：原 mock_xxx id 通过 seed 持久化进 DB，旧 VisualizerProductOption.productCatalogId 不需要改写。
/// 范围：
/// - orgId = null：青砚平台预置（所有组织可见，不可编辑/删除）
/// - orgId = 某组织：组织私有产品（仅组织成员可见、可编辑/软删）
model VisualizerCatalogProduct {
  id String @id @default(cuid())

  /// null 表示平台预置；非空表示该组织私有
  orgId String?

  name          String
  category      String // roller / solar / blackout_roller / zebra / sheer / drapery / dual / honeycomb / vertical / motorized / custom
  categoryLabel String

  previewImageUrl String?
  textureUrl      String?

  defaultOpacity Float @default(0.85)

  /// [{ name, hex }, ...]
  colorsJson    Json
  /// ["inside","outside"]
  mountingsJson Json

  /// 可选：弱关联到 pricing-data 中的 ProductName，未来 Visualizer→Quote 一键带价
  pricingProductName String?

  notes    String? @db.Text
  archived Boolean @default(false)

  createdById String?
  createdBy   User?   @relation("VisualizerCatalogCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assets VisualizerCatalogAsset[]

  @@index([orgId, archived])
  @@index([category])
}

/// 产品参考资产。按用途分类，供目录展示和 AI 生成共同使用。
model VisualizerCatalogAsset {
  id        String                   @id @default(cuid())
  productId String
  product   VisualizerCatalogProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  /// installed / texture / detail / style_reference / swatch
  role       String
  fileUrl    String
  fileName   String
  mimeType   String
  width      Int?
  height     Int?
  bytes      Int?
  sortOrder  Int     @default(0)
  isPrimary  Boolean @default(false)
  /// real / ai_generated
  sourceType String  @default("real")

  createdById String?
  createdAt   DateTime @default(now())

  @@index([productId, role, sortOrder])
}

// ============================================================
// 运营矩阵 — 矩阵账号登记 + 视频资产管道（Aivora → 文案变体 → 发布）
// ============================================================

/// 矩阵账号登记表
/// 英文社媒（IG/FB/TikTok，Postiz 官方 API 发布）+ 小红书（PostFlow 浏览器自动化发布）
/// 品牌记忆中枢 — 每组织一份品牌语料，供所有内容生产链路统一引用。
/// 严格按 orgId 隔离：无平台级预设、无跨组织回退。
model BrandProfile {
  id    String @id @default(cuid())
  orgId String @unique

  brandName String
  /// 一句话定位 / slogan
  tagline   String?

  /// 品牌定位与故事（谁、为谁、凭什么）
  positioning     String? @db.Text
  /// 核心卖点（一行一条）
  sellingPoints   String? @db.Text
  /// 目标客群画像
  targetAudience  String? @db.Text
  /// 品牌语气与声音（如：家的温暖、专业不生硬）
  toneOfVoice     String? @db.Text
  /// 服务范围（城市/配送/安装覆盖）
  serviceScope    String? @db.Text
  /// 代表案例 / 社会证明（一行一条）
  caseStudies     String? @db.Text
  /// 内容禁忌（禁用表述、不可承诺项，一行一条）
  forbiddenClaims String? @db.Text

  updatedByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

/// 内容日历 — 选题规划层：AI 按品牌记忆出选题 → 人工审 → 关联视频资产扇出
model ContentPlanItem {
  id    String @id @default(cuid())
  orgId String

  /// 计划发布日（按天规划，具体时刻在扇出时定）
  plannedDate DateTime @db.Date

  /// 目标账号组（对应 MatrixAccount.groupName）
  groupName String

  /// 选题标题
  topic            String
  /// 切入角度 / 内容要点
  angle            String? @db.Text
  /// 母版文案草稿（扇出时作为 captionText，AI 再做每账号变体）
  suggestedCaption String? @db.Text
  hashtags         String?

  /// proposed（AI 生成待审）/ approved（已通过待配视频）/ dispatched（已扇出）/ skipped
  status String @default("proposed")
  /// ai / manual / intelligence（来自市场情报确认）
  source String @default("ai")

  /// 扇出时关联的视频资产
  assetId String?

  /// 溯源：市场情报信号（intelligence 来源时有值；应用层按 orgId+sourceSignalId 去重）
  sourceSignalId      String?
  /// 溯源：市场研究报告（预留，M1 可空）
  sourceResearchRunId String?

  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([orgId, plannedDate])
  @@index([orgId, status])
  @@index([orgId, sourceSignalId])
}

model MatrixAccount {
  id    String @id @default(cuid())
  orgId String

  platform    String // instagram / facebook / tiktok / youtube / xiaohongshu
  handle      String // 平台账号名 / 唯一标识
  displayName String?

  /// 账号组：同组共享 persona 模板与内容支柱（如「多伦多华人家居」「EN 智能家居」）
  groupName    String  @default("默认组")
  /// 组内差异化说明（昵称口吻、细分定位等）
  personaNotes String? @db.Text

  /// 账号档位：matrix（矩阵号，全自动+抽检）/ premium（精品号，发布 100% 人工审核）
  tier String @default("matrix")

  /// 发布通道：postiz（官方 API）/ postflow（浏览器自动化，DB 队列由服务器 worker 消费）/ manual
  publishChannel    String  @default("manual")
  /// 通道侧账号标识：Postiz integration id 或 PostFlow --account 名
  externalChannelId String?

  status     String @default("active") // active / limited / banned / paused
  /// 每日发布配额（防超频限流）
  dailyQuota Int    @default(3)

  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  publishJobs PublishJob[]

  @@unique([orgId, platform, handle])
  @@index([orgId, status])
  @@index([orgId, groupName])
}

/// 视频资产 — 只存元数据与外部 URL，视频文件不经过青砚存储（成本与 serverless 限制）
model VideoAsset {
  id    String @id @default(cuid())
  orgId String

  source     String // aivora / manual / visualizer
  externalId String? // Aivora 成片 ID（定时拉取的幂等键）

  title    String
  topic    String? // 内容主题，用于匹配账号组
  language String  @default("en") // en / zh

  videoUrl    String // 外部 CDN / 签名 URL
  coverUrl    String?
  durationSec Int?

  /// pending（待配文案）/ ready（可排期）/ scheduled / published / blocked（规则拦截或抽检不过）
  status      String  @default("pending")
  blockReason String?

  metadataJson Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  publishJobs PublishJob[]

  @@unique([source, externalId])
  @@index([orgId, status, createdAt])
}

/// 发布任务 — 一条视频 × 一个矩阵账号；文案变体随任务，不随资产（矩阵查重要求每号不同文案）
model PublishJob {
  id    String @id @default(cuid())
  orgId String

  assetId   String
  asset     VideoAsset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  accountId String
  account   MatrixAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  /// 本账号的差异化文案（变体引擎产出）
  captionText String  @db.Text
  hashtags    String?

  channel     String // postiz / postflow
  scheduledAt DateTime?

  /// draft / review（抽检或高敏滞留）/ blocked（规则拦截）/ queued（已派发到通道）/
  /// processing（postflow worker 已认领）/ published / failed / canceled
  status         String    @default("draft")
  externalJobId  String? // Postiz post id / PostFlow worker 回执
  errorMessage   String?
  attemptCount   Int       @default(0)
  nextAttemptAt  DateTime?
  leaseToken     String?
  leaseExpiresAt DateTime?

  /// 抽检标记：true 表示进入人工抽检队列
  sampledForReview Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([assetId, accountId])
  @@unique([channel, externalJobId])
  @@index([orgId, status, scheduledAt])
  @@index([accountId, status])
  @@index([channel, status, nextAttemptAt])
  @@index([channel, leaseExpiresAt])
}

/// 自动流统一运行账本。业务数据仍归各自模型所有，此表只记录执行健康度。
model AutomationRun {
  id             String    @id @default(cuid())
  automationKey  String
  orgId          String?
  trigger        String    @default("cron")
  status         String    @default("running") // running | succeeded | partial | skipped | failed
  processedCount Int       @default(0)
  succeededCount Int       @default(0)
  failedCount    Int       @default(0)
  error          String?   @db.VarChar(2000)
  metadataJson   Json?
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  durationMs     Int?
  createdAt      DateTime  @default(now())

  @@index([automationKey, startedAt])
  @@index([orgId, automationKey, startedAt])
  @@index([status, startedAt])
}

// ============================================================
// Growth Center — 营销诊断、执行与效果闭环（Phase 1）
// ============================================================

/// 企业事实中心。与 BrandProfile（品牌语料）分离，作为检测地域/行业/竞品的事实边界。
model MarketingBrandProfile {
  id    String @id @default(cuid())
  orgId String @unique

  legalName   String
  brandName   String
  website     String?
  phone       String?
  addressLine String?
  city        String?
  region      String?
  country     String?
  postalCode  String?
  timezone    String  @default("America/Toronto")
  industry    String

  productsJson          Json  @default("[]")
  serviceAreasJson      Json  @default("[]")
  targetAudiencesJson   Json  @default("[]")
  competitorsJson       Json  @default("[]")
  forbiddenContextsJson Json  @default("[]")
  canonicalNapJson      Json?
  /// 已确认的产品营销上下文（Product Marketing Context）；AI 只能提议更新，不可直接覆盖
  productMarketingContextJson Json?

  validationStatus String    @default("draft") // draft / valid / needs_review
  validationScore  Int       @default(0)
  validationIssues Json      @default("[]")
  validatedAt      DateTime?
  validatedById    String?
  updatedById      String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([orgId, validationStatus])
}

/// 渠道账号适配层。Phase 1 可手工录入，providerConfig 为后续 OAuth/API 预留。
model MarketingChannelAccount {
  id                String    @id @default(cuid())
  orgId             String
  provider          String // manual / gsc / ga4 / gbp / meta / tiktok / google_ads / xiaohongshu
  name              String
  externalAccountId String?
  status            String    @default("manual") // manual / connected / paused / error
  providerConfig    Json?
  lastSyncedAt      DateTime?
  lastError         String?   @db.Text
  createdById       String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([orgId, provider, name])
  @@index([orgId, status])
}

model MarketingAuditRun {
  id                        String    @id @default(cuid())
  orgId                     String
  source                    String    @default("manual")
  status                    String    @default("draft") // draft / completed / invalid
  totalScore                Int?
  confidence                Int       @default(0)
  profileValidationSnapshot Json
  invalidReason             String?   @db.Text
  startedAt                 DateTime  @default(now())
  completedAt               DateTime?
  createdById               String
  createdAt                 DateTime  @default(now())

  scores   MarketingDimensionScore[]
  findings MarketingFinding[]

  @@index([orgId, createdAt])
  @@index([orgId, status])
}

model MarketingDimensionScore {
  id           String            @id @default(cuid())
  orgId        String
  auditRunId   String
  auditRun     MarketingAuditRun @relation(fields: [auditRunId], references: [id], onDelete: Cascade)
  dimension    String // AI_VISIBILITY / SEO / LISTINGS / REVIEWS / SOCIAL / WEBSITE / ADVERTISING
  score        Int
  grade        String
  confidence   Int               @default(100)
  evidenceJson Json?
  createdAt    DateTime          @default(now())

  @@unique([auditRunId, dimension])
  @@index([orgId, dimension])
}

model MarketingFinding {
  id            String             @id @default(cuid())
  orgId         String
  auditRunId    String?
  auditRun      MarketingAuditRun? @relation(fields: [auditRunId], references: [id], onDelete: SetNull)
  dimension     String
  severity      String // critical / high / medium / low
  title         String
  description   String?            @db.Text
  currentValue  String?            @db.Text
  expectedValue String?            @db.Text
  evidenceUrl   String?
  evidenceJson  Json?
  confidence    Int                @default(100)
  status        String             @default("open") // open / tasked / resolved / dismissed / invalid
  taskId        String?
  createdById   String
  resolvedAt    DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([orgId, status, severity])
  @@index([orgId, dimension])
  @@index([taskId])
}

model MarketingPlan {
  id                  String              @id @default(cuid())
  orgId               String
  name                String
  objective           String
  startDate           DateTime            @db.Date
  endDate             DateTime            @db.Date
  status              String              @default("draft") // draft / awaiting_approval / active / completed / canceled
  createdById         String
  approvedById        String?
  approvedAt          DateTime?
  projectId           String?
  sourceResearchRunId String?             @unique
  pendingActionId     String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  items               MarketingPlanItem[]

  @@index([orgId, status, startDate])
}

model MarketingPlanItem {
  id              String        @id @default(cuid())
  orgId           String
  planId          String
  plan            MarketingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  dayOffset       Int
  category        String // repair / content / growth / experiment
  title           String
  description     String?       @db.Text
  priority        String        @default("medium")
  status          String        @default("planned")
  taskId          String?
  findingId       String?
  ownerId         String?
  successMetric   String?
  targetValue     String?
  stopCondition   String?       @db.Text
  evidenceSummary String?       @db.Text
  confidence      Int?
  dueDate         DateTime      @db.Date
  createdAt       DateTime      @default(now())

  @@index([orgId, dueDate])
  @@index([planId, dayOffset])
}

model MarketingCampaign {
  id                String    @id @default(cuid())
  orgId             String
  name              String
  objective         String
  product           String?
  geography         String?
  offer             String?
  primaryConversion String
  status            String    @default("draft") // draft / awaiting_approval / active / paused / completed
  budget            Float?
  currency          String    @default("CAD")
  startsAt          DateTime?
  endsAt            DateTime?
  createdById       String
  approvedById      String?
  approvedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  assets       MarketingContentAsset[]
  publications MarketingPublication[]
  experiments  MarketingExperiment[]
  attributions MarketingLeadAttribution[]

  @@index([orgId, status, createdAt])
}

/// 对现有 ContentPlanItem / VideoAsset 的非破坏性关联层。
model MarketingContentAsset {
  id                String            @id @default(cuid())
  orgId             String
  campaignId        String
  campaign          MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contentPlanItemId String?
  videoAssetId      String?
  assetType         String            @default("video")
  variantKey        String?
  approvalStatus    String            @default("draft")
  metadataJson      Json?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([orgId, campaignId])
  @@index([contentPlanItemId])
  @@index([videoAssetId])
}

/// 对现有 PublishJob 的非破坏性关联层。
model MarketingPublication {
  id             String            @id @default(cuid())
  orgId          String
  campaignId     String
  campaign       MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contentAssetId String?
  publishJobId   String?
  channel        String
  status         String            @default("draft")
  publishedAt    DateTime?
  externalPostId String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([orgId, campaignId, status])
  @@index([publishJobId])
}

model MarketingMetricSnapshot {
  id                String    @id @default(cuid())
  orgId             String
  channelAccountId  String?
  campaignId        String?
  publicationId     String?
  source            String    @default("manual")
  capturedAt        DateTime
  periodStart       DateTime?
  periodEnd         DateTime?
  granularity       String    @default("snapshot") // snapshot / daily / weekly / monthly
  geography         String?
  productCategory   String?
  objective         String?
  impressions       Int       @default(0)
  views             Int       @default(0)
  engagements       Int       @default(0)
  clicks            Int       @default(0)
  leads             Int       @default(0)
  qualifiedLeads    Int       @default(0)
  appointments      Int       @default(0)
  quotes            Int       @default(0)
  wins              Int       @default(0)
  spend             Float     @default(0)
  revenue           Float     @default(0)
  currency          String    @default("CAD")
  baseCurrency      String    @default("CAD")
  ingestionKey      String?
  externalEventId   String?
  dataQualityStatus String    @default("unverified") // unverified / valid / warning / invalid
  rawJson           Json?
  createdById       String
  createdAt         DateTime  @default(now())

  @@unique([orgId, source, ingestionKey])
  @@index([orgId, capturedAt])
  @@index([orgId, campaignId])
  @@index([orgId, periodStart, granularity])
}

/// Activepieces 等外部执行层的统一运行账本。业务事实仍保存在青砚模型中。
model MarketingWorkflowRun {
  id            String    @id @default(cuid())
  orgId         String
  provider      String    @default("activepieces")
  flowKey       String
  externalRunId String?
  requestId     String    @unique
  status        String    @default("queued") // queued / dispatched / running / completed / skipped / failed
  inputJson     Json?
  outputJson    Json?
  error         String?   @db.Text
  triggeredById String?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([provider, externalRunId])
  @@index([orgId, flowKey, createdAt])
  @@index([status, createdAt])
}

/// 交给 Meridian 的不可变数据集版本。Phase 1 将标准周级数据保存在 dataJson。
model MmmDatasetVersion {
  id            String   @id @default(cuid())
  orgId         String
  name          String
  periodStart   DateTime
  periodEnd     DateTime
  granularity   String   @default("weekly")
  targetKpi     String
  currency      String   @default("CAD")
  rowCount      Int      @default(0)
  weekCount     Int      @default(0)
  status        String   @default("draft") // draft / ready / insufficient_data / archived
  checksum      String
  schemaJson    Json
  dataJson      Json
  qualityIssues Json     @default("[]")
  createdById   String
  createdAt     DateTime @default(now())

  modelRuns MmmModelRun[]

  @@unique([orgId, checksum])
  @@index([orgId, createdAt])
}

/// Meridian 模型运行与诊断结果。计算在独立 Worker 中完成，青砚只保存可审计结果。
model MmmModelRun {
  id               String            @id @default(cuid())
  orgId            String
  datasetVersionId String
  datasetVersion   MmmDatasetVersion @relation(fields: [datasetVersionId], references: [id], onDelete: Restrict)
  provider         String            @default("meridian")
  externalRunId    String?
  status           String            @default("queued") // queued / running / completed / failed / canceled
  modelVersion     String?
  configJson       Json?
  diagnosticsJson  Json?
  summaryJson      Json?
  error            String?           @db.Text
  requestedById    String
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  contributions MmmChannelContribution[]
  scenarios     MmmBudgetScenario[]

  @@unique([provider, externalRunId])
  @@index([orgId, createdAt])
  @@index([datasetVersionId, status])
}

model MmmChannelContribution {
  id                String      @id @default(cuid())
  orgId             String
  modelRunId        String
  modelRun          MmmModelRun @relation(fields: [modelRunId], references: [id], onDelete: Cascade)
  channel           String
  spend             Float       @default(0)
  contribution      Float       @default(0)
  contributionShare Float       @default(0)
  roi               Float?
  marginalRoi       Float?
  confidenceLow     Float?
  confidenceHigh    Float?
  createdAt         DateTime    @default(now())

  @@unique([modelRunId, channel])
  @@index([orgId, channel])
}

model MmmBudgetScenario {
  id              String      @id @default(cuid())
  orgId           String
  modelRunId      String
  modelRun        MmmModelRun @relation(fields: [modelRunId], references: [id], onDelete: Cascade)
  name            String
  totalBudget     Float
  currency        String      @default("CAD")
  allocationsJson Json
  expectedKpi     Float?
  confidenceLow   Float?
  confidenceHigh  Float?
  status          String      @default("draft") // draft / pending_approval / approved / rejected
  createdById     String
  createdAt       DateTime    @default(now())

  @@index([orgId, createdAt])
  @@index([modelRunId])
}

model MarketingExperiment {
  id                    String            @id @default(cuid())
  orgId                 String
  campaignId            String
  campaign              MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name                  String
  hypothesis            String            @db.Text
  primaryMetric         String
  secondaryMetricsJson  Json              @default("[]")
  variantsJson          Json
  trafficAllocationJson Json?
  status                String            @default("draft") // draft / running / completed / stopped
  winnerVariantKey      String?
  learningSummary       String?           @db.Text
  stopCondition         String?           @db.Text
  startsAt              DateTime?
  endsAt                DateTime?
  createdById           String
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([orgId, status])
  @@index([campaignId])
}

model MarketingLeadAttribution {
  id                 String            @id @default(cuid())
  orgId              String
  campaignId         String
  campaign           MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  salesOpportunityId String
  publicationId      String?
  attributionModel   String            @default("manual")
  confidence         Int               @default(100)
  attributedRevenue  Float?
  currency           String            @default("CAD")
  notes              String?           @db.Text
  createdById        String
  createdAt          DateTime          @default(now())

  @@unique([orgId, campaignId, salesOpportunityId])
  @@index([orgId, salesOpportunityId])
}

// ============================================================
// 人机协作与企业数字员工学习系统 Phase 1
// 原则：先辅助真人 → 再学习真人 → 最后沉淀企业能力
// 不自动改 Prompt/Skill、不监控私人行为、不跨组织
// ============================================================

/// 员工个人数字助理偏好（orgId+userId 唯一；推断与确认值分开）
model EmployeeAiProfile {
  id     String       @id @default(cuid())
  orgId  String
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId String
  user   User         @relation("EmployeeAiProfileUser", fields: [userId], references: [id], onDelete: Cascade)

  roleScope  String  @default("general") // sales / marketing / tender / analytics / general
  department String?

  preferredLanguage   String?
  responseDetailLevel String? // concise / balanced / detailed
  preferredFormats    Json?
  preferredChannels   Json?
  schedulingPreferences Json?
  communicationStyle  Json?
  approvalPreferences Json?
  personalTemplates   Json?

  /// AI 推断偏好（须经员工确认才写入 confirmed）
  learnedPreferences Json?
  /// 员工人工确认偏好（优先级高于 inferred）
  manuallyConfirmedPreferences Json?

  /// 学习知情同意
  consentConfirmed   Boolean   @default(false)
  consentConfirmedAt DateTime?

  status  String @default("active") // active / paused
  version Int    @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, userId])
  @@index([orgId, department])
  @@index([userId])
}

/// AI 建议与真人决策差异（默认 personal_only，须授权才进 team_candidate）
model HumanFeedbackEvent {
  id     String       @id @default(cuid())
  orgId  String
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId String
  user   User         @relation("HumanFeedbackEventUser", fields: [userId], references: [id], onDelete: Cascade)

  agentRunId        String?
  skillExecutionId  String?
  pendingActionId   String?
  supervisorStepId  String?
  workerType        String?
  skillSlug         String?
  taskType          String

  /// 引用优先：{ type, id }；必要时才存快照
  aiOutputRef      Json
  aiOutputSnapshot Json?
  humanDecision    String // accepted / edited / rejected / deferred / not_applicable
  humanEditedOutput Json?
  diffSummary       Json?
  reasonCode        String?
  reasonText        String?

  /// personal_only | team_candidate | do_not_learn
  feedbackScope    String  @default("personal_only")
  consentConfirmed Boolean @default(true)

  createdAt DateTime @default(now())

  businessOutcomes BusinessOutcome[]

  @@index([orgId, userId, createdAt])
  @@index([orgId, feedbackScope, createdAt])
  @@index([orgId, skillSlug, createdAt])
  @@index([agentRunId])
  @@index([pendingActionId])
  @@index([skillExecutionId])
}

/// 可验证业务结果（禁止仅凭 AI 推测写入）
model BusinessOutcome {
  id     String       @id @default(cuid())
  orgId  String
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId String?
  user   User?        @relation("BusinessOutcomeUser", fields: [userId], references: [id], onDelete: SetNull)

  feedbackEventId  String?
  feedbackEvent    HumanFeedbackEvent? @relation(fields: [feedbackEventId], references: [id], onDelete: SetNull)
  pendingActionId  String?
  skillExecutionId String?

  entityType String
  entityId   String
  actionType String
  actionOccurredAt DateTime

  outcomeType    String
  outcomeValue   Json?
  successSignals Json?
  failureSignals Json?
  revenueImpact  Float?
  confidence     Float  @default(0.5)

  /// business_record | user_confirmed | approval_result | connected_source
  sourceType String
  sourceId   String?

  manuallyVerified Boolean   @default(false)
  verifiedBy       String?
  verifiedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, entityType, entityId])
  @@index([orgId, outcomeType, createdAt])
  @@index([feedbackEventId])
  @@index([pendingActionId])
}

/// 候选工作方法（不得被数字员工自动当作正式规则）
model CandidatePractice {
  id     String       @id @default(cuid())
  orgId  String
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  department String
  roleScope  String
  title      String
  description String @db.Text

  triggerConditions   Json?
  recommendedProcess  Json?
  exceptions          Json?
  evidenceSummary     Json?
  supportingFeedbackIds Json?
  supportingOutcomeIds  Json?

  evidenceCount Int    @default(0)
  confidence    Float  @default(0)
  /// draft | pending_review | approved | rejected | archived
  status        String @default("draft")

  generatedByRunId String?
  reviewedBy       String?
  reviewedAt       DateTime?
  rejectionReason  String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, status, department])
  @@index([orgId, roleScope])
}

/// 已批准部门 Playbook（版本化，禁止覆盖历史）
model RolePlaybook {
  id     String       @id @default(cuid())
  orgId  String
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  department  String
  roleScope   String
  name        String
  description String  @db.Text
  version     Int     @default(1)
  /// draft | active | retired
  status      String  @default("draft")

  rules           Json?
  workflows       Json?
  templates       Json?
  exceptions      Json?
  evidenceSummary Json?
  sourceCandidatePracticeIds Json?

  approvedBy String?
  approvedAt DateTime?
  effectiveFrom DateTime?
  effectiveTo   DateTime?
  supersedesId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, name, version])
  @@index([orgId, status, department])
  @@index([orgId, roleScope, status])
  @@index([supersedesId])
}

/// Skill 版本快照（本轮不自动改正式 Skill 代码；供追溯与评估）
model AgentSkillVersion {
  id      String       @id @default(cuid())
  orgId   String
  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  skillId String
  skill   AgentSkill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  version           Int
  systemPromptHash  String
  inputSchemaHash   String?
  outputSchemaHash  String?
  playbookVersionRefs Json?
  changeReason      String? @db.Text
  /// draft | active | retired
  status            String  @default("active")
  createdBy         String?
  createdAt         DateTime @default(now())

  @@unique([skillId, version])
  @@index([orgId, skillId])
}

/// 评估用例（脱敏 fixture；用于后续 Playbook/Skill 变更评估）
model EvaluationCase {
  id     String       @id @default(cuid())
  orgId  String
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  domain   String
  taskType String
  title    String
  inputFixture        Json
  expectedConstraints Json?
  expectedSignals     Json?
  source   String  @default("manual")
  approved Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, domain, taskType])
  @@index([orgId, approved])
}

// ============================================================
// AI 外贸产品内容总监 Phase 1
// ============================================================

/// 组织级产品主档（动态 attributes，行业字段由 Industry Pack 定义）
model TradeProduct {
  id             String       @id @default(cuid())
  orgId          String
  org            Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  sku            String
  name           String
  nameEn         String?
  brand          String?
  category       String?
  collection     String?
  modelNumber    String?
  industryPack   String       @default("home_textile")
  geometryClass  String       @default("DEFORMABLE_SURFACE")
  attributes     Json         @default("{}")
  status         String       @default("draft") // draft | active | archived
  createdById    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  facts ProductFact[]
  assets ProductAsset[]
  jobs  ProductContentJob[]

  @@unique([orgId, sku])
  @@index([orgId, category])
  @@index([orgId, status])
}

model ProductAsset {
  id                 String       @id @default(cuid())
  orgId              String
  productId          String?
  product            TradeProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)
  jobId              String?
  job                ProductContentJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)
  roleAuto           String       @default("unknown")
  roleConfirmed      String?
  roleConfidence     Float        @default(0)
  sourceType         String       @default("upload")
  blobPathname       String
  mimeType           String?
  fileName           String?
  width              Int?
  height             Int?
  locked             Boolean      @default(false)
  metadata           Json?
  createdById        String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([orgId, productId])
  @@index([orgId, jobId])
}

model ProductFact {
  id               String        @id @default(cuid())
  orgId            String
  productId        String?
  product          TradeProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)
  jobId            String?
  job              ProductContentJob? @relation(fields: [jobId], references: [id], onDelete: Cascade)
  fieldKey         String
  value            Json
  normalizedValue  Json?
  sourceType       String
  sourceId         String?
  sourceLocation   String?
  confidence       Float         @default(0.5)
  status           String        @default("extracted") // extracted | needs_review | confirmed | rejected | conflict
  confirmedById    String?
  confirmedAt      DateTime?
  locked           Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  conflictsAsCurrent ProductFactConflict[] @relation("ConflictCurrent")
  conflictsAsIncoming ProductFactConflict[] @relation("ConflictIncoming")

  @@index([orgId, jobId, fieldKey])
  @@index([orgId, productId, fieldKey])
  @@index([orgId, status])
}

model ProductFactConflict {
  id              String      @id @default(cuid())
  orgId           String
  jobId           String
  job             ProductContentJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  fieldKey        String
  currentFactId   String?
  currentFact     ProductFact? @relation("ConflictCurrent", fields: [currentFactId], references: [id], onDelete: SetNull)
  incomingFactId  String?
  incomingFact    ProductFact? @relation("ConflictIncoming", fields: [incomingFactId], references: [id], onDelete: SetNull)
  currentValue    Json?
  incomingValue   Json?
  status          String      @default("open") // open | resolved | dismissed
  resolution      String?
  resolvedById    String?
  resolvedAt      DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([orgId, jobId, status])
}

model ProductContentJob {
  id               String       @id @default(cuid())
  orgId            String
  org              Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  productId        String?
  product          TradeProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)
  title            String
  status           String       @default("DRAFT")
  executionMode    String       @default("AUTOPILOT") // AUTOPILOT | ALWAYS_ASK
  industryPack     String       @default("home_textile")
  selectedSku      String?
  planJson         Json?
  missingFieldsJson Json?
  costCents        Int          @default(0)
  estimatedCostCents Int        @default(0)
  currency         String       @default("USD")
  documentPurpose  String       @default("INTERNAL_DRAFT") // INTERNAL_DRAFT | CUSTOMER_REVIEW | FORMAL_EXTERNAL
  errorMessage     String?      @db.Text
  createdById      String?
  approvedById     String?
  approvedAt       DateTime?
  deliveredAt      DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  inputs      ProductContentJobInput[]
  steps       ProductContentStep[]
  facts       ProductFact[]
  conflicts   ProductFactConflict[]
  assets      ProductAsset[]
  visualJobs  VisualGenerationJob[]
  copy        ProductCopy?
  documents   GeneratedDocument[]
  approvals   ProductContentApproval[]
  snapshots   ProductContentSnapshot[]
  costEntries ProductContentCostEntry[]

  @@index([orgId, status])
  @@index([orgId, createdAt])
  @@index([orgId, productId])
}

model ProductContentSnapshot {
  id          String            @id @default(cuid())
  orgId       String
  jobId       String
  job         ProductContentJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  version     Int               @default(1)
  purpose     String            @default("INTERNAL_DRAFT") // INTERNAL_DRAFT | CUSTOMER_REVIEW | FORMAL_EXTERNAL
  payloadJson Json
  createdById String?
  createdAt   DateTime          @default(now())

  @@unique([jobId, version])
  @@index([orgId, jobId])
}

model ProductContentCostEntry {
  id             String            @id @default(cuid())
  orgId          String
  jobId          String
  job            ProductContentJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  category       String            // image_edit | fidelity_qa | copy | document | other
  provider       String?
  model          String?
  estimatedCents Int               @default(0)
  actualCents    Int               @default(0)
  currency       String            @default("USD")
  requestId      String?
  latencyMs      Int?
  metaJson       Json?
  createdAt      DateTime          @default(now())

  @@index([orgId, jobId])
}

/// Phase 3A-2：最小统一 AI 使用成本账本（不替代 ProductContentCostEntry）
/// sourceType: AGENT_RUNTIME | PRODUCT_CONTENT | IMAGE_ENGINE | SUPERVISOR | WORKFLOW | MANUAL_IMPORT
/// usageType: TEXT | IMAGE | EMBEDDING | AUDIO | OTHER
/// status: SUCCEEDED | FAILED | PARTIAL | ESTIMATED
model AiUsageLedger {
  id                 String       @id @default(cuid())
  orgId              String
  org                Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  workspaceId        String?
  projectId          String?
  userId             String?

  traceId            String?
  runId              String?
  parentRunId        String?

  sourceType         String
  sourceId           String?
  idempotencyKey     String       @unique

  provider           String
  model              String
  usageType          String

  inputTokens        Int?
  outputTokens       Int?
  cachedInputTokens  Int?
  imageCount         Int?
  audioSeconds       Float?

  durationMs         Int?
  costAmount         Decimal      @db.Decimal(18, 6)
  currency           String       @default("USD")
  pricingVersion     String?

  status             String
  errorCode          String?
  occurredAt         DateTime
  createdAt          DateTime     @default(now())

  metadataJson       Json?

  @@index([orgId, occurredAt])
  @@index([workspaceId, occurredAt])
  @@index([traceId])
  @@index([runId])
  @@index([provider, model])
  @@index([orgId, sourceType, sourceId])
}

/// Phase 3A-4：能力配额策略（Organization / Workspace）
model CapabilityQuotaPolicy {
  id            String       @id @default(cuid())
  orgId         String
  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  workspaceId   String?
  metric        String
  period        String
  warningLimit  Decimal?     @db.Decimal(18, 6)
  softLimit     Decimal?     @db.Decimal(18, 6)
  hardLimit     Decimal?     @db.Decimal(18, 6)
  enabled       Boolean      @default(true)
  version       Int          @default(1)
  effectiveFrom DateTime     @default(now())
  effectiveTo   DateTime?
  createdById   String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([orgId, metric, enabled])
  @@index([orgId, workspaceId, metric])
  @@index([orgId, metric, version])
}

/// Phase 3A-4：配额预留（防并发穿透 hard limit）
model CapabilityQuotaReservation {
  id             String       @id @default(cuid())
  orgId          String
  org            Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  workspaceId    String?
  metric         String
  amount         Decimal      @db.Decimal(18, 6)
  idempotencyKey String       @unique
  /// RESERVED | COMMITTED | RELEASED | EXPIRED
  status         String       @default("RESERVED")
  expiresAt      DateTime
  committedAt    DateTime?
  releasedAt     DateTime?
  runId          String?
  traceId        String?
  createdAt      DateTime     @default(now())

  @@index([orgId, metric, status, expiresAt])
  @@index([orgId, workspaceId, metric, status])
  @@index([runId])
}

model ProductContentJobInput {
  id             String           @id @default(cuid())
  orgId          String
  jobId          String
  job            ProductContentJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  inputType      String           // image | excel | pdf | url | text | voice
  blobPathname   String?
  mimeType       String?
  fileName       String?
  textContent    String?          @db.Text
  url            String?
  purpose        String?          // WebSourcePurpose / image role hint
  parseStatus    String           @default("pending") // pending | parsed | failed
  parseResultJson Json?
  transcriptText String?          @db.Text
  createdById    String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([orgId, jobId])
}

model ProductContentStep {
  id          String           @id @default(cuid())
  orgId       String
  jobId       String
  job         ProductContentJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  stepKey     String
  status      String           @default("pending") // pending | running | waiting_approval | done | failed | skipped
  inputJson   Json?
  outputJson  Json?
  errorMessage String?         @db.Text
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([orgId, jobId, stepKey])
}

model VisualGenerationJob {
  id            String           @id @default(cuid())
  orgId         String
  jobId         String
  job           ProductContentJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  mode          String           // EXACT | STUDIO | CREATIVE
  sceneType     String           // white_bg | lifestyle | marketing_layout
  status        String           @default("pending")
  prompt        String?          @db.Text
  provider      String?
  model         String?
  costCents     Int              @default(0)
  errorMessage  String?          @db.Text
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  outputs VisualOutput[]

  @@index([orgId, jobId])
}

model VisualOutput {
  id              String              @id @default(cuid())
  orgId           String
  visualJobId     String
  visualJob       VisualGenerationJob @relation(fields: [visualJobId], references: [id], onDelete: Cascade)
  blobPathname    String?
  status          String              @default("generated") // generated | approved | rejected | locked
  locked          Boolean             @default(false)
  provider        String?
  model           String?
  qaOverallScore  Float?
  metadata        Json?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  qaResult VisualQaResult?

  @@index([orgId, visualJobId])
  @@index([orgId, status])
}

model VisualQaResult {
  id                 String       @id @default(cuid())
  orgId              String
  visualOutputId     String       @unique
  visualOutput       VisualOutput @relation(fields: [visualOutputId], references: [id], onDelete: Cascade)
  overallScore       Float
  shapeScore         Float
  colorScore         Float
  patternScore       Float?
  textureScore       Float?
  logoScore          Float?
  textScore          Float?
  accessoryScore     Float?
  detectedChangesJson Json
  recommendedStatus  String       // APPROVE | REVIEW | REJECT
  rawJson            Json?
  createdAt          DateTime     @default(now())

  @@index([orgId, recommendedStatus])
}

model ProductCopy {
  id                    String           @id @default(cuid())
  orgId                 String
  jobId                 String           @unique
  job                   ProductContentJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  productNameEn         String?
  titleEn               String?
  sellingPointsJson     Json?
  shortDescriptionEn    String?          @db.Text
  longDescriptionEn     String?          @db.Text
  specificationsJson    Json?
  packagingJson         Json?
  careInstructionsEn    String?          @db.Text
  useCasesJson          Json?
  missingInformationJson Json?
  claimsToVerifyJson    Json?
  locked                Boolean          @default(false)
  status                String           @default("draft") // draft | ready | approved
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@index([orgId, status])
}

model GeneratedDocument {
  id           String           @id @default(cuid())
  orgId        String
  jobId        String
  job          ProductContentJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  docType      String           // word | pdf | excel | zip | web
  blobPathname String?
  fileName     String?
  version      Int              @default(1)
  status       String           @default("draft") // draft | ready | approved
  metadata     Json?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([orgId, jobId, docType])
}

model ProductContentApproval {
  id           String           @id @default(cuid())
  orgId        String
  jobId        String
  job          ProductContentJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  actionKey    String
  policy       String           // AUTO_ALLOW | ASK_BEFORE | MANUAL_ONLY
  status       String           @default("pending") // pending | approved | rejected | auto_allowed
  requestedById String?
  decidedById  String?
  decidedAt    DateTime?
  reason       String?          @db.Text
  payloadJson  Json?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([orgId, jobId, status])
  @@index([orgId, actionKey])
}

model AgentApprovalSettings {
  id                                  String       @id @default(cuid())
  orgId                               String       @unique
  org                                 Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  version                             Int          @default(1)
  effectiveAt                         DateTime     @default(now())
  updatedById                         String?
  defaultExecutionMode                String       @default("AUTOPILOT")
  autoAnalyzeFiles                    Boolean      @default(true)
  autoCreateProductDraft              Boolean      @default(true)
  autoGenerateLowCostVisuals          Boolean      @default(true)
  autoRunFidelityQa                   Boolean      @default(true)
  autoGenerateCopyDraft               Boolean      @default(true)
  autoGenerateFormalDocuments         Boolean      @default(false)
  autoProcessMultipleSkus             Boolean      @default(false)
  askBeforeHighCostModel              Boolean      @default(true)
  askBeforeCreativeMode               Boolean      @default(true)
  askBeforeFormalPdf                  Boolean      @default(true)
  askBeforeOverwriteApprovedContent   Boolean      @default(true)
  askBeforeExternalSend               Boolean      @default(true)
  askBeforePublish                    Boolean      @default(true)
  maxAutoCostPerJobCents              Int?
  maxAutoCostPerDayCents              Int?
  createdAt                           DateTime     @default(now())
  updatedAt                           DateTime     @updatedAt
}
