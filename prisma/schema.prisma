generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

/// pgvector 扩展 — 用于向量相似度搜索

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

/// Security-1：企业访问模式
/// FIXED = 普通员工锁定企业；MULTI_ORG = 可在设置中切换；PLATFORM_SUPPORT = 平台支持（本阶段仅占位）
enum OrgAccessMode {
  FIXED
  MULTI_ORG
  PLATFORM_SUPPORT
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  phone        String?
  passwordHash String?
  authProvider String    @default("email")
  name         String
  nickname     String?
  avatar       String?
  role         String    @default("user")
  status       String    @default("active")
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // 销售个人配置 — 在驾驶舱"销售个人设置"里一次性填写
  salesRepInitials String? // 如 "LJ"，用于自动生成报价单编号

  // admin 可在用户管理页对每个销售单独开关"是否允许修改客户信息"
  // 仅对 sales/trade/user 生效；admin/super_admin 永远可改
  canEditCustomers Boolean @default(true)

  /// 用户当前锁定的工作企业（Security-1：不再由侧栏随意切换）
  activeOrgId String?
  activeOrg   Organization? @relation("UserActiveOrg", fields: [activeOrgId], references: [id], onDelete: SetNull)

  /// 企业访问模式（默认 FIXED：普通员工不可自助切换）
  orgAccessMode    OrgAccessMode @default(FIXED)
  /// 是否允许在个人设置中自助切换工作企业（需同时 MULTI_ORG）
  canSelfSwitchOrg Boolean       @default(false)

  projects                 Project[]                  @relation("ProjectOwner")
  purchasedProjects        Project[]                  @relation("ProjectPurchaser")
  tasks                    Task[]                      @relation("TaskAssignee")
  createdTasks             Task[]                      @relation("TaskCreator")
  comments                 TaskComment[]
  activities               TaskActivity[]
  calendarEvents           CalendarEvent[]
  calendarProviders        CalendarProvider[]
  blindsOrders             BlindsOrder[]
  reminders                Reminder[]
  notifications            Notification[]              @relation("UserNotifications")
  notificationPreference   UserNotificationPreference?
  projectNotificationRules ProjectNotificationRule[]
  ownedOrgs                Organization[]
  orgMemberships           OrganizationMember[]
  workspaceMemberships     WorkspaceMember[]
  projectMemberships       ProjectMember[]
  auditLogs                AuditLog[]
  promptsCreated           Prompt[]                    @relation("PromptCreatedBy")
  promptsUpdated           Prompt[]                    @relation("PromptUpdatedBy")
  promptVersions           PromptVersion[]             @relation("PromptVersionCreatedBy")
  promptPublishLogs        PromptPublishLog[]          @relation("PromptPublishBy")

  knowledgeBasesCreated            KnowledgeBase[]            @relation("KnowledgeBaseCreatedBy")
  knowledgeBasesUpdated            KnowledgeBase[]            @relation("KnowledgeBaseUpdatedBy")
  knowledgeBaseVersionsCreated     KnowledgeBaseVersion[]     @relation("KBVersionCreatedBy")
  knowledgeDocumentsCreated        KnowledgeDocument[]        @relation("KnowledgeDocumentCreatedBy")
  knowledgeDocumentsUpdated        KnowledgeDocument[]        @relation("KnowledgeDocumentUpdatedBy")
  projectMessages                  ProjectMessage[]           @relation("ProjectMessageSender")
  knowledgeDocumentVersionsCreated KnowledgeDocumentVersion[] @relation("KDVersionCreatedBy")
  knowledgePublishLogs             KnowledgePublishLog[]      @relation("KBPublishedBy")

  conversations Conversation[] @relation("ConversationUser")
  aiThreads     AiThread[]

  agentsCreated        Agent[]              @relation("AgentCreatedBy")
  agentsUpdated        Agent[]              @relation("AgentUpdatedBy")
  agentVersionsCreated AgentVersion[]       @relation("AgentVersionCreatedBy")
  toolsCreated         ToolRegistry[]       @relation("ToolCreatedBy")
  toolsUpdated         ToolRegistry[]       @relation("ToolUpdatedBy")
  agentTasksCreated    AgentTask[]          @relation("AgentTaskCreatedBy")
  customFlowTemplates  CustomFlowTemplate[] @relation("CustomFlowTemplateCreatedBy")

  // AI Memory
  memories UserMemory[]

  // Dynamic Skills
  agentSkillsCreated AgentSkill[] @relation("AgentSkillCreatedBy")

  // WeChat Bindings
  wechatBindings WeChatBinding[] @relation("UserWeChatBindings")

  // Sales CRM relations
  salesCustomersCreated       SalesCustomer[]       @relation("SalesCustomerCreatedBy")
  salesOpportunitiesAssigned  SalesOpportunity[]    @relation("SalesOpportunityAssignee")
  salesOpportunitiesCreated   SalesOpportunity[]    @relation("SalesOpportunityCreatedBy")
  customerInteractionsCreated CustomerInteraction[] @relation("CustomerInteractionCreatedBy")
  salesQuotesCreated          SalesQuote[]          @relation("SalesQuoteCreatedBy")

  // Appointments
  appointmentsAssigned Appointment[] @relation("AppointmentAssignee")
  appointmentsCreated  Appointment[] @relation("AppointmentCreatedBy")

  // Email Binding
  emailBinding EmailBinding?

  // Sales RAG
  salesInsights   SalesInsight[]   @relation("SalesInsightUser")
  coachingRecords CoachingRecord[] @relation("CoachingRecordUser")

  // PR4 — AI 待审批动作
  pendingActionsCreated  PendingAction[] @relation("PendingActionCreatedBy")
  pendingActionsAssigned PendingAction[] @relation("PendingActionApprover")
  pendingActionsDecided  PendingAction[] @relation("PendingActionDecidedBy")

  /// 外贸线索转入销售 CRM 的操作人
  tradeProspectsConverted         TradeProspect[]          @relation("TradeProspectConvertedBy")
  tradeProspectsOwned             TradeProspect[]          @relation("TradeProspectOwner")
  tradeIntelligenceCasesCreated   TradeIntelligenceCase[]  @relation("TradeIntelligenceCaseCreatedBy")
  tradeIntelligenceCasesConverted TradeIntelligenceCase[]  @relation("TradeIntelligenceCaseConvertedBy")
  tradeIntelligenceAssetsCreated  TradeIntelligenceAsset[] @relation("TradeIntelligenceAssetCreatedBy")

  // Visualizer 窗饰可视化
  visualizerSessionsCreated VisualizerSession[]        @relation("VisualizerSessionCreatedBy")
  visualizerSessionsOwned   VisualizerSession[]        @relation("VisualizerSessionSalesOwner")
  visualizerSelectionsMade  VisualizerSelection[]      @relation("VisualizerSelectionBy")
  visualizerCatalogCreated  VisualizerCatalogProduct[] @relation("VisualizerCatalogCreatedBy")

  // 微信开放平台 OpenID（网站应用扫码登录）
  wechatOpenId String? @unique

  // 邀请码溯源
  inviteCodeId String?

  /// 公司归属（JSON 数组的 Company.id）；第一个为主公司，用于左上角联合品牌
  companyIdsJson String?

  // 人机协作学习 Phase 1
  employeeAiProfiles  EmployeeAiProfile[] @relation("EmployeeAiProfileUser")
  humanFeedbackEvents HumanFeedbackEvent[] @relation("HumanFeedbackEventUser")
  businessOutcomes    BusinessOutcome[]    @relation("BusinessOutcomeUser")

  @@index([status])
  @@index([authProvider])
  @@index([role])
  @@index([activeOrgId])
}

// ============================================================
// 销售邮箱绑定 — SMTP 发信配置（一次绑定，自动发信）
// ============================================================

model EmailBinding {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  email       String // 发信邮箱地址 (e.g. sales@sunny.com)
  displayName String // 发件人显示名 (e.g. "Kevin @ Sunny Blinds")
  provider    String  @default("smtp") // smtp / gmail / outlook
  smtpHost    String? // smtp.gmail.com / smtp.office365.com
  smtpPort    Int?    @default(587)
  smtpUser    String? // 通常是邮箱地址
  smtpPass    String? // App Password（加密存储）
  useTls      Boolean @default(true)

  verified   Boolean   @default(false)
  verifiedAt DateTime?
  lastSentAt DateTime?
  lastError  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

// ============================================================
// 公司（联合品牌）— 同一公司旗下用户左上角显示「青砚 × 公司logo」
// ============================================================

model Company {
  id        String   @id @default(cuid())
  name      String // 显示名，如 "Sunny"
  slug      String   @unique // 如 "sunny"
  logoUrl   String // 公司 logo，如 "/brands/sunny.png"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// 邀请码（注册准入 + 角色绑定 + 公司归属）
// ============================================================

model InviteCode {
  id          String    @id @default(cuid())
  code        String    @unique
  role        String
  label       String?
  maxUses     Int?
  usedCount   Int       @default(0)
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  createdById String
  createdAt   DateTime  @default(now())

  /// 公司归属（JSON 数组的 Company.id，可多选）；注册时复制到 User.companyIdsJson
  companyIdsJson String?

  @@index([code])
  @@index([role])
}

model Project {
  id          String        @id @default(cuid())
  orgId       String?
  org         Organization? @relation(fields: [orgId], references: [id])
  /// 可选归属工作空间（部门级）；空=仅挂在企业下
  workspaceId String?
  workspace   Workspace?    @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  name        String
  code        String?       @unique
  description String?
  color       String        @default("#3B82F6")
  status      String        @default("active")
  startDate   DateTime?
  dueDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // BidToGo / 外部集成字段
  category           String?
  priority           String  @default("medium")
  tenderStatus       String?
  sourceSystem       String?
  sourcePlatform     String?
  clientOrganization String?
  location           String?
  estimatedValue     Float?
  currency           String?
  /// 我方提交/拟报价格（复盘与相似对比用，可空）
  ourBidPrice        Float?
  /// 中标价 / 成交价（复盘用，可空）
  winningBidPrice    Float?
  /// 项目类型标签 JSON 数组，如 ["china_sourcing","install"]
  projectTypes       Json?
  /// AI 建议态：advance | conditional | wait_info | abandon（不覆盖 tenderStatus）
  aiAdviceStatus     String?
  solicitationNumber String?
  workflowTemplate   String?
  sourceMetadataJson String?

  // 招投标流程日期
  publicDate         DateTime?
  questionCloseDate  DateTime?
  closeDate          DateTime?
  /// 开标日（可人工调整；有值则同步日历并通知全员）
  openDate           DateTime?
  distributedAt      DateTime?
  interpretedAt      DateTime?
  supplierInquiredAt DateTime?
  supplierQuotedAt   DateTime?
  submittedAt        DateTime?
  awardDate          DateTime?

  // 项目放弃
  abandonedAt     DateTime?
  abandonedStage  String?
  abandonedById   String?
  abandonedReason String?

  // 项目分发 (Bid to Go intake)
  intakeStatus   String    @default("dispatched")
  dispatchedAt   DateTime?
  dispatchedById String?

  ownerId              String
  owner                User                      @relation("ProjectOwner", fields: [ownerId], references: [id])
  /// 主采购人：与主负责人一样需跟进各关键节点
  purchaserId          String?
  purchaser            User?                     @relation("ProjectPurchaser", fields: [purchaserId], references: [id])
  tasks                Task[]
  blindsOrders         BlindsOrder[]
  members              ProjectMember[]
  environments         Environment[]
  auditLogs            AuditLog[]
  prompts              Prompt[]
  promptPublishLogs    PromptPublishLog[]
  knowledgeBases       KnowledgeBase[]
  knowledgePublishLogs KnowledgePublishLog[]
  conversations        Conversation[]
  agents               Agent[]
  tools                ToolRegistry[]
  notificationRules    ProjectNotificationRule[]
  calendarEvents       CalendarEvent[]

  externalRef       ExternalReference?
  intelligence      ProjectIntelligence?
  progressSummaries ProjectProgressSummary[]
  documents         ProjectDocument[]
  discussion        ProjectConversation?
  aiThreads         AiThread[]
  inquiries         ProjectInquiry[]
  quotes            ProjectQuote[]
  agentTasks        AgentTask[]
  insights          ProjectInsight[]
  similaritiesAsSource ProjectSimilarity[] @relation("SimilaritySource")
  similaritiesAsTarget ProjectSimilarity[] @relation("SimilarityTarget")
  reviews           ProjectReview[]
  generatedDocs     ProjectGeneratedDocument[]

  @@index([orgId])
  @@index([workspaceId])
  @@index([purchaserId])
  @@index([sourceSystem])
  @@index([tenderStatus])
  @@index([intakeStatus])
  @@index([status, createdAt])
}

model Task {
  id           String    @id @default(cuid())
  title        String
  description  String?
  status       String    @default("todo")
  priority     String    @default("medium")
  dueDate      DateTime?
  needReminder Boolean   @default(false)
  followupAt   DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])

  assigneeId String?
  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])

  creatorId String
  creator   User   @relation("TaskCreator", fields: [creatorId], references: [id])

  tags           TagOnTask[]
  comments       TaskComment[]
  activities     TaskActivity[]
  calendarEvents CalendarEvent[]
  reminders      Reminder[]

  @@index([projectId, status])
  @@index([projectId, createdAt])
  @@index([creatorId])
  @@index([assigneeId])
  @@index([dueDate])
  @@index([status, createdAt])
}

model TaskComment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id])
}

model TaskActivity {
  id        String   @id @default(cuid())
  action    String
  detail    String?
  createdAt DateTime @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  actorId String
  actor   User   @relation(fields: [actorId], references: [id])
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#6B7280")
  createdAt DateTime @default(now())

  tasks TagOnTask[]
}

model TagOnTask {
  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tagId  String
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
}

model CalendarEvent {
  id              String   @id @default(cuid())
  title           String
  description     String?
  startTime       DateTime
  endTime         DateTime
  allDay          Boolean  @default(false)
  location        String?
  reminderMinutes Int      @default(15)
  source          String   @default("qingyan")
  externalId      String?
  /// 系统里程碑去重键，如 project:{id}:close（与 userId 联合唯一）
  sourceKey       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  taskId String?
  task   Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  reminders Reminder[]

  @@unique([userId, sourceKey])
  @@index([projectId])
}

model BlindsOrder {
  id          String @id @default(cuid())
  code        String @unique
  status      String @default("draft")
  // draft → confirmed → in_production → ready → scheduled → installed → completed → cancelled
  ruleVersion String @default("blinds_20251024_v1")

  customerName String
  phone        String?
  address      String?
  installDate  String?
  remarks      String?

  confirmedAt       DateTime?
  productionStartAt DateTime?
  readyAt           DateTime?
  scheduledAt       DateTime?
  installedAt       DateTime?
  completedAt       DateTime?
  cancelledAt       DateTime?
  cancelReason      String?

  expectedInstallDate DateTime?
  appointmentId       String?

  priority String @default("normal") // urgent / normal / low

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creatorId String
  creator   User     @relation(fields: [creatorId], references: [id])
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])

  customerId    String?
  customer      SalesCustomer?    @relation(fields: [customerId], references: [id])
  opportunityId String?
  opportunity   SalesOpportunity? @relation(fields: [opportunityId], references: [id])

  items      BlindsOrderItem[]
  statusLogs OrderStatusLog[]

  @@index([customerId])
  @@index([opportunityId])
  @@index([status])
  @@index([expectedInstallDate])
}

/// 工单状态变更日志
model OrderStatusLog {
  id         String      @id @default(cuid())
  orderId    String
  order      BlindsOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus String
  toStatus   String
  note       String?
  operatorId String
  createdAt  DateTime    @default(now())

  @@index([orderId, createdAt])
}

model BlindsOrderItem {
  id         String @id @default(cuid())
  itemNumber Int

  location       String
  width          Float
  height         Float
  fabricSku      String
  productType    String
  measureType    String
  controlType    String
  controlSide    String
  headrailType   String
  mountType      String
  fabricRatio    Float?
  silkRatio      Float?
  bottomBarWidth Float?
  itemRemark     String?

  cutHeadrail     Float?
  cutTube38       Float?
  cutRollerBar    Float?
  cutZebraBar     Float?
  cutCoreRod      Float?
  cutShangrilaBar Float?
  cutFabricWidth  Float?
  cutFabricLength Float?
  insertSize      Float?
  cordLength      Float?
  cordSleeveLen   Float?
  squareFeet      Float?

  sortOrder Int @default(0)

  orderId String
  order   BlindsOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ============================================================
// 面料库存管理
// ============================================================

model FabricInventory {
  id          String  @id @default(cuid())
  sku         String  @unique
  productType String // Zebra / Roller / Drapery / ...
  fabricName  String // Light Filtering / Blackout / ...
  color       String?
  supplier    String?

  totalYards    Float @default(0) // 总库存（码数）
  reservedYards Float @default(0) // 已预留（在产工单占用）
  minYards      Float @default(10) // 安全库存线
  unitCost      Float @default(0) // 单位成本（$/yard）

  status        String    @default("in_stock") // in_stock / low / out_of_stock
  lastRestockAt DateTime?
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productType])
  @@index([status])
  @@index([sku])
}

/// 库存变动日志
model FabricStockLog {
  id         String   @id @default(cuid())
  fabricId   String
  type       String // restock / reserve / consume / release / adjust
  yards      Float // 变动数量（正=入库，负=出库）
  reason     String? // 工单号 / 手动调整说明
  operatorId String
  createdAt  DateTime @default(now())

  @@index([fabricId, createdAt])
  @@index([type])
}

model Reminder {
  id        String @id @default(cuid())
  type      String
  status    String @default("pending")
  sourceKey String @unique

  title     String
  message   String?
  triggerAt DateTime
  readAt    DateTime?

  taskId  String?
  task    Task?          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  eventId String?
  event   CalendarEvent? @relation(fields: [eventId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model CalendarProvider {
  id           String    @id @default(cuid())
  type         String
  name         String
  enabled      Boolean   @default(true)
  accessToken  String?
  refreshToken String?
  tokenExpiry  DateTime?
  accountEmail String?
  calendarId   String? // 逗号分隔的已选日历 ID 列表（primary,xxx@group.calendar.google.com,...）
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])
}

// ============================================================
// 多租户基础模型
// ============================================================

model Organization {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  status    String   @default("active")
  planType  String   @default("free")
  /// 启用模块：{ "enabled": ["sales","trade",...] }
  modulesJson Json?
  /// 企业级设置预留（审批默认、Agent 默认等）
  settingsJson Json?
  /// Industry Pack id（Registry）：如 window_covering_services_v1；空=未配置（禁止静默家纺回退）
  industryPackId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members           OrganizationMember[]
  projects          Project[]
  workspaces        Workspace[]
  businessRules     OrgBusinessRule[]
  auditLogs         AuditLog[]
  suppliers         Supplier[]
  agentSkills       AgentSkill[]
  marketCompetitors MarketCompetitor[]
  projectRules      OrganizationProjectRule[]
  activeUsers       User[]                   @relation("UserActiveOrg")
  roleProfiles      RoleProfile[]
  positionTemplates PositionTemplate[]

  // 人机协作学习 Phase 1
  employeeAiProfiles    EmployeeAiProfile[]
  humanFeedbackEvents   HumanFeedbackEvent[]
  businessOutcomes      BusinessOutcome[]
  candidatePractices    CandidatePractice[]
  rolePlaybooks         RolePlaybook[]
  agentSkillVersions    AgentSkillVersion[]
  evaluationCases       EvaluationCase[]

  // AI 外贸产品内容总监 Phase 1
  tradeProducts              TradeProduct[]
  productContentJobs         ProductContentJob[]
  agentApprovalSettings      AgentApprovalSettings?
  quoteDiscountSettings      QuoteDiscountSettings?

  // Phase 2B：企业语义与业务配置
  glossaryTerms              OrganizationGlossaryTerm[]
  businessObjectDefinitions  BusinessObjectDefinition[]
  businessMetricDefinitions  BusinessMetricDefinition[]
  workspaceSkillBindings     WorkspaceSkillBinding[]
  workspaceKnowledgeBindings WorkspaceKnowledgeBinding[]

  // Phase 3A-2：统一 AI 使用成本账本
  aiUsageLedgers             AiUsageLedger[]
  // Phase 3A-4：企业配额
  capabilityQuotaPolicies    CapabilityQuotaPolicy[]
  capabilityQuotaReservations CapabilityQuotaReservation[]
}

/// 企业内部工作空间 / 部门（第一阶段骨架）
model Workspace {
  id           String       @id @default(cuid())
  orgId        String
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name         String
  slug         String
  type         String       @default("department") // department | team | custom
  status       String       @default("active") // active | archived
  description  String?
  settingsJson Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  members  WorkspaceMember[]
  projects Project[]
  glossaryTerms              OrganizationGlossaryTerm[]
  businessObjectDefinitions  BusinessObjectDefinition[]
  businessMetricDefinitions  BusinessMetricDefinition[]
  skillBindings              WorkspaceSkillBinding[]
  knowledgeBindings          WorkspaceKnowledgeBinding[]

  @@unique([orgId, slug])
  @@index([orgId, status])
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// workspace_admin | manager | editor | member | viewer
  role        String    @default("member")
  status      String    @default("active")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

/// 企业项目规则（Phase2）：仅用户确认后生效，不自动变成正式规则
model OrganizationProjectRule {
  id              String       @id @default(cuid())
  orgId           String
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  title           String
  content         String       @db.Text
  category        String       @default("general") // price | tech | qualification | execution | competition | general
  status          String       @default("proposed") // proposed | active | rejected | archived
  sourceProjectId String?
  sourceReviewId  String?
  sourceInsightId String?
  evidenceJson    String?      @db.Text
  confirmedById   String?
  confirmedAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([orgId, status])
  @@index([orgId, category])
  @@index([sourceProjectId])
}

model OrganizationMember {
  id        String       @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String       @default("org_member")
  status    String       @default("active")
  joinedAt  DateTime     @default(now())
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([orgId, userId])
  @@index([orgId])
  @@index([userId])
}

// ============================================================
// Security-1：统一授权底座（Role Profile / Permission Binding / Principal）
// ============================================================

model RoleProfile {
  id            String   @id @default(cuid())
  orgId         String
  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  key           String
  name          String
  description   String?
  principalType String   @default("HUMAN")
  isSystem      Boolean  @default(false)
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  permissions RolePermissionBinding[]
  assignments PrincipalRoleBinding[]
  positionTemplates PositionTemplate[]

  @@unique([orgId, key])
  @@index([orgId, status])
}

model RolePermissionBinding {
  id            String @id @default(cuid())
  orgId         String
  roleProfileId String
  permissionKey String
  dataScope     String
  effect        String @default("ALLOW")
  conditionsJson Json?

  roleProfile RoleProfile @relation(fields: [roleProfileId], references: [id], onDelete: Cascade)

  @@unique([roleProfileId, permissionKey, dataScope])
  @@index([orgId, permissionKey])
}

model PrincipalRoleBinding {
  id            String    @id @default(cuid())
  orgId         String
  principalType String
  principalId   String
  roleProfileId String
  startsAt      DateTime  @default(now())
  expiresAt     DateTime?
  status        String    @default("active")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  roleProfile RoleProfile @relation(fields: [roleProfileId], references: [id], onDelete: Cascade)

  @@index([orgId, principalType, principalId, status])
  @@index([roleProfileId])
}

model PositionTemplate {
  id                   String   @id @default(cuid())
  orgId                String
  org                  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  key                  String
  name                 String
  description          String?
  principalType        String   @default("HUMAN")
  status               String   @default("active")
  isSystem             Boolean  @default(false)
  primaryRoleProfileId String?
  primaryRoleProfile   RoleProfile? @relation(fields: [primaryRoleProfileId], references: [id], onDelete: SetNull)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([orgId, key])
  @@index([orgId, status])
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   @default("operator")
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model Environment {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  code      String
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  prompts            Prompt[]
  publishLogsFrom    PromptPublishLog[]    @relation("PublishLogFromEnv")
  publishLogsTo      PromptPublishLog[]    @relation("PublishLogToEnv")
  knowledgeBases     KnowledgeBase[]
  knowledgeDocuments KnowledgeDocument[]
  kbPublishLogsFrom  KnowledgePublishLog[] @relation("KbPublishFromEnv")
  kbPublishLogsTo    KnowledgePublishLog[] @relation("KbPublishToEnv")
  conversations      Conversation[]
  agents             Agent[]

  @@unique([projectId, code])
  @@index([projectId])
}

model Prompt {
  id              String         @id @default(cuid())
  projectId       String
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environmentId   String
  environment     Environment    @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  key             String
  name            String
  type            String         @default("system")
  status          String         @default("active")
  activeVersionId String?        @unique
  activeVersion   PromptVersion? @relation("PromptActiveVersion", fields: [activeVersionId], references: [id], onDelete: SetNull)
  createdById     String
  createdBy       User           @relation("PromptCreatedBy", fields: [createdById], references: [id])
  updatedById     String
  updatedBy       User           @relation("PromptUpdatedBy", fields: [updatedById], references: [id])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  versions PromptVersion[] @relation("PromptVersions")

  @@unique([projectId, environmentId, key])
  @@index([projectId, environmentId])
  @@index([environmentId])
}

model PromptVersion {
  id              String          @id @default(cuid())
  promptId        String
  prompt          Prompt          @relation("PromptVersions", fields: [promptId], references: [id], onDelete: Cascade)
  version         Int
  content         String
  note            String?
  sourceVersionId String?
  sourceVersion   PromptVersion?  @relation("VersionLineage", fields: [sourceVersionId], references: [id], onDelete: SetNull)
  derivedVersions PromptVersion[] @relation("VersionLineage")
  createdById     String
  createdBy       User            @relation("PromptVersionCreatedBy", fields: [createdById], references: [id])
  createdAt       DateTime        @default(now())

  activeForPrompt Prompt? @relation("PromptActiveVersion")

  @@unique([promptId, version])
  @@index([promptId])
}

// [C7审计] 低频使用，仅在 Prompt 发布时记录。后续可考虑归档到 AuditLog
model PromptPublishLog {
  id                String      @id @default(cuid())
  projectId         String
  project           Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  promptKey         String
  fromEnvironmentId String
  fromEnvironment   Environment @relation("PublishLogFromEnv", fields: [fromEnvironmentId], references: [id])
  toEnvironmentId   String
  toEnvironment     Environment @relation("PublishLogToEnv", fields: [toEnvironmentId], references: [id])
  fromVersionId     String
  toVersionId       String
  publishedById     String
  publishedBy       User        @relation("PromptPublishBy", fields: [publishedById], references: [id])
  note              String?
  createdAt         DateTime    @default(now())

  @@index([projectId])
  @@index([promptKey])
}

// ============================================================
// 知识库（按项目 + 环境隔离，版本快照 + 发布）
// ============================================================

model KnowledgeBase {
  id              String                @id @default(cuid())
  projectId       String
  project         Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environmentId   String
  environment     Environment           @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  key             String
  name            String
  description     String?
  status          String                @default("active")
  activeVersionId String?               @unique
  activeVersion   KnowledgeBaseVersion? @relation("KBActiveVersion", fields: [activeVersionId], references: [id], onDelete: SetNull)
  createdById     String
  createdBy       User                  @relation("KnowledgeBaseCreatedBy", fields: [createdById], references: [id])
  updatedById     String
  updatedBy       User                  @relation("KnowledgeBaseUpdatedBy", fields: [updatedById], references: [id])
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  versions  KnowledgeBaseVersion[] @relation("KBVersions")
  documents KnowledgeDocument[]

  @@unique([projectId, environmentId, key])
  @@index([projectId, environmentId])
  @@index([environmentId])
}

model KnowledgeBaseVersion {
  id                String                 @id @default(cuid())
  knowledgeBaseId   String
  knowledgeBase     KnowledgeBase          @relation("KBVersions", fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  version           Int
  note              String?
  sourceVersionId   String?
  sourceVersion     KnowledgeBaseVersion?  @relation("KBVersionLineage", fields: [sourceVersionId], references: [id], onDelete: SetNull)
  derivedKbVersions KnowledgeBaseVersion[] @relation("KBVersionLineage")
  createdById       String
  createdBy         User                   @relation("KBVersionCreatedBy", fields: [createdById], references: [id])
  createdAt         DateTime               @default(now())

  documentSnapshots KnowledgeDocumentVersion[]
  activeForKb       KnowledgeBase?             @relation("KBActiveVersion")

  @@unique([knowledgeBaseId, version])
  @@index([knowledgeBaseId])
}

model KnowledgeDocument {
  id              String        @id @default(cuid())
  knowledgeBaseId String
  knowledgeBase   KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  environmentId   String
  environment     Environment   @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  title           String
  sourceType      String
  sourceUrl       String?
  status          String        @default("active")
  sortOrder       Int           @default(0)
  createdById     String
  createdBy       User          @relation("KnowledgeDocumentCreatedBy", fields: [createdById], references: [id])
  updatedById     String
  updatedBy       User          @relation("KnowledgeDocumentUpdatedBy", fields: [updatedById], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  versions KnowledgeDocumentVersion[]

  @@index([knowledgeBaseId])
  @@index([environmentId])
}

model KnowledgeDocumentVersion {
  id                     String                     @id @default(cuid())
  documentId             String
  document               KnowledgeDocument          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  knowledgeBaseVersionId String
  knowledgeBaseVersion   KnowledgeBaseVersion       @relation(fields: [knowledgeBaseVersionId], references: [id], onDelete: Cascade)
  version                Int
  content                String                     @default("")
  summary                String?
  note                   String?
  sourceVersionId        String?
  sourceVersion          KnowledgeDocumentVersion?  @relation("DocVersionLineage", fields: [sourceVersionId], references: [id], onDelete: SetNull)
  derivedDocVersions     KnowledgeDocumentVersion[] @relation("DocVersionLineage")
  createdById            String
  createdBy              User                       @relation("KDVersionCreatedBy", fields: [createdById], references: [id])
  createdAt              DateTime                   @default(now())

  @@unique([documentId, knowledgeBaseVersionId])
  @@unique([documentId, version])
  @@index([knowledgeBaseVersionId])
}

// [C7审计] 低频使用，仅在知识库发布时记录。后续可考虑归档到 AuditLog
model KnowledgePublishLog {
  id                         String      @id @default(cuid())
  projectId                  String
  project                    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  knowledgeBaseKey           String
  fromEnvironmentId          String
  fromEnvironment            Environment @relation("KbPublishFromEnv", fields: [fromEnvironmentId], references: [id])
  toEnvironmentId            String
  toEnvironment              Environment @relation("KbPublishToEnv", fields: [toEnvironmentId], references: [id])
  fromKnowledgeBaseVersionId String
  toKnowledgeBaseVersionId   String
  publishedById              String
  publishedBy                User        @relation("KBPublishedBy", fields: [publishedById], references: [id])
  note                       String?
  createdAt                  DateTime    @default(now())

  @@index([projectId])
  @@index([knowledgeBaseKey])
}

// ============================================================
// 会话管理（按项目 + 环境隔离，消息记录 + 上下文追踪）
// ============================================================

model Conversation {
  id            String      @id @default(cuid())
  projectId     String
  project       Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?       @relation("ConversationUser", fields: [userId], references: [id], onDelete: SetNull)
  title         String      @default("")
  channel       String      @default("web")
  status        String      @default("active")

  messageCount  Int   @default(0)
  inputTokens   Int   @default(0)
  outputTokens  Int   @default(0)
  totalTokens   Int   @default(0)
  estimatedCost Float @default(0)
  avgLatencyMs  Int   @default(0)

  promptId               String?
  promptVersionId        String?
  knowledgeBaseId        String?
  knowledgeBaseVersionId String?

  agentId          String?
  runtimeStatus    String  @default("idle")
  lastErrorMessage String?
  runCount         Int     @default(0)

  startedAt     DateTime  @default(now())
  lastMessageAt DateTime?
  endedAt       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  messages         Message[]
  contextSnapshots ConversationContextSnapshot[]
  toolCallTraces   ToolCallTrace[]

  @@index([projectId, environmentId])
  @@index([projectId])
  @@index([projectId, startedAt])
  @@index([environmentId])
  @@index([userId])
  @@index([status])
  @@index([lastMessageAt])
}

model Message {
  id              String       @id @default(cuid())
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role            String
  content         String       @default("")
  contentType     String       @default("text")
  sequence        Int
  modelName       String?
  inputTokens     Int          @default(0)
  outputTokens    Int          @default(0)
  latencyMs       Int          @default(0)
  status          String       @default("success")
  errorMessage    String?
  finishReason    String?
  toolName        String?
  toolCallId      String?
  parentMessageId String?
  metadataJson    String?
  createdAt       DateTime     @default(now())

  toolCallTraces ToolCallTrace[]

  @@unique([conversationId, sequence])
  @@index([conversationId])
}

// [C7审计] 低频使用，会话上下文快照。后续可考虑按需懒加载或归档
model ConversationContextSnapshot {
  id                     String       @id @default(cuid())
  conversationId         String
  conversation           Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  promptId               String?
  promptVersionId        String?
  promptKey              String?
  knowledgeBaseId        String?
  knowledgeBaseVersionId String?
  knowledgeBaseKey       String?
  environmentId          String?
  systemPromptSnapshot   String?
  retrievalConfigJson    String?
  extraConfigJson        String?
  createdAt              DateTime     @default(now())

  @@index([conversationId])
}

model AuditLog {
  id         String        @id @default(cuid())
  orgId      String?
  org        Organization? @relation(fields: [orgId], references: [id])
  projectId  String?
  project    Project?      @relation(fields: [projectId], references: [id])
  /// Phase 3A-4：可选 Workspace / Trace / 风险（历史可空）
  workspaceId String?
  traceId     String?
  riskLevel   String?
  userId     String
  user       User          @relation(fields: [userId], references: [id])
  action     String
  targetType String
  targetId   String?
  beforeData String?
  afterData  String?
  ip         String?
  userAgent  String?
  createdAt  DateTime      @default(now())

  @@index([orgId])
  @@index([projectId])
  @@index([userId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@index([orgId, workspaceId, createdAt])
  @@index([traceId])
}

// ============================================================
// Agent 配置与编排
// ============================================================

model Agent {
  id            String      @id @default(cuid())
  projectId     String
  project       Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  key           String
  name          String
  description   String?
  type          String      @default("chat")
  status        String      @default("active")

  promptId               String?
  promptVersionId        String?
  knowledgeBaseId        String?
  knowledgeBaseVersionId String?
  modelProvider          String  @default("openai")
  modelName              String  @default("gpt-5.2")
  temperature            Float   @default(0.7)
  maxTokens              Int     @default(4096)
  systemBehaviorNote     String?
  extraConfigJson        String?

  activeVersionId String?       @unique
  activeVersion   AgentVersion? @relation("AgentActiveVersion", fields: [activeVersionId], references: [id], onDelete: SetNull)

  createdById String
  createdBy   User     @relation("AgentCreatedBy", fields: [createdById], references: [id])
  updatedById String
  updatedBy   User     @relation("AgentUpdatedBy", fields: [updatedById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  versions     AgentVersion[]     @relation("AgentVersions")
  toolBindings AgentToolBinding[]

  @@unique([projectId, environmentId, key])
  @@index([projectId, environmentId])
  @@index([environmentId])
}

model AgentVersion {
  id                 String   @id @default(cuid())
  agentId            String
  agent              Agent    @relation("AgentVersions", fields: [agentId], references: [id], onDelete: Cascade)
  version            Int
  configSnapshotJson String
  changeNote         String?
  createdById        String
  createdBy          User     @relation("AgentVersionCreatedBy", fields: [createdById], references: [id])
  createdAt          DateTime @default(now())

  activeForAgent Agent? @relation("AgentActiveVersion")

  @@unique([agentId, version])
  @@index([agentId])
}

model ToolRegistry {
  id               String   @id @default(cuid())
  projectId        String
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  key              String
  name             String
  description      String?
  category         String   @default("builtin")
  type             String   @default("function")
  status           String   @default("active")
  inputSchemaJson  String?
  outputSchemaJson String?
  configJson       String?
  createdById      String
  createdBy        User     @relation("ToolCreatedBy", fields: [createdById], references: [id])
  updatedById      String
  updatedBy        User     @relation("ToolUpdatedBy", fields: [updatedById], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  agentBindings AgentToolBinding[]

  @@unique([projectId, key])
  @@index([projectId])
}

model AgentToolBinding {
  id                 String       @id @default(cuid())
  agentId            String
  agent              Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  toolId             String
  tool               ToolRegistry @relation(fields: [toolId], references: [id], onDelete: Cascade)
  enabled            Boolean      @default(true)
  sortOrder          Int          @default(0)
  configOverrideJson String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@unique([agentId, toolId])
  @@index([agentId])
  @@index([toolId])
}

// ============================================================
// Runtime: 工具调用追踪
// ============================================================

model ToolCallTrace {
  id             String       @id @default(cuid())
  projectId      String
  environmentId  String
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  messageId      String
  message        Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  agentId        String?
  toolId         String?
  toolKey        String
  toolName       String
  toolCallId     String?
  inputJson      String?
  outputJson     String?
  status         String       @default("success")
  errorMessage   String?
  durationMs     Int          @default(0)
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([messageId])
  @@index([projectId, environmentId])
}

// ============================================================
// 评估与质量反馈
// ============================================================

model ConversationFeedback {
  id                     String  @id @default(cuid())
  projectId              String
  environmentId          String
  conversationId         String
  agentId                String?
  promptId               String?
  promptVersionId        String?
  knowledgeBaseId        String?
  knowledgeBaseVersionId String?
  createdById            String

  rating            Int     @default(0)
  scoreAccuracy     Int?
  scoreHelpfulness  Int?
  scoreSafety       Int?
  scoreCompleteness Int?
  sentiment         String  @default("neutral")
  issueType         String?
  note              String?
  status            String  @default("open")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tags ConversationFeedbackTag[]

  @@index([projectId, environmentId])
  @@index([conversationId])
  @@index([status])
  @@index([rating])
  @@index([createdById])
}

model MessageFeedback {
  id             String  @id @default(cuid())
  projectId      String
  environmentId  String
  conversationId String
  messageId      String
  agentId        String?
  createdById    String

  rating    Int     @default(0)
  issueType String?
  note      String?
  status    String  @default("open")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tags MessageFeedbackTag[]

  @@index([projectId, environmentId])
  @@index([conversationId])
  @@index([messageId])
  @@index([status])
  @@index([createdById])
}

model EvaluationTag {
  id          String   @id @default(cuid())
  projectId   String
  key         String
  label       String
  category    String   @default("quality")
  color       String   @default("#6b7280")
  status      String   @default("active")
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  conversationFeedbackTags ConversationFeedbackTag[]
  messageFeedbackTags      MessageFeedbackTag[]

  @@unique([projectId, key])
  @@index([projectId])
}

model ConversationFeedbackTag {
  id         String               @id @default(cuid())
  feedbackId String
  feedback   ConversationFeedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  tagId      String
  tag        EvaluationTag        @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt  DateTime             @default(now())

  @@unique([feedbackId, tagId])
  @@index([feedbackId])
  @@index([tagId])
}

model MessageFeedbackTag {
  id         String          @id @default(cuid())
  feedbackId String
  feedback   MessageFeedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  tagId      String
  tag        EvaluationTag   @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt  DateTime        @default(now())

  @@unique([feedbackId, tagId])
  @@index([feedbackId])
  @@index([tagId])
}

model EvaluationRun {
  id             String   @id @default(cuid())
  projectId      String
  environmentId  String
  conversationId String?
  messageId      String?
  type           String   @default("manual")
  judgeModel     String?
  judgeVersion   String?
  criteriaJson   String?
  resultJson     String?
  score          Float?
  createdById    String
  createdAt      DateTime @default(now())

  @@index([projectId, environmentId])
  @@index([conversationId])
}

model Notification {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation("UserNotifications", fields: [userId], references: [id])
  orgId       String?
  projectId   String?
  type        String    @default("update")
  category    String    @default("update")
  title       String
  summary     String?
  entityType  String?
  entityId    String?
  activityId  String?
  status      String    @default("unread")
  priority    String    @default("medium")
  dueAt       DateTime?
  snoozeUntil DateTime?
  readAt      DateTime?
  doneAt      DateTime?
  sourceKey   String?   @unique
  metadata    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([projectId])
  @@index([projectId, status])
}

model UserNotificationPreference {
  id                       String   @id @default(cuid())
  userId                   String   @unique
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgId                    String?
  enableInAppNotifications Boolean  @default(true)
  onlyHighPriority         Boolean  @default(false)
  onlyMyItems              Boolean  @default(false)
  includeWatchedProjects   Boolean  @default(true)
  quietHoursEnabled        Boolean  @default(false)
  quietHoursStart          String?
  quietHoursEnd            String?
  emailEnabled             Boolean  @default(false)
  pushEnabled              Boolean  @default(false)
  enabledTypesJson         String?
  metadata                 String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([userId])
}

model ProjectNotificationRule {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId             String
  project               Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  watchEnabled          Boolean  @default(false)
  notifyProjectUpdates  Boolean  @default(true)
  notifyRuntimeFailed   Boolean  @default(true)
  notifyFeedbackCreated Boolean  @default(true)
  notifyLowEvaluations  Boolean  @default(true)
  notifyTaskDue         Boolean  @default(true)
  minimumPriority       String   @default("medium")
  metadata              String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([userId, projectId])
  @@index([projectId])
}

// ============================================================
